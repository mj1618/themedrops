{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011mukfMj3UpM4FsEB5J9S64","type":"tool_result","content":"     1→import { v } from \"convex/values\";\n     2→import { query, mutation, DatabaseReader } from \"./_generated/server\";\n     3→import { paginationOptsValidator } from \"convex/server\";\n     4→\n     5→export const list = query({\n     6→  args: { paginationOpts: paginationOptsValidator },\n     7→  handler: async (ctx, args) => {\n     8→    return await ctx.db\n     9→      .query(\"themes\")\n    10→      .withIndex(\"by_public_and_star_count\", (q) => q.eq(\"isPublic\", true))\n    11→      .order(\"desc\")\n    12→      .paginate(args.paginationOpts);\n    13→  },\n    14→});\n    15→\n    16→export const getBySlug = query({\n    17→  args: { slug: v.string() },\n    18→  handler: async (ctx, args) => {\n    19→    const theme = await ctx.db\n    20→      .query(\"themes\")\n    21→      .withIndex(\"by_slug\", (q) => q.eq(\"slug\", args.slug))\n    22→      .unique();\n    23→    if (!theme) return null;\n    24→    if (!theme.isPublic) {\n    25→      const identity = await ctx.auth.getUserIdentity();\n    26→      if (!identity) return null;\n    27→      const user = await ctx.db\n    28→        .query(\"users\")\n    29→        .withIndex(\"by_token\", (q) =>\n    30→          q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    31→        )\n    32→        .unique();\n    33→      if (!user || theme.authorId !== user._id) return null;\n    34→    }\n    35→    return theme;\n    36→  },\n    37→});\n    38→\n    39→export const getByAuthor = query({\n    40→  args: { authorId: v.id(\"users\") },\n    41→  handler: async (ctx, args) => {\n    42→    const identity = await ctx.auth.getUserIdentity();\n    43→    let currentUserId = null;\n    44→    if (identity) {\n    45→      const user = await ctx.db\n    46→        .query(\"users\")\n    47→        .withIndex(\"by_token\", (q) =>\n    48→          q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    49→        )\n    50→        .unique();\n    51→      if (user) currentUserId = user._id;\n    52→    }\n    53→\n    54→    const themes = await ctx.db\n    55→      .query(\"themes\")\n    56→      .withIndex(\"by_author\", (q) => q.eq(\"authorId\", args.authorId))\n    57→      .take(50);\n    58→\n    59→    if (currentUserId === args.authorId) return themes;\n    60→    return themes.filter((t) => t.isPublic);\n    61→  },\n    62→});\n    63→\n    64→export const getBasicInfo = query({\n    65→  args: { id: v.id(\"themes\") },\n    66→  handler: async (ctx, args) => {\n    67→    const theme = await ctx.db.get(args.id);\n    68→    if (!theme) return null;\n    69→    if (!theme.isPublic) {\n    70→      const identity = await ctx.auth.getUserIdentity();\n    71→      if (!identity) return null;\n    72→      const user = await ctx.db\n    73→        .query(\"users\")\n    74→        .withIndex(\"by_token\", (q) =>\n    75→          q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    76→        )\n    77→        .unique();\n    78→      if (!user || theme.authorId !== user._id) return null;\n    79→    }\n    80→    return { name: theme.name, slug: theme.slug };\n    81→  },\n    82→});\n    83→\n    84→export const search = query({\n    85→  args: { name: v.string() },\n    86→  handler: async (ctx, args) => {\n    87→    const results = await ctx.db\n    88→      .query(\"themes\")\n    89→      .withSearchIndex(\"search_name\", (q) => q.search(\"name\", args.name))\n    90→      .take(40);\n    91→    return results.filter((t) => t.isPublic).slice(0, 20);\n    92→  },\n    93→});\n    94→\n    95→function generateSlug(name: string): string {\n    96→  return name\n    97→    .toLowerCase()\n    98→    .replace(/\\s+/g, \"-\")\n    99→    .replace(/[^a-z0-9-]/g, \"\");\n   100→}\n   101→\n   102→async function uniqueSlug(db: DatabaseReader, name: string): Promise<string> {\n   103→  const base = generateSlug(name);\n   104→  let slug = base;\n   105→  let suffix = 2;\n   106→  while (\n   107→    await db\n   108→      .query(\"themes\")\n   109→      .withIndex(\"by_slug\", (q) => q.eq(\"slug\", slug))\n   110→      .unique()\n   111→  ) {\n   112→    slug = `${base}-${suffix}`;\n   113→    suffix++;\n   114→  }\n   115→  return slug;\n   116→}\n   117→\n   118→export const create = mutation({\n   119→  args: {\n   120→    name: v.string(),\n   121→    description: v.optional(v.string()),\n   122→    isPublic: v.boolean(),\n   123→    colors: v.object({\n   124→      background: v.optional(v.string()),\n   125→      foreground: v.optional(v.string()),\n   126→      primary: v.optional(v.string()),\n   127→      secondary: v.optional(v.string()),\n   128→      accent: v.optional(v.string()),\n   129→      muted: v.optional(v.string()),\n   130→    }),\n   131→    fonts: v.optional(\n   132→      v.object({\n   133→        sans: v.optional(v.string()),\n   134→        serif: v.optional(v.string()),\n   135→        mono: v.optional(v.string()),\n   136→      })\n   137→    ),\n   138→  },\n   139→  handler: async (ctx, args) => {\n   140→    const identity = await ctx.auth.getUserIdentity();\n   141→    if (!identity) throw new Error(\"Not authenticated\");\n   142→\n   143→    const user = await ctx.db\n   144→      .query(\"users\")\n   145→      .withIndex(\"by_token\", (q) =>\n   146→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n   147→      )\n   148→      .unique();\n   149→    if (!user) throw new Error(\"User not found\");\n   150→\n   151→    const slug = await uniqueSlug(ctx.db, args.name);\n   152→\n   153→    const id = await ctx.db.insert(\"themes\", {\n   154→      name: args.name,\n   155→      slug,\n   156→      description: args.description,\n   157→      authorId: user._id,\n   158→      isPublic: args.isPublic,\n   159→      starCount: 0,\n   160→      colors: args.colors,\n   161→      fonts: args.fonts,\n   162→    });\n   163→\n   164→    return { id, slug };\n   165→  },\n   166→});\n   167→\n   168→export const update = mutation({\n   169→  args: {\n   170→    id: v.id(\"themes\"),\n   171→    name: v.optional(v.string()),\n   172→    description: v.optional(v.string()),\n   173→    isPublic: v.optional(v.boolean()),\n   174→    colors: v.optional(\n   175→      v.object({\n   176→        background: v.optional(v.string()),\n   177→        foreground: v.optional(v.string()),\n   178→        primary: v.optional(v.string()),\n   179→        secondary: v.optional(v.string()),\n   180→        accent: v.optional(v.string()),\n   181→        muted: v.optional(v.string()),\n   182→      })\n   183→    ),\n   184→    fonts: v.optional(\n   185→      v.object({\n   186→        sans: v.optional(v.string()),\n   187→        serif: v.optional(v.string()),\n   188→        mono: v.optional(v.string()),\n   189→      })\n   190→    ),\n   191→  },\n   192→  handler: async (ctx, args) => {\n   193→    const identity = await ctx.auth.getUserIdentity();\n   194→    if (!identity) throw new Error(\"Not authenticated\");\n   195→\n   196→    const user = await ctx.db\n   197→      .query(\"users\")\n   198→      .withIndex(\"by_token\", (q) =>\n   199→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n   200→      )\n   201→      .unique();\n   202→    if (!user) throw new Error(\"User not found\");\n   203→\n   204→    const theme = await ctx.db.get(args.id);\n   205→    if (!theme) throw new Error(\"Theme not found\");\n   206→    if (theme.authorId !== user._id) throw new Error(\"Not authorized\");\n   207→\n   208→    const updates: Record<string, unknown> = {};\n   209→    if (args.name !== undefined) {\n   210→      updates.name = args.name;\n   211→      updates.slug = await uniqueSlug(ctx.db, args.name);\n   212→    }\n   213→    if (args.description !== undefined) updates.description = args.description;\n   214→    if (args.isPublic !== undefined) updates.isPublic = args.isPublic;\n   215→    if (args.colors !== undefined) updates.colors = args.colors;\n   216→    if (args.fonts !== undefined) updates.fonts = args.fonts;\n   217→\n   218→    await ctx.db.patch(args.id, updates);\n   219→  },\n   220→});\n   221→\n   222→export const remove = mutation({\n   223→  args: { id: v.id(\"themes\") },\n   224→  handler: async (ctx, args) => {\n   225→    const identity = await ctx.auth.getUserIdentity();\n   226→    if (!identity) throw new Error(\"Not authenticated\");\n   227→\n   228→    const user = await ctx.db\n   229→      .query(\"users\")\n   230→      .withIndex(\"by_token\", (q) =>\n   231→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n   232→      )\n   233→      .unique();\n   234→    if (!user) throw new Error(\"User not found\");\n   235→\n   236→    const theme = await ctx.db.get(args.id);\n   237→    if (!theme) throw new Error(\"Theme not found\");\n   238→    if (theme.authorId !== user._id) throw new Error(\"Not authorized\");\n   239→\n   240→    // Clean up all associated stars\n   241→    let stars;\n   242→    do {\n   243→      stars = await ctx.db\n   244→        .query(\"stars\")\n   245→        .withIndex(\"by_theme\", (q) => q.eq(\"themeId\", args.id))\n   246→        .take(500);\n   247→      for (const star of stars) {\n   248→        await ctx.db.delete(star._id);\n   249→      }\n   250→    } while (stars.length === 500);\n   251→\n   252→    // Clean up all associated comments\n   253→    let comments;\n   254→    do {\n   255→      comments = await ctx.db\n   256→        .query(\"comments\")\n   257→        .withIndex(\"by_theme\", (q) => q.eq(\"themeId\", args.id))\n   258→        .take(500);\n   259→      for (const comment of comments) {\n   260→        await ctx.db.delete(comment._id);\n   261→      }\n   262→    } while (comments.length === 500);\n   263→\n   264→    await ctx.db.delete(args.id);\n   265→  },\n   266→});\n   267→\n   268→export const fork = mutation({\n   269→  args: { id: v.id(\"themes\") },\n   270→  handler: async (ctx, args) => {\n   271→    const identity = await ctx.auth.getUserIdentity();\n   272→    if (!identity) throw new Error(\"Not authenticated\");\n   273→\n   274→    const user = await ctx.db\n   275→      .query(\"users\")\n   276→      .withIndex(\"by_token\", (q) =>\n   277→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n   278→      )\n   279→      .unique();\n   280→    if (!user) throw new Error(\"User not found\");\n   281→\n   282→    const original = await ctx.db.get(args.id);\n   283→    if (!original) throw new Error(\"Theme not found\");\n   284→    if (!original.isPublic && original.authorId !== user._id) {\n   285→      throw new Error(\"Not authorized\");\n   286→    }\n   287→\n   288→    const slug = await uniqueSlug(ctx.db, original.name + \" fork\");\n   289→\n   290→    const id = await ctx.db.insert(\"themes\", {\n   291→      name: original.name + \" (fork)\",\n   292→      slug,\n   293→      description: original.description,\n   294→      authorId: user._id,\n   295→      forkedFromId: original._id,\n   296→      isPublic: false,\n   297→      starCount: 0,\n   298→      colors: original.colors,\n   299→      fonts: original.fonts,\n   300→    });\n   301→\n   302→    return { id, slug };\n   303→  },\n   304→});\n   305→"}]},"parent_tool_use_id":"toolu_01LtCLpwY6DhCu8Bxdpacgh5","session_id":"5c840083-39b9-4622-8789-f41c7bcab736","uuid":"bbc4012e-16e7-4965-85f4-e4188775f0e7","timestamp":"2026-03-27T23:48:06.807Z"}
