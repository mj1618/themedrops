{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WDSkQK24YqrUVoCciTuJdx","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { useParams, useRouter } from \"next/navigation\";\n     4→import { useQuery, useMutation } from \"convex/react\";\n     5→import { api } from \"../../../../convex/_generated/api\";\n     6→import { useState } from \"react\";\n     7→import AuthControls from \"../../components/AuthControls\";\n     8→import CreateThemeLink from \"../../components/CreateThemeLink\";\n     9→const COLOR_LABELS: { key: string; label: string }[] = [\n    10→  { key: \"background\", label: \"Background\" },\n    11→  { key: \"foreground\", label: \"Foreground\" },\n    12→  { key: \"primary\", label: \"Primary\" },\n    13→  { key: \"secondary\", label: \"Secondary\" },\n    14→  { key: \"accent\", label: \"Accent\" },\n    15→  { key: \"muted\", label: \"Muted\" },\n    16→];\n    17→\n    18→function ColorSwatch({ color, label }: { color: string; label: string }) {\n    19→  return (\n    20→    <div className=\"flex flex-col items-center gap-2\">\n    21→      <div\n    22→        className=\"w-16 h-16 rounded-xl border border-gray-200 shadow-sm\"\n    23→        style={{ backgroundColor: color }}\n    24→      />\n    25→      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n    26→      <span className=\"text-xs font-mono text-gray-400\">{color}</span>\n    27→    </div>\n    28→  );\n    29→}\n    30→\n    31→function LivePreview({\n    32→  colors,\n    33→}: {\n    34→  colors: Record<string, string | undefined>;\n    35→}) {\n    36→  return (\n    37→    <div\n    38→      className=\"rounded-xl border p-6 space-y-4\"\n    39→      style={{\n    40→        backgroundColor: colors.background ?? \"#ffffff\",\n    41→        color: colors.foreground ?? \"#000000\",\n    42→        borderColor: colors.muted ?? \"#e5e7eb\",\n    43→      }}\n    44→    >\n    45→      <h3 className=\"text-lg font-semibold\">Live Preview</h3>\n    46→      <p style={{ color: colors.muted ?? \"#6b7280\" }} className=\"text-sm\">\n    47→        This is how the theme looks when applied to a card.\n    48→      </p>\n    49→      <div className=\"flex gap-3\">\n    50→        <button\n    51→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    52→          style={{ backgroundColor: colors.primary ?? \"#3b82f6\" }}\n    53→        >\n    54→          Primary\n    55→        </button>\n    56→        <button\n    57→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    58→          style={{ backgroundColor: colors.secondary ?? \"#6366f1\" }}\n    59→        >\n    60→          Secondary\n    61→        </button>\n    62→        <button\n    63→          className=\"px-4 py-2 rounded-lg text-sm font-medium border\"\n    64→          style={{\n    65→            backgroundColor: colors.accent ?? \"#f59e0b\",\n    66→            borderColor: colors.muted ?? \"#e5e7eb\",\n    67→          }}\n    68→        >\n    69→          Accent\n    70→        </button>\n    71→      </div>\n    72→    </div>\n    73→  );\n    74→}\n    75→\n    76→export default function ThemeDetailPage() {\n    77→  const params = useParams<{ slug: string }>();\n    78→  const router = useRouter();\n    79→  const slug = params.slug;\n    80→\n    81→  const theme = useQuery(api.themes.getBySlug, { slug });\n    82→  const author = useQuery(\n    83→    api.users.get,\n    84→    theme ? { id: theme.authorId } : \"skip\"\n    85→  );\n    86→  const currentUser = useQuery(api.users.getCurrentUser);\n    87→\n    88→  // Stars\n    89→  const isStarred = useQuery(\n    90→    api.stars.isStarred,\n    91→    theme ? { themeId: theme._id } : \"skip\"\n    92→  );\n    93→  const toggleStar = useMutation(api.stars.toggle);\n    94→\n    95→  // Comments\n    96→  const comments = useQuery(\n    97→    api.comments.listByTheme,\n    98→    theme ? { themeId: theme._id } : \"skip\"\n    99→  );\n   100→  const createComment = useMutation(api.comments.create);\n   101→  const [commentBody, setCommentBody] = useState(\"\");\n   102→  const [submittingComment, setSubmittingComment] = useState(false);\n   103→\n   104→  // Fork\n   105→  const forkTheme = useMutation(api.themes.fork);\n   106→  const [forking, setForking] = useState(false);\n   107→\n   108→  // Forked-from theme info (for link)\n   109→  const forkedFrom = useQuery(\n   110→    api.themes.getBasicInfo,\n   111→    theme?.forkedFromId ? { id: theme.forkedFromId } : \"skip\"\n   112→  );\n   113→\n   114→  // Loading state\n   115→  if (theme === undefined) {\n   116→    return (\n   117→      <div className=\"min-h-screen flex items-center justify-center\">\n   118→        <div className=\"animate-pulse text-gray-400 text-lg\">\n   119→          Loading theme...\n   120→        </div>\n   121→      </div>\n   122→    );\n   123→  }\n   124→\n   125→  // Not found\n   126→  if (theme === null) {\n   127→    return (\n   128→      <div className=\"min-h-screen flex flex-col items-center justify-center gap-4\">\n   129→        <h1 className=\"text-2xl font-bold text-gray-800\">Theme not found</h1>\n   130→        <p className=\"text-gray-500\">\n   131→          This theme doesn&apos;t exist or is private.\n   132→        </p>\n   133→        <a href=\"/\" className=\"text-blue-600 hover:underline text-sm\">\n   134→          Back to gallery\n   135→        </a>\n   136→      </div>\n   137→    );\n   138→  }\n   139→\n   140→  const colors = theme.colors as Record<string, string | undefined>;\n   141→\n   142→  async function handleToggleStar() {\n   143→    if (!theme || !currentUser) return;\n   144→    await toggleStar({ themeId: theme._id });\n   145→  }\n   146→\n   147→  async function handleSubmitComment(e: React.FormEvent) {\n   148→    e.preventDefault();\n   149→    if (!theme || !commentBody.trim()) return;\n   150→    setSubmittingComment(true);\n   151→    try {\n   152→      await createComment({ themeId: theme._id, body: commentBody.trim() });\n   153→      setCommentBody(\"\");\n   154→    } finally {\n   155→      setSubmittingComment(false);\n   156→    }\n   157→  }\n   158→\n   159→  async function handleFork() {\n   160→    if (!theme) return;\n   161→    setForking(true);\n   162→    try {\n   163→      const result = await forkTheme({ id: theme._id });\n   164→      if (result) {\n   165→        router.push(`/theme/${result.slug}`);\n   166→      }\n   167→    } catch {\n   168→      // Fork may fail if not authenticated\n   169→    } finally {\n   170→      setForking(false);\n   171→    }\n   172→  }\n   173→\n   174→  return (\n   175→    <div className=\"min-h-screen bg-gray-50\">\n   176→      {/* Header */}\n   177→      <header className=\"bg-white border-b border-gray-200\">\n   178→        <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n   179→          <a\n   180→            href=\"/\"\n   181→            className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n   182→          >\n   183→            ThemeDrops\n   184→          </a>\n   185→          <div className=\"flex items-center gap-3\">\n   186→            <CreateThemeLink />\n   187→            <AuthControls />\n   188→          </div>\n   189→        </div>\n   190→      </header>\n   191→\n   192→      <main className=\"max-w-4xl mx-auto px-6 py-10 space-y-10\">\n   193→        {/* Theme header */}\n   194→        <div className=\"space-y-3\">\n   195→          <div className=\"flex items-start justify-between gap-4\">\n   196→            <div className=\"space-y-1\">\n   197→              <h1 className=\"text-3xl font-bold text-gray-900\">{theme.name}</h1>\n   198→              {author && (\n   199→                <p className=\"text-sm text-gray-500\">\n   200→                  by{\" \"}\n   201→                  <span className=\"font-medium text-gray-700\">\n   202→                    {author.displayName ?? author.username}\n   203→                  </span>\n   204→                </p>\n   205→              )}\n   206→            </div>\n   207→\n   208→            {/* Star button */}\n   209→            <button\n   210→              onClick={handleToggleStar}\n   211→              disabled={!currentUser}\n   212→              className={`flex items-center gap-1.5 px-4 py-2 rounded-lg border text-sm font-medium transition-colors ${\n   213→                isStarred\n   214→                  ? \"bg-yellow-50 border-yellow-300 text-yellow-700\"\n   215→                  : \"bg-white border-gray-200 text-gray-600 hover:bg-gray-50\"\n   216→              } ${!currentUser ? \"opacity-50 cursor-not-allowed\" : \"cursor-pointer\"}`}\n   217→              title={!currentUser ? \"Sign in to star themes\" : undefined}\n   218→            >\n   219→              <span className=\"text-lg\">{isStarred ? \"\\u2605\" : \"\\u2606\"}</span>\n   220→              <span>{theme.starCount}</span>\n   221→            </button>\n   222→          </div>\n   223→\n   224→          {theme.description && (\n   225→            <p className=\"text-gray-600 leading-relaxed\">{theme.description}</p>\n   226→          )}\n   227→\n   228→          {theme.forkedFromId && forkedFrom && (\n   229→            <p className=\"text-sm text-gray-400 italic\">\n   230→              Forked from <a href={`/theme/${forkedFrom.slug}`} className=\"text-blue-500 hover:underline\">{forkedFrom.name}</a>\n   231→            </p>\n   232→          )}\n   233→\n   234→          <p className=\"text-xs text-gray-400 font-mono bg-gray-100 inline-block px-2 py-1 rounded\">\n   235→            API: /api/theme/{theme.slug}\n   236→          </p>\n   237→        </div>\n   238→\n   239→        {/* Color palette */}\n   240→        <section className=\"space-y-4\">\n   241→          <h2 className=\"text-lg font-semibold text-gray-800\">Color Palette</h2>\n   242→          <div className=\"flex flex-wrap gap-6\">\n   243→            {COLOR_LABELS.map(({ key, label }) => {\n   244→              const color = colors[key];\n   245→              if (!color) return null;\n   246→              return <ColorSwatch key={key} color={color} label={label} />;\n   247→            })}\n   248→          </div>\n   249→        </section>\n   250→\n   251→        {/* Live preview */}\n   252→        <section className=\"space-y-4\">\n   253→          <h2 className=\"text-lg font-semibold text-gray-800\">Preview</h2>\n   254→          <LivePreview colors={colors} />\n   255→        </section>\n   256→\n   257→        {/* Fonts */}\n   258→        {theme.fonts &&\n   259→          (theme.fonts.sans || theme.fonts.serif || theme.fonts.mono) && (\n   260→            <section className=\"space-y-4\">\n   261→              <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   262→              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   263→                {theme.fonts.sans && (\n   264→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   265→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   266→                      Sans\n   267→                    </p>\n   268→                    <p\n   269→                      className=\"text-lg\"\n   270→                      style={{ fontFamily: theme.fonts.sans }}\n   271→                    >\n   272→                      {theme.fonts.sans}\n   273→                    </p>\n   274→                    <p\n   275→                      className=\"text-sm text-gray-500 mt-1\"\n   276→                      style={{ fontFamily: theme.fonts.sans }}\n   277→                    >\n   278→                      The quick brown fox jumps over the lazy dog.\n   279→                    </p>\n   280→                  </div>\n   281→                )}\n   282→                {theme.fonts.serif && (\n   283→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   284→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   285→                      Serif\n   286→                    </p>\n   287→                    <p\n   288→                      className=\"text-lg\"\n   289→                      style={{ fontFamily: theme.fonts.serif }}\n   290→                    >\n   291→                      {theme.fonts.serif}\n   292→                    </p>\n   293→                    <p\n   294→                      className=\"text-sm text-gray-500 mt-1\"\n   295→                      style={{ fontFamily: theme.fonts.serif }}\n   296→                    >\n   297→                      The quick brown fox jumps over the lazy dog.\n   298→                    </p>\n   299→                  </div>\n   300→                )}\n   301→                {theme.fonts.mono && (\n   302→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   303→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   304→                      Mono\n   305→                    </p>\n   306→                    <p\n   307→                      className=\"text-lg font-mono\"\n   308→                      style={{ fontFamily: theme.fonts.mono }}\n   309→                    >\n   310→                      {theme.fonts.mono}\n   311→                    </p>\n   312→                    <p\n   313→                      className=\"text-sm text-gray-500 mt-1\"\n   314→                      style={{ fontFamily: theme.fonts.mono }}\n   315→                    >\n   316→                      The quick brown fox jumps over the lazy dog.\n   317→                    </p>\n   318→                  </div>\n   319→                )}\n   320→              </div>\n   321→            </section>\n   322→          )}\n   323→\n   324→        {/* Fork button */}\n   325→        {currentUser && (\n   326→          <div>\n   327→            <button\n   328→              onClick={handleFork}\n   329→              disabled={forking}\n   330→              className=\"px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors disabled:opacity-50\"\n   331→            >\n   332→              {forking ? \"Forking...\" : \"Fork this theme\"}\n   333→            </button>\n   334→          </div>\n   335→        )}\n   336→\n   337→        {/* Comments */}\n   338→        <section className=\"space-y-6\">\n   339→          <h2 className=\"text-lg font-semibold text-gray-800\">\n   340→            Comments{\" \"}\n   341→            {comments && comments.length > 0 && (\n   342→              <span className=\"text-gray-400 font-normal\">\n   343→                ({comments.length})\n   344→              </span>\n   345→            )}\n   346→          </h2>\n   347→\n   348→          {comments === undefined && (\n   349→            <p className=\"text-gray-400 text-sm animate-pulse\">\n   350→              Loading comments...\n   351→            </p>\n   352→          )}\n   353→\n   354→          {comments && comments.length === 0 && (\n   355→            <p className=\"text-gray-400 text-sm\">No comments yet.</p>\n   356→          )}\n   357→\n   358→          {comments && comments.length > 0 && (\n   359→            <div className=\"space-y-4\">\n   360→              {comments.map((comment) => (\n   361→                <div\n   362→                  key={comment._id}\n   363→                  className=\"bg-white rounded-lg border border-gray-200 p-4\"\n   364→                >\n   365→                  <div className=\"flex items-center gap-2 mb-2\">\n   366→                    {comment.author?.avatarUrl && (\n   367→                      <img\n   368→                        src={comment.author.avatarUrl}\n   369→                        alt=\"\"\n   370→                        className=\"w-6 h-6 rounded-full\"\n   371→                      />\n   372→                    )}\n   373→                    <span className=\"text-sm font-medium text-gray-700\">\n   374→                      {comment.author?.displayName ??\n   375→                        comment.author?.username ??\n   376→                        \"Unknown\"}\n   377→                    </span>\n   378→                  </div>\n   379→                  <p className=\"text-sm text-gray-600\">{comment.body}</p>\n   380→                </div>\n   381→              ))}\n   382→            </div>\n   383→          )}\n   384→\n   385→          {/* Add comment form */}\n   386→          {currentUser && (\n   387→            <form onSubmit={handleSubmitComment} className=\"flex gap-3\">\n   388→              <input\n   389→                type=\"text\"\n   390→                value={commentBody}\n   391→                onChange={(e) => setCommentBody(e.target.value)}\n   392→                placeholder=\"Add a comment...\"\n   393→                className=\"flex-1 px-4 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n   394→              />\n   395→              <button\n   396→                type=\"submit\"\n   397→                disabled={!commentBody.trim() || submittingComment}\n   398→                className=\"px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n   399→              >\n   400→                {submittingComment ? \"Posting...\" : \"Post\"}\n   401→              </button>\n   402→            </form>\n   403→          )}\n   404→        </section>\n   405→      </main>\n   406→    </div>\n   407→  );\n   408→}\n   409→"}]},"parent_tool_use_id":"toolu_01LtCLpwY6DhCu8Bxdpacgh5","session_id":"5c840083-39b9-4622-8789-f41c7bcab736","uuid":"67c23321-69f4-4a97-a4f5-5a7dacefd400","timestamp":"2026-03-27T23:48:06.681Z"}
