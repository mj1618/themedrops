{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R3y6s26tYhoipCj5pLkL9A","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { usePaginatedQuery, useQuery } from \"convex/react\";\n     4→import { api } from \"../../convex/_generated/api\";\n     5→import { Doc } from \"../../convex/_generated/dataModel\";\n     6→import { useState, useEffect, useRef, useCallback } from \"react\";\n     7→import Link from \"next/link\";\n     8→import AuthControls from \"./components/AuthControls\";\n     9→import CreateThemeLink from \"./components/CreateThemeLink\";\n    10→\n    11→const COLOR_KEYS = [\n    12→  \"background\",\n    13→  \"foreground\",\n    14→  \"primary\",\n    15→  \"secondary\",\n    16→  \"accent\",\n    17→  \"muted\",\n    18→] as const;\n    19→\n    20→function useDebounce(value: string, delay: number) {\n    21→  const [debounced, setDebounced] = useState(value);\n    22→  useEffect(() => {\n    23→    const timer = setTimeout(() => setDebounced(value), delay);\n    24→    return () => clearTimeout(timer);\n    25→  }, [value, delay]);\n    26→  return debounced;\n    27→}\n    28→\n    29→function ThemeCard({\n    30→  theme,\n    31→  index,\n    32→}: {\n    33→  theme: Doc<\"themes\">;\n    34→  index: number;\n    35→}) {\n    36→  const author = useQuery(api.users.get, { id: theme.authorId });\n    37→  const colors = theme.colors;\n    38→  const primaryColor = colors.primary ?? colors.accent ?? \"#6366f1\";\n    39→  const bgColor = colors.background ?? \"#ffffff\";\n    40→  const fgColor = colors.foreground ?? \"#000000\";\n    41→\n    42→  return (\n    43→    <Link\n    44→      href={`/theme/${theme.slug}`}\n    45→      className=\"group relative flex flex-col rounded-2xl border border-gray-200/80 bg-white overflow-hidden transition-all duration-300 hover:shadow-xl hover:shadow-gray-200/50 hover:-translate-y-1 hover:border-gray-300/80\"\n    46→      style={{\n    47→        animationDelay: `${index * 60}ms`,\n    48→        animation: \"cardIn 0.5s ease-out both\",\n    49→      }}\n    50→    >\n    51→      {/* Color bar — the hero of each card */}\n    52→      <div className=\"relative h-28 overflow-hidden\">\n    53→        <div className=\"absolute inset-0 flex\">\n    54→          {COLOR_KEYS.map((key) => {\n    55→            const color = colors[key];\n    56→            if (!color) return null;\n    57→            return (\n    58→              <div\n    59→                key={key}\n    60→                className=\"flex-1 transition-all duration-300 group-hover:flex-[1.2]\"\n    61→                style={{ backgroundColor: color }}\n    62→              />\n    63→            );\n    64→          })}\n    65→        </div>\n    66→        {/* Subtle overlay fade at bottom */}\n    67→        <div className=\"absolute bottom-0 left-0 right-0 h-8 bg-gradient-to-t from-white to-transparent\" />\n    68→      </div>\n    69→\n    70→      {/* Card content */}\n    71→      <div className=\"flex flex-col flex-1 px-5 pb-5 pt-3\">\n    72→        <h3 className=\"text-base font-semibold text-gray-900 tracking-tight group-hover:text-gray-700 transition-colors truncate\">\n    73→          {theme.name}\n    74→        </h3>\n    75→\n    76→        {author && (\n    77→          <p className=\"text-xs text-gray-400 mt-0.5 truncate\">\n    78→            {author.displayName ?? author.username}\n    79→          </p>\n    80→        )}\n    81→\n    82→        {theme.description && (\n    83→          <p className=\"text-xs text-gray-500 mt-2 line-clamp-2 leading-relaxed\">\n    84→            {theme.description}\n    85→          </p>\n    86→        )}\n    87→\n    88→        <div className=\"mt-auto pt-4 flex items-center justify-between\">\n    89→          {/* Mini swatch row */}\n    90→          <div className=\"flex gap-1\">\n    91→            {COLOR_KEYS.map((key) => {\n    92→              const color = colors[key];\n    93→              if (!color) return null;\n    94→              return (\n    95→                <div\n    96→                  key={key}\n    97→                  className=\"w-4 h-4 rounded-full border border-gray-200/60 shadow-sm\"\n    98→                  style={{ backgroundColor: color }}\n    99→                  title={`${key}: ${color}`}\n   100→                />\n   101→              );\n   102→            })}\n   103→          </div>\n   104→\n   105→          {/* Star count */}\n   106→          <div className=\"flex items-center gap-1 text-xs text-gray-400\">\n   107→            <span className=\"text-amber-400\">&#9733;</span>\n   108→            <span>{theme.starCount}</span>\n   109→          </div>\n   110→        </div>\n   111→\n   112→        {/* Preview strip at bottom */}\n   113→        <div\n   114→          className=\"mt-3 rounded-lg px-3 py-2 flex items-center justify-between\"\n   115→          style={{ backgroundColor: bgColor }}\n   116→        >\n   117→          <span\n   118→            className=\"text-[10px] font-medium truncate\"\n   119→            style={{ color: fgColor }}\n   120→          >\n   121→            Aa Preview\n   122→          </span>\n   123→          <div\n   124→            className=\"w-10 h-4 rounded\"\n   125→            style={{ backgroundColor: primaryColor }}\n   126→          />\n   127→        </div>\n   128→      </div>\n   129→    </Link>\n   130→  );\n   131→}\n   132→\n   133→function CardSkeleton() {\n   134→  return (\n   135→    <div className=\"flex flex-col rounded-2xl border border-gray-100 bg-white overflow-hidden animate-pulse\">\n   136→      <div className=\"h-28 bg-gray-100\" />\n   137→      <div className=\"px-5 pb-5 pt-3 space-y-3\">\n   138→        <div className=\"h-4 bg-gray-100 rounded w-2/3\" />\n   139→        <div className=\"h-3 bg-gray-50 rounded w-1/3\" />\n   140→        <div className=\"h-3 bg-gray-50 rounded w-full mt-4\" />\n   141→        <div className=\"flex justify-between items-center pt-2\">\n   142→          <div className=\"flex gap-1\">\n   143→            {[...Array(6)].map((_, i) => (\n   144→              <div key={i} className=\"w-4 h-4 rounded-full bg-gray-100\" />\n   145→            ))}\n   146→          </div>\n   147→          <div className=\"h-3 w-6 bg-gray-100 rounded\" />\n   148→        </div>\n   149→      </div>\n   150→    </div>\n   151→  );\n   152→}\n   153→\n   154→export default function Home() {\n   155→  const [searchInput, setSearchInput] = useState(\"\");\n   156→  const debouncedSearch = useDebounce(searchInput, 300);\n   157→  const isSearching = debouncedSearch.length > 0;\n   158→\n   159→  const {\n   160→    results: pagedThemes,\n   161→    status,\n   162→    loadMore,\n   163→  } = usePaginatedQuery(api.themes.list, {}, { initialNumItems: 20 });\n   164→\n   165→  const searchResults = useQuery(\n   166→    api.themes.search,\n   167→    isSearching ? { name: debouncedSearch } : \"skip\"\n   168→  );\n   169→\n   170→  const themes = isSearching ? searchResults : pagedThemes;\n   171→  const isLoading = themes === undefined;\n   172→\n   173→  const inputRef = useRef<HTMLInputElement>(null);\n   174→\n   175→  const handleClearSearch = useCallback(() => {\n   176→    setSearchInput(\"\");\n   177→    inputRef.current?.focus();\n   178→  }, []);\n   179→\n   180→  return (\n   181→    <div className=\"min-h-screen bg-gray-50\">\n   182→      <style>{`\n   183→        @keyframes cardIn {\n   184→          from {\n   185→            opacity: 0;\n   186→            transform: translateY(12px);\n   187→          }\n   188→          to {\n   189→            opacity: 1;\n   190→            transform: translateY(0);\n   191→          }\n   192→        }\n   193→        @keyframes fadeIn {\n   194→          from { opacity: 0; }\n   195→          to { opacity: 1; }\n   196→        }\n   197→        @keyframes heroShift {\n   198→          0%, 100% { background-position: 0% 50%; }\n   199→          50% { background-position: 100% 50%; }\n   200→        }\n   201→      `}</style>\n   202→\n   203→      {/* Hero */}\n   204→      <header className=\"relative overflow-hidden border-b border-gray-200 bg-white\">\n   205→        {/* Animated gradient backdrop */}\n   206→        <div\n   207→          className=\"absolute inset-0 opacity-[0.035]\"\n   208→          style={{\n   209→            backgroundImage:\n   210→              \"radial-gradient(ellipse at 20% 50%, #6366f1, transparent 50%), radial-gradient(ellipse at 80% 50%, #f59e0b, transparent 50%), radial-gradient(ellipse at 50% 0%, #ec4899, transparent 50%)\",\n   211→            backgroundSize: \"200% 200%\",\n   212→            animation: \"heroShift 20s ease-in-out infinite\",\n   213→          }}\n   214→        />\n   215→\n   216→        <div className=\"relative max-w-6xl mx-auto px-6 py-16 sm:py-20\">\n   217→          <div className=\"absolute top-6 right-6 flex items-center gap-3\">\n   218→            <CreateThemeLink />\n   219→            <AuthControls />\n   220→          </div>\n   221→          <div className=\"max-w-2xl\">\n   222→            <h1 className=\"text-4xl sm:text-5xl font-bold tracking-tight text-gray-900\">\n   223→              Theme\n   224→              <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-amber-500\">\n   225→                Drops\n   226→              </span>\n   227→            </h1>\n   228→            <p className=\"mt-4 text-lg text-gray-500 leading-relaxed max-w-lg\">\n   229→              Discover, share, and remix color and typography themes for any\n   230→              application.\n   231→            </p>\n   232→          </div>\n   233→\n   234→          {/* Search */}\n   235→          <div className=\"mt-8 max-w-xl relative\">\n   236→            <div className=\"absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none\">\n   237→              <svg\n   238→                width=\"18\"\n   