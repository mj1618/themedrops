{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013wsdbdAHJCH3Qwmorwj6Ve","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { useParams, useRouter } from \"next/navigation\";\n     4→import { useQuery, useMutation } from \"convex/react\";\n     5→import { api } from \"../../../../convex/_generated/api\";\n     6→import { useState } from \"react\";\n     7→import Link from \"next/link\";\n     8→import AuthControls from \"../../components/AuthControls\";\n     9→import CreateThemeLink from \"../../components/CreateThemeLink\";\n    10→\n    11→const COLOR_LABELS: { key: string; label: string }[] = [\n    12→  { key: \"background\", label: \"Background\" },\n    13→  { key: \"foreground\", label: \"Foreground\" },\n    14→  { key: \"primary\", label: \"Primary\" },\n    15→  { key: \"secondary\", label: \"Secondary\" },\n    16→  { key: \"accent\", label: \"Accent\" },\n    17→  { key: \"muted\", label: \"Muted\" },\n    18→];\n    19→\n    20→const FONT_KEYS = [\"sans\", \"serif\", \"mono\"] as const;\n    21→\n    22→function ColorSwatch({ color, label }: { color: string; label: string }) {\n    23→  return (\n    24→    <div className=\"flex flex-col items-center gap-2\">\n    25→      <div\n    26→        className=\"w-16 h-16 rounded-xl border border-gray-200 shadow-sm\"\n    27→        style={{ backgroundColor: color }}\n    28→      />\n    29→      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n    30→      <span className=\"text-xs font-mono text-gray-400\">{color}</span>\n    31→    </div>\n    32→  );\n    33→}\n    34→\n    35→function EditableColorSwatch({\n    36→  color,\n    37→  label,\n    38→  onChange,\n    39→}: {\n    40→  color: string;\n    41→  label: string;\n    42→  onChange: (value: string) => void;\n    43→}) {\n    44→  return (\n    45→    <div className=\"flex flex-col items-center gap-2\">\n    46→      <label className=\"relative w-16 h-16 rounded-xl border border-gray-200 shadow-sm cursor-pointer overflow-hidden\">\n    47→        <div\n    48→          className=\"absolute inset-0\"\n    49→          style={{ backgroundColor: color }}\n    50→        />\n    51→        <input\n    52→          type=\"color\"\n    53→          value={color}\n    54→          onChange={(e) => onChange(e.target.value)}\n    55→          className=\"absolute inset-0 opacity-0 cursor-pointer\"\n    56→        />\n    57→      </label>\n    58→      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n    59→      <input\n    60→        type=\"text\"\n    61→        value={color}\n    62→        onChange={(e) => onChange(e.target.value)}\n    63→        className=\"text-xs font-mono text-gray-600 w-20 text-center border border-gray-200 rounded px-1 py-0.5 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n    64→      />\n    65→    </div>\n    66→  );\n    67→}\n    68→\n    69→function LivePreview({\n    70→  colors,\n    71→}: {\n    72→  colors: Record<string, string | undefined>;\n    73→}) {\n    74→  return (\n    75→    <div\n    76→      className=\"rounded-xl border p-6 space-y-4\"\n    77→      style={{\n    78→        backgroundColor: colors.background ?? \"#ffffff\",\n    79→        color: colors.foreground ?? \"#000000\",\n    80→        borderColor: colors.muted ?? \"#e5e7eb\",\n    81→      }}\n    82→    >\n    83→      <h3 className=\"text-lg font-semibold\">Live Preview</h3>\n    84→      <p style={{ color: colors.muted ?? \"#6b7280\" }} className=\"text-sm\">\n    85→        This is how the theme looks when applied to a card.\n    86→      </p>\n    87→      <div className=\"flex gap-3\">\n    88→        <button\n    89→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    90→          style={{ backgroundColor: colors.primary ?? \"#3b82f6\" }}\n    91→        >\n    92→          Primary\n    93→        </button>\n    94→        <button\n    95→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    96→          style={{ backgroundColor: colors.secondary ?? \"#6366f1\" }}\n    97→        >\n    98→          Secondary\n    99→        </button>\n   100→        <button\n   101→          className=\"px-4 py-2 rounded-lg text-sm font-medium border\"\n   102→          style={{\n   103→            backgroundColor: colors.accent ?? \"#f59e0b\",\n   104→            borderColor: colors.muted ?? \"#e5e7eb\",\n   105→          }}\n   106→        >\n   107→          Accent\n   108→        </button>\n   109→      </div>\n   110→    </div>\n   111→  );\n   112→}\n   113→\n   114→export default function ThemeDetailPage() {\n   115→  const params = useParams<{ slug: string }>();\n   116→  const router = useRouter();\n   117→  const slug = params.slug;\n   118→\n   119→  const theme = useQuery(api.themes.getBySlug, { slug });\n   120→  const author = useQuery(\n   121→    api.users.get,\n   122→    theme ? { id: theme.authorId } : \"skip\"\n   123→  );\n   124→  const currentUser = useQuery(api.users.getCurrentUser);\n   125→\n   126→  // Stars\n   127→  const isStarred = useQuery(\n   128→    api.stars.isStarred,\n   129→    theme ? { themeId: theme._id } : \"skip\"\n   130→  );\n   131→  const toggleStar = useMutation(api.stars.toggle);\n   132→\n   133→  // Comments\n   134→  const comments = useQuery(\n   135→    api.comments.listByTheme,\n   136→    theme ? { themeId: theme._id } : \"skip\"\n   137→  );\n   138→  const createComment = useMutation(api.comments.create);\n   139→  const removeComment = useMutation(api.comments.remove);\n   140→  const [commentBody, setCommentBody] = useState(\"\");\n   141→  const [submittingComment, setSubmittingComment] = useState(false);\n   142→  const [deletingCommentId, setDeletingCommentId] = useState<string | null>(null);\n   143→\n   144→  // Fork\n   145→  const forkTheme = useMutation(api.themes.fork);\n   146→  const [forking, setForking] = useState(false);\n   147→\n   148→  // Forked-from theme info (for link)\n   149→  const forkedFrom = useQuery(\n   150→    api.themes.getBasicInfo,\n   151→    theme?.forkedFromId ? { id: theme.forkedFromId } : \"skip\"\n   152→  );\n   153→\n   154→  // Edit/Delete mutations\n   155→  const updateTheme = useMutation(api.themes.update);\n   156→  const removeTheme = useMutation(api.themes.remove);\n   157→\n   158→  // Edit mode state\n   159→  const [editing, setEditing] = useState(false);\n   160→  const [editName, setEditName] = useState(\"\");\n   161→  const [editDescription, setEditDescription] = useState(\"\");\n   162→  const [editIsPublic, setEditIsPublic] = useState(true);\n   163→  const [editColors, setEditColors] = useState<Record<string, string>>({});\n   164→  const [editFonts, setEditFonts] = useState<Record<string, string>>({});\n   165→  const [saving, setSaving] = useState(false);\n   166→  const [saveError, setSaveError] = useState<string | null>(null);\n   167→\n   168→  // Delete state\n   169→  const [confirmingDelete, setConfirmingDelete] = useState(false);\n   170→  const [deleting, setDeleting] = useState(false);\n   171→  const [deleteError, setDeleteError] = useState<string | null>(null);\n   172→\n   173→  // Owner detection\n   174→  const isOwner = !!(currentUser && theme && currentUser._id === theme.authorId);\n   175→\n   176→  function enterEditMode() {\n   177→    if (!theme) return;\n   178→    setEditName(theme.name);\n   179→    setEditDescription(theme.description ?? \"\");\n   180→    setEditIsPublic(theme.isPublic);\n   181→    const c: Record<string, string> = {};\n   182→    const themeColors = theme.colors as Record<string, string | undefined>;\n   183→    for (const { key } of COLOR_LABELS) {\n   184→      if (themeColors[key]) c[key] = themeColors[key]!;\n   185→    }\n   186→    setEditColors(c);\n   187→    const f: Record<string, string> = {};\n   188→    if (theme.fonts) {\n   189→      for (const k of FONT_KEYS) {\n   190→        if (theme.fonts[k]) f[k] = theme.fonts[k]!;\n   191→      }\n   192→    }\n   193→    setEditFonts(f);\n   194→    setSaveError(null);\n   195→    setEditing(true);\n   196→  }\n   197→\n   198→  function cancelEdit() {\n   199→    setEditing(false);\n   200→    setSaveError(null);\n   201→  }\n   202→\n   203→  async function handleSave() {\n   204→    if (!theme) return;\n   205→    setSaving(true);\n   206→    setSaveError(null);\n   207→    try {\n   208→      const updates: Record<string, unknown> = { id: theme._id };\n   209→      if (editName !== theme.name) updates.name = editName;\n   210→      if (editDescription !== (theme.description ?? \"\"))\n   211→        updates.description = editDescription;\n   212→      if (editIsPublic !== theme.isPublic) updates.isPublic = editIsPublic;\n   213→\n   214→      // Colors: always send all edited colors\n   215→      const origColors = theme.colors as Record<string, string | undefined>;\n   216→      const colorsChanged = COLOR_LABELS.some(\n   217→        ({ key }) => (editColors[key] ?? \"\") !== (origColors[key] ?? \"\")\n   218→      );\n   219→      if (colorsChanged) updates.colors = editColors;\n   220→\n   221→      // Fonts: send if changed\n   222→      const origFonts = (theme.fonts ?? {}) as Record<string, string | undefined>;\n   223→      const fontsChanged = FONT_KEYS.some(\n   224→        (k) => (editFonts[k] ?? \"\") !== (origFonts[k] ?? \"\")\n   225→      );\n   226→      if (fontsChanged) {\n   227→        const fontPayload: Record<string, string> = {};\n   228→        for (const k of FONT_KEYS) {\n   229→          if (editFonts[k]?.trim()) fontPayload[k] = editFonts[k];\n   230→        }\n   231→        updates.fonts = fontPayload;\n   232→      }\n   233→\n   234→      const result = await updateTheme(updates as Parameters<typeof updateTheme>[0]);\n   235→      setEditing(false);\n   236→\n   237→      // If name changed, the slug changed server-side — redirect using the returned slug\n   238→      if (editName !== theme.name && result?.slug) {\n   239→        router.push(`/theme/${result.slug}`);\n   240→      }\n   241→    } catch (err) {\n   242→      setSaveError(err instanceof Error ? err.message : \"Failed to save\");\n   243→    } finally {\n   244→      setSaving(false);\n   245→    }\n   246→  }\n   247→\n   248→  async function handleDelete() {\n   249→    if (!theme) return;\n   250→    setDeleting(true);\n   251→    setDeleteError(null);\n   252→    try {\n   253→      await removeTheme({ id: theme._id });\n   254→      router.push(\"/\");\n   255→    } catch (err) {\n   256→      setDeleteError(err instanceof Error ? err.message : \"Failed to delete\");\n   257→      setDeleting(false);\n   258→    }\n   259→  }\n   260→\n   261→  // Loading state\n   262→  if (theme === undefined) {\n   263→    return (\n   264→      <div className=\"min-h-screen flex items-center justify-center\">\n   265→        <div className=\"animate-pulse text-gray-400 text-lg\">\n   266→          Loading theme...\n   267→        </div>\n   268→      </div>\n   269→    );\n   270→  }\n   271→\n   272→  // Not found\n   273→  if (theme === null) {\n   274→    return (\n   275→      <div className=\"min-h-screen flex flex-col items-center justify-center gap-4\">\n   276→        <h1 className=\"text-2xl font-bold text-gray-800\">Theme not found</h1>\n   277→        <p className=\"text-gray-500\">\n   278→          This theme doesn&apos;t exist or is private.\n   279→        </p>\n   280→        <a href=\"/\" className=\"text-blue-600 hover:underline text-sm\">\n   281→          Back to gallery\n   282→        </a>\n   283→      </div>\n   284→    );\n   285→  }\n   286→\n   287→  const colors = editing\n   288→    ? (editColors as Record<string, string | undefined>)\n   289→    : (theme.colors as Record<string, string | undefined>);\n   290→\n   291→  async function handleToggleStar() {\n   292→    if (!theme || !currentUser) return;\n   293→    await toggleStar({ themeId: theme._id });\n   294→  }\n   295→\n   296→  async function handleSubmitComment(e: React.FormEvent) {\n   297→    e.preventDefault();\n   298→    if (!theme || !commentBody.trim()) return;\n   299→    setSubmittingComment(true);\n   300→    try {\n   301→      await createComment({ themeId: theme._id, body: commentBody.trim() });\n   302→      setCommentBody(\"\");\n   303→    } finally {\n   304→      setSubmittingComment(false);\n   305→    }\n   306→  }\n   307→\n   308→  async function handleDeleteComment(commentId: string) {\n   309→    if (!window.confirm(\"Delete this comment?\")) return;\n   310→    setDeletingCommentId(commentId);\n   311→    try {\n   312→      await removeComment({ id: commentId as Parameters<typeof removeComment>[0][\"id\"] });\n   313→    } finally {\n   314→      setDeletingCommentId(null);\n   315→    }\n   316→  }\n   317→\n   318→  async function handleFork() {\n   319→    if (!theme) return;\n   320→    setForking(true);\n   321→    try {\n   322→      const result = await forkTheme({ id: theme._id });\n   323→      if (result) {\n   324→        router.push(`/theme/${result.slug}`);\n   325→      }\n   326→    } catch {\n   327→      // Fork may fail if not authenticated\n   328→    } finally {\n   329→      setForking(false);\n   330→    }\n   331→  }\n   332→\n   333→  return (\n   334→    <div className=\"min-h-screen bg-gray-50\">\n   335→      {/* Header */}\n   336→      <header className=\"bg-white border-b border-gray-200\">\n   337→        <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n   338→          <a\n   339→            href=\"/\"\n   340→            className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n   341→          >\n   342→            ThemeDrops\n   343→          </a>\n   344→          <div className=\"flex items-center gap-3\">\n   345→            <CreateThemeLink />\n   346→            <AuthControls />\n   347→          </div>\n   348→        </div>\n   349→      </header>\n   350→\n   351→      <main className=\"max-w-4xl mx-auto px-6 py-10 space-y-10\">\n   352→        {/* Theme header */}\n   353→        <div className=\"space-y-3\">\n   354→          <div className=\"flex items-start justify-between gap-4\">\n   355→            <div className=\"space-y-1 flex-1\">\n   356→              {editing ? (\n   357→                <input\n   358→                  type=\"text\"\n   359→                  value={editName}\n   360→                  onChange={(e) => setEditName(e.target.value)}\n   361→                  className=\"text-3xl font-bold text-gray-900 w-full border border-gray-300 rounded-lg px-3 py-1 focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   362→                />\n   363→              ) : (\n   364→                <h1 className=\"text-3xl font-bold text-gray-900\">\n   365→                  {theme.name}\n   366→                </h1>\n   367→              )}\n   368→              {author && (\n   369→                <p className=\"text-sm text-gray-500\">\n   370→                  by{\" \"}\n   371→                  <Link\n   372→                    href={`/user/${author.username}`}\n   373→                    className=\"font-medium text-gray-700 hover:text-blue-600 transition-colors\"\n   374→                  >\n   375→                    {author.displayName ?? author.username}\n   376→                  </Link>\n   377→                </p>\n   378→              )}\n   379→            </div>\n   380→\n   381→            <div className=\"flex items-center gap-2\">\n   382→              {/* Owner controls */}\n   383→              {isOwner && !editing && (\n   384→                <>\n   385→                  <button\n   386→                    onClick={enterEditMode}\n   387→                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors\"\n   388→                  >\n   389→                    Edit\n   390→                  </button>\n   391→                  {!confirmingDelete ? (\n   392→                    <button\n   393→                      onClick={() => setConfirmingDelete(true)}\n   394→                      className=\"px-4 py-2 rounded-lg border border-red-200 bg-white text-sm font-medium text-red-600 hover:bg-red-50 transition-colors\"\n   395→                    >\n   396→                      Delete\n   397→                    </button>\n   398→                  ) : (\n   399→                    <div className=\"flex items-center gap-2 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   400→                      <span className=\"text-sm text-red-700\">Delete this theme?</span>\n   401→                      <button\n   402→                        onClick={handleDelete}\n   403→                        disabled={deleting}\n   404→                        className=\"px-3 py-1 rounded bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition-colors disabled:opacity-50\"\n   405→                      >\n   406→                        {deleting ? \"Deleting...\" : \"Confirm\"}\n   407→                      </button>\n   408→                      <button\n   409→                        onClick={() => {\n   410→                          setConfirmingDelete(false);\n   411→                          setDeleteError(null);\n   412→                        }}\n   413→                        disabled={deleting}\n   414→                        className=\"px-3 py-1 rounded border border-red-200 text-sm text-red-600 hover:bg-red-100 transition-colors disabled:opacity-50\"\n   415→                      >\n   416→                        Cancel\n   417→                      </button>\n   418→                    </div>\n   419→                  )}\n   420→                </>\n   421→              )}\n   422→\n   423→              {/* Edit mode controls */}\n   424→              {editing && (\n   425→                <>\n   426→                  <button\n   427→                    onClick={handleSave}\n   428→                    disabled={saving || !editName.trim()}\n   429→                    className=\"px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n   430→                  >\n   431→                    {saving ? \"Saving...\" : \"Save\"}\n   432→                  </button>\n   433→                  <button\n   434→                    onClick={cancelEdit}\n   435→                    disabled={saving}\n   436→                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50\"\n   437→                  >\n   438→                    Cancel\n   439→                  </button>\n   440→                </>\n   441→              )}\n   442→\n   443→              {/* Star button */}\n   444→              {!editing && (\n   445→                <button\n   446→                  onClick={handleToggleStar}\n   447→                  disabled={!currentUser}\n   448→                  className={`flex items-center gap-1.5 px-4 py-2 rounded-lg border text-sm font-medium transition-colors ${\n   449→                    isStarred\n   450→                      ? \"bg-yellow-50 border-yellow-300 text-yellow-700\"\n   451→                      : \"bg-white border-gray-200 text-gray-600 hover:bg-gray-50\"\n   452→                  } ${!currentUser ? \"opacity-50 cursor-not-allowed\" : \"cursor-pointer\"}`}\n   453→                  title={!currentUser ? \"Sign in to star themes\" : undefined}\n   454→                >\n   455→                  <span className=\"text-lg\">\n   456→                    {isStarred ? \"\\u2605\" : \"\\u2606\"}\n   457→                  </span>\n   458→                  <span>{theme.starCount}</span>\n   459→                </button>\n   460→              )}\n   461→            </div>\n   462→          </div>\n   463→\n   464→          {/* Delete error */}\n   465→          {deleteError && (\n   466→            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   467→              {deleteError}\n   468→            </p>\n   469→          )}\n   470→\n   471→          {/* Save error */}\n   472→          {saveError && (\n   473→            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   474→              {saveError}\n   475→            </p>\n   476→          )}\n   477→\n   478→          {/* Description */}\n   479→          {editing ? (\n   480→            <textarea\n   481→              value={editDescription}\n   482→              onChange={(e) => setEditDescription(e.target.value)}\n   483→              placeholder=\"Theme description...\"\n   484→              rows={3}\n   485→              className=\"w-full text-gray-600 leading-relaxed border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   486→            />\n   487→          ) : (\n   488→            theme.description && (\n   489→              <p className=\"text-gray-600 leading-relaxed\">\n   490→                {theme.description}\n   491→              </p>\n   492→            )\n   493→          )}\n   494→\n   495→          {/* Visibility toggle */}\n   496→          {editing && (\n   497→            <div className=\"flex items-center gap-3\">\n   498→              <span className=\"text-sm text-gray-600\">Visibility:</span>\n   499→              <button\n   500→                onClick={() => setEditIsPublic(!editIsPublic)}\n   501→                className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${\n   502→                  editIsPublic ? \"bg-blue-600\" : \"bg-gray-300\"\n   503→                }`}\n   504→              >\n   505→                <span\n   506→                  className={`inline-block h-4 w-4 rounded-full bg-white transition-transform ${\n   507→                    editIsPublic ? \"translate-x-6\" : \"translate-x-1\"\n   508→                  }`}\n   509→                />\n   510→              </button>\n   511→              <span className=\"text-sm text-gray-500\">\n   512→                {editIsPublic ? \"Public\" : \"Private\"}\n   513→              </span>\n   514→            </div>\n   515→          )}\n   516→\n   517→          {theme.forkedFromId && forkedFrom && (\n   518→            <p className=\"text-sm text-gray-400 italic\">\n   519→              Forked from{\" \"}\n   520→              <a\n   521→                href={`/theme/${forkedFrom.slug}`}\n   522→                className=\"text-blue-500 hover:underline\"\n   523→              >\n   524→                {forkedFrom.name}\n   525→              </a>\n   526→            </p>\n   527→          )}\n   528→\n   529→          {!editing && (\n   530→            <p className=\"text-xs text-gray-400 font-mono bg-gray-100 inline-block px-2 py-1 rounded\">\n   531→              API: /api/themes/{theme.slug}\n   532→            </p>\n   533→          )}\n   534→        </div>\n   535→\n   536→        {/* Color palette */}\n   537→        <section className=\"space-y-4\">\n   538→          <h2 className=\"text-lg font-semibold text-gray-800\">Color Palette</h2>\n   539→          <div className=\"flex flex-wrap gap-6\">\n   540→            {editing\n   541→              ? COLOR_LABELS.map(({ key, label }) => (\n   542→                  <EditableColorSwatch\n   543→                    key={key}\n   544→                    color={editColors[key] ?? \"#000000\"}\n   545→                    label={label}\n   546→                    onChange={(value) =>\n   547→                      setEditColors((prev) => ({ ...prev, [key]: value }))\n   548→                    }\n   549→                  />\n   550→                ))\n   551→              : COLOR_LABELS.map(({ key, label }) => {\n   552→                  const color = colors[key];\n   553→                  if (!color) return null;\n   554→                  return <ColorSwatch key={key} color={color} label={label} />;\n   555→                })}\n   556→          </div>\n   557→        </section>\n   558→\n   559→        {/* Live preview */}\n   560→        <section className=\"space-y-4\">\n   561→          <h2 className=\"text-lg font-semibold text-gray-800\">Preview</h2>\n   562→          <LivePreview colors={colors} />\n   563→        </section>\n   564→\n   565→        {/* Fonts */}\n   566→        {editing ? (\n   567→          <section className=\"space-y-4\">\n   568→            <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   569→            <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   570→              {FONT_KEYS.map((k) => (\n   571→                <div\n   572→                  key={k}\n   573→                  className=\"bg-white rounded-lg border border-gray-200 p-4\"\n   574→                >\n   575→                  <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   576→                    {k}\n   577→                  </p>\n   578→                  <input\n   579→                    type=\"text\"\n   580→                    value={editFonts[k] ?? \"\"}\n   581→                    onChange={(e) =>\n   582→                      setEditFonts((prev) => ({ ...prev, [k]: e.target.value }))\n   583→                    }\n   584→                    placeholder={`${k} font name`}\n   585→                    className=\"w-full text-sm border border-gray-200 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n   586→                  />\n   587→                  {editFonts[k] && (\n   588→                    <p\n   589→                      className=\"text-sm text-gray-500 mt-2\"\n   590→                      style={{ fontFamily: editFonts[k] }}\n   591→                    >\n   592→                      The quick brown fox jumps over the lazy dog.\n   593→                    </p>\n   594→                  )}\n   595→                </div>\n   596→              ))}\n   597→            </div>\n   598→          </section>\n   599→        ) : (\n   600→          theme.fonts &&\n   601→          (theme.fonts.sans || theme.fonts.serif || theme.fonts.mono) && (\n   602→            <section className=\"space-y-4\">\n   603→              <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   604→              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   605→                {theme.fonts.sans && (\n   606→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   607→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   608→                      Sans\n   609→                    </p>\n   610→                    <p\n   611→                      className=\"text-lg\"\n   612→                      style={{ fontFamily: theme.fonts.sans }}\n   613→                    >\n   614→                      {theme.fonts.sans}\n   615→                    </p>\n   616→                    <p\n   617→                      className=\"text-sm text-gray-500 mt-1\"\n   618→                      style={{ fontFamily: theme.fonts.sans }}\n   619→                    >\n   620→                      The quick brown fox jumps over the lazy dog.\n   621→                    </p>\n   622→                  </div>\n   623→                )}\n   624→                {theme.fonts.serif && (\n   625→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   626→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   627→                      Serif\n   628→                    </p>\n   629→                    <p\n   630→                      className=\"text-lg\"\n   631→                      style={{ fontFamily: theme.fonts.serif }}\n   632→                    >\n   633→                      {theme.fonts.serif}\n   634→                    </p>\n   635→                    <p\n   636→                      className=\"text-sm text-gray-500 mt-1\"\n   637→                      style={{ fontFamily: theme.fonts.serif }}\n   638→                    >\n   639→                      The quick brown fox jumps over the lazy dog.\n   640→                    </p>\n   641→                  </div>\n   642→                )}\n   643→                {theme.fonts.mono && (\n   644→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   645→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   646→                      Mono\n   647→                    </p>\n   648→                    <p\n   649→                      className=\"text-lg font-mono\"\n   650→                      style={{ fontFamily: theme.fonts.mono }}\n   651→                    >\n   652→                      {theme.fonts.mono}\n   653→                    </p>\n   654→                    <p\n   655→                      className=\"text-sm text-gray-500 mt-1\"\n   656→                      style={{ fontFamily: theme.fonts.mono }}\n   657→                    >\n   658→                      The quick brown fox jumps over the lazy dog.\n   659→                    </p>\n   660→                  </div>\n   661→                )}\n   662→              </div>\n   663→            </section>\n   664→          )\n   665→        )}\n   666→\n   667→        {/* Fork button */}\n   668→        {currentUser && !editing && (\n   669→          <div>\n   670→            <button\n   671→              onClick={handleFork}\n   672→              disabled={forking}\n   673→              className=\"px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors disabled:opacity-50\"\n   674→            >\n   675→              {forking ? \"Forking...\" : \"Fork this theme\"}\n   676→            </button>\n   677→          </div>\n   678→        )}\n   679→\n   680→        {/* Comments */}\n   681→        {!editing && (\n   682→          <section className=\"space-y-6\">\n   683→            <h2 className=\"text-lg font-semibold text-gray-800\">\n   684→              Comments{\" \"}\n   685→              {comments && comments.length > 0 && (\n   686→                <span className=\"text-gray-400 font-normal\">\n   687→                  ({comments.length})\n   688→                </span>\n   689→              )}\n   690→            </h2>\n   691→\n   692→            {comments === undefined && (\n   693→              <p className=\"text-gray-400 text-sm animate-pulse\">\n   694→                Loading comments...\n   695→              </p>\n   696→            )}\n   697→\n   698→            {comments && comments.length === 0 && (\n   699→              <p className=\"text-gray-400 text-sm\">No comments yet.</p>\n   700→            )}\n   701→\n   702→            {comments && comments.length > 0 && (\n   703→              <div className=\"space-y-4\">\n   704→                {comments.map((comment) => (\n   705→                  <div\n   706→                    key={comment._id}\n   707→                    className=\"bg-white rounded-lg border border-gray-200 p-4\"\n   708→                  >\n   709→                    <div className=\"flex items-center justify-between mb-2\">\n   710→                      <div className=\"flex items-center gap-2\">\n   711→                        {comment.author?.avatarUrl && (\n   712→                          <img\n   713→                            src={comment.author.avatarUrl}\n   714→                            alt=\"\"\n   715→                            className=\"w-6 h-6 rounded-full\"\n   716→                          />\n   717→                        )}\n   718→                        <span className=\"text-sm font-medium text-gray-700\">\n   719→                          {comment.author?.displayName ??\n   720→                            comment.author?.username ??\n   721→                            \"Unknown\"}\n   722→                        </span>\n   723→                      </div>\n   724→                      {currentUser?._id === comment.userId && (\n   725→                        <button\n   726→                          onClick={() => handleDeleteComment(comment._id)}\n   727→                          disabled={deletingCommentId === comment._id}\n   728→                          className=\"text-xs text-gray-400 hover:text-red-500 transition-colors disabled:opacity-50\"\n   729→                        >\n   730→                          {deletingCommentId === comment._id ? \"Deleting...\" : \"Delete\"}\n   731→                        </button>\n   732→                      )}\n   733→                    </div>\n   734→                    <p className=\"text-sm text-gray-600\">{comment.body}</p>\n   735→                  </div>\n   736→                ))}\n   737→              </div>\n   738→            )}\n   739→\n   740→            {/* Add comment form */}\n   741→            {currentUser && (\n   742→              <form onSubmit={handleSubmitComment} className=\"flex gap-3\">\n   743→                <input\n   744→                  type=\"text\"\n   745→                  value={commentBody}\n   746→                  onChange={(e) => setCommentBody(e.target.value)}\n   747→                  placeholder=\"Add a comment...\"\n   748→                  className=\"flex-1 px-4 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n   749→                />\n   750→                <button\n   751→                  type=\"submit\"\n   752→                  disabled={!commentBody.trim() || submittingComment}\n   753→                  className=\"px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n   754→                >\n   755→                  {submittingComment ? \"Posting...\" : \"Post\"}\n   756→                </button>\n   757→              </form>\n   758→            )}\n   759→          </section>\n   760→        )}\n   761→      </main>\n   762→    </div>\n   763→  );\n   764→}\n   765→"}]},"parent_tool_use_id":null,"session_id":"f50fcd61-610c-4f99-a11d-1fbd0640633f","uuid":"97b7d86b-72b6-4ef3-9649-afaeca4d2cbb","timestamp":"2026-03-28T00:19:00.342Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/matt/code/themedrops/app/src/app/theme/[slug]/page.tsx","content":"\"use client\";\n\nimport { useParams, useRouter } from \"next/navigation\";\nimport { useQuery, useMutation } from \"convex/react\";\nimport { api } from \"../../../../convex/_generated/api\";\nimport { useState } from \"react\";\nimport Link from \"next/link\";\nimport AuthControls from \"../../components/AuthControls\";\nimport CreateThemeLink from \"../../components/CreateThemeLink\";\n\nconst COLOR_LABELS: { key: string; label: string }[] = [\n  { key: \"background\", label: \"Background\" },\n  { key: \"foreground\", label: \"Foreground\" },\n  { key: \"primary\", label: \"Primary\" },\n  { key: \"secondary\", label: \"Secondary\" },\n  { key: \"accent\", label: \"Accent\" },\n  { key: \"muted\", label: \"Muted\" },\n];\n\nconst FONT_KEYS = [\"sans\", \"serif\", \"mono\"] as const;\n\nfunction ColorSwatch({ color, label }: { color: string; label: string }) {\n  return (\n    <div className=\"flex flex-col items-center gap-2\">\n      <div\n        className=\"w-16 h-16 rounded-xl border border-gray-200 shadow-sm\"\n        style={{ backgroundColor: color }}\n      />\n      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n      <span className=\"text-xs font-mono text-gray-400\">{color}</span>\n    </div>\n  );\n}\n\nfunction EditableColorSwatch({\n  color,\n  label,\n  onChange,\n}: {\n  color: string;\n  label: string;\n  onChange: (value: string) => void;\n}) {\n  return (\n    <div className=\"flex flex-col items-center gap-2\">\n      <label className=\"relative w-16 h-16 rounded-xl border border-gray-200 shadow-sm cursor-pointer overflow-hidden\">\n        <div\n          className=\"absolute inset-0\"\n          style={{ backgroundColor: color }}\n        />\n        <input\n          type=\"color\"\n          value={color}\n          onChange={(e) => onChange(e.target.value)}\n          className=\"absolute inset-0 opacity-0 cursor-pointer\"\n        />\n      </label>\n      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n      <input\n        type=\"text\"\n        value={color}\n        onChange={(e) => onChange(e.target.value)}\n        className=\"text-xs font-mono text-gray-600 w-20 text-center border border-gray-200 rounded px-1 py-0.5 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n      />\n    </div>\n  );\n}\n\nfunction LivePreview({\n  colors,\n}: {\n  colors: Record<string, string | undefined>;\n}) {\n  return (\n    <div\n      className=\"rounded-xl border p-6 space-y-4\"\n      style={{\n        backgroundColor: colors.background ?? \"#ffffff\",\n        color: colors.foreground ?? \"#000000\",\n        borderColor: colors.muted ?? \"#e5e7eb\",\n      }}\n    >\n      <h3 className=\"text-lg font-semibold\">Live Preview</h3>\n      <p style={{ color: colors.muted ?? \"#6b7280\" }} className=\"text-sm\">\n        This is how the theme looks when applied to a card.\n      </p>\n      <div className=\"flex gap-3\">\n        <button\n          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n          style={{ backgroundColor: colors.primary ?? \"#3b82f6\" }}\n        >\n          Primary\n        </button>\n        <button\n          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n          style={{ backgroundColor: colors.secondary ?? \"#6366f1\" }}\n        >\n          Secondary\n        </button>\n        <button\n          className=\"px-4 py-2 rounded-lg text-sm font-medium border\"\n          style={{\n            backgroundColor: colors.accent ?? \"#f59e0b\",\n            borderColor: colors.muted ?? \"#e5e7eb\",\n          }}\n        >\n          Accent\n        </button>\n      </div>\n    </div>\n  );\n}\n\nexport default function ThemeDetailPage() {\n  const params = useParams<{ slug: string }>();\n  const router = useRouter();\n  const slug = params.slug;\n\n  const theme = useQuery(api.themes.getBySlug, { slug });\n  const author = useQuery(\n    api.users.get,\n    theme ? { id: theme.authorId } : \"skip\"\n  );\n  const currentUser = useQuery(api.users.getCurrentUser);\n\n  // Stars\n  const isStarred = useQuery(\n    api.stars.isStarred,\n    theme ? { themeId: theme._id } : \"skip\"\n  );\n  const toggleStar = useMutation(api.stars.toggle);\n\n  // Comments\n  const comments = useQuery(\n    api.comments.listByTheme,\n    theme ? { themeId: theme._id } : \"skip\"\n  );\n  const createComment = useMutation(api.comments.create);\n  const removeComment = useMutation(api.comments.remove);\n  const [commentBody, setCommentBody] = useState(\"\");\n  const [submittingComment, setSubmittingComment] = useState(false);\n  const [deletingCommentId, setDeletingCommentId] = useState<string | null>(null);\n\n  // Fork\n  const forkTheme = useMutation(api.themes.fork);\n  const [forking, setForking] = useState(false);\n\n  // Forked-from theme info (for link)\n  const forkedFrom = useQuery(\n    api.themes.getBasicInfo,\n    theme?.forkedFromId ? { id: theme.forkedFromId } : \"skip\"\n  );\n\n  // Edit/Delete mutations\n  const updateTheme = useMutation(api.themes.update);\n  const removeTheme = useMutation(api.themes.remove);\n\n  // Edit mode state\n  const [editing, setEditing] = useState(false);\n  const [editName, setEditName] = useState(\"\");\n  const [editDescription, setEditDescription] = useState(\"\");\n  const [editIsPublic, setEditIsPublic] = useState(true);\n  const [editColors, setEditColors] = useState<Record<string, string>>({});\n  const [editFonts, setEditFonts] = useState<Record<string, string>>({});\n  const [saving, setSaving] = useState(false);\n  const [saveError, setSaveError] = useState<string | null>(null);\n\n  // Delete state\n  const [confirmingDelete, setConfirmingDelete] = useState(false);\n  const [deleting, setDeleting] = useState(false);\n  const [deleteError, setDeleteError] = useState<string | null>(null);\n\n  // Owner detection\n  const isOwner = !!(currentUser && theme && currentUser._id === theme.authorId);\n\n  function enterEditMode() {\n    if (!theme) return;\n    setEditName(theme.name);\n    setEditDescription(theme.description ?? \"\");\n    setEditIsPublic(theme.isPublic);\n    const c: Record<string, string> = {};\n    const themeColors = theme.colors as Record<string, string | undefined>;\n    for (const { key } of COLOR_LABELS) {\n      if (themeColors[key]) c[key] = themeColors[key]!;\n    }\n    setEditColors(c);\n    const f: Record<string, string> = {};\n    if (theme.fonts) {\n      for (const k of FONT_KEYS) {\n        if (theme.fonts[k]) f[k] = theme.fonts[k]!;\n      }\n    }\n    setEditFonts(f);\n    setSaveError(null);\n    setEditing(true);\n  }\n\n  function cancelEdit() {\n    setEditing(false);\n    setSaveError(null);\n  }\n\n  async function handleSave() {\n    if (!theme) return;\n    setSaving(true);\n    setSaveError(null);\n    try {\n      const updates: Record<string, unknown> = { id: theme._id };\n      if (editName !== theme.name) updates.name = editName;\n      if (editDescription !== (theme.description ?? \"\"))\n        updates.description = editDescription;\n      if (editIsPublic !== theme.isPublic) updates.isPublic = editIsPublic;\n\n      // Colors: always send all edited colors\n      const origColors = theme.colors as Record<string, string | undefined>;\n      const colorsChanged = COLOR_LABELS.some(\n        ({ key }) => (editColors[key] ?? \"\") !== (origColors[key] ?? \"\")\n      );\n      if (colorsChanged) updates.colors = editColors;\n\n      // Fonts: send if changed\n      const origFonts = (theme.fonts ?? {}) as Record<string, string | undefined>;\n      const fontsChanged = FONT_KEYS.some(\n        (k) => (editFonts[k] ?? \"\") !== (origFonts[k] ?? \"\")\n      );\n      if (fontsChanged) {\n        const fontPayload: Record<string, string> = {};\n        for (const k of FONT_KEYS) {\n          if (editFonts[k]?.trim()) fontPayload[k] = editFonts[k];\n        }\n        updates.fonts = fontPayload;\n      }\n\n      const result = await updateTheme(updates as Parameters<typeof updateTheme>[0]);\n      setEditing(false);\n\n      // If name changed, the slug changed server-side — redirect using the returned slug\n      if (editName !== theme.name && result?.slug) {\n        router.push(`/theme/${result.slug}`);\n      }\n    } catch (err) {\n      setSaveError(err instanceof Error ? err.message : \"Failed to save\");\n    } finally {\n      setSaving(false);\n    }\n  }\n\n  async function handleDelete() {\n    if (!theme) return;\n    setDeleting(true);\n    setDeleteError(null);\n    try {\n      await removeTheme({ id: theme._id });\n      router.push(\"/\");\n    } catch (err) {\n      setDeleteError(err instanceof Error ? err.message : \"Failed to delete\");\n      setDeleting(false);\n    }\n  }\n\n  // Loading state\n  if (theme === undefined) {\n    return (\n      <div className=\"min-h-screen flex items-center justify-center\">\n        <div className=\"animate-pulse text-gray-400 text-lg\">\n          Loading theme...\n        </div>\n      </div>\n    );\n  }\n\n  // Not found\n  if (theme === null) {\n    return (\n      <div className=\"min-h-screen flex flex-col items-center justify-center gap-4\">\n        <h1 className=\"text-2xl font-bold text-gray-800\">Theme not found</h1>\n        <p className=\"text-gray-500\">\n          This theme doesn&apos;t exist or is private.\n        </p>\n        <a href=\"/\" className=\"text-blue-600 hover:underline text-sm\">\n          Back to gallery\n        </a>\n      </div>\n    );\n  }\n\n  const colors = editing\n    ? (editColors as Record<string, string | undefined>)\n    : (theme.colors as Record<string, string | undefined>);\n\n  async function handleToggleStar() {\n    if (!theme || !currentUser) return;\n    await toggleStar({ themeId: theme._id });\n  }\n\n  async function handleSubmitComment(e: React.FormEvent) {\n    e.preventDefault();\n    if (!theme || !commentBody.trim()) return;\n    setSubmittingComment(true);\n    try {\n      await createComment({ themeId: theme._id, body: commentBody.trim() });\n      setCommentBody(\"\");\n    } finally {\n      setSubmittingComment(false);\n    }\n  }\n\n  async function handleDeleteComment(commentId: string) {\n    if (!window.confirm(\"Delete this comment?\")) return;\n    setDeletingCommentId(commentId);\n    try {\n      await removeComment({ id: commentId as Parameters<typeof removeComment>[0][\"id\"] });\n    } finally {\n      setDeletingCommentId(null);\n    }\n  }\n\n  async function handleFork() {\n    if (!theme) return;\n    setForking(true);\n    try {\n      const result = await forkTheme({ id: theme._id });\n      if (result) {\n        router.push(`/theme/${result.slug}`);\n      }\n    } catch {\n      // Fork may fail if not authenticated\n    } finally {\n      setForking(false);\n    }\n  }\n\n  return (\n    <div className=\"min-h-screen bg-gray-50\">\n      {/* Header */}\n      <header className=\"bg-white border-b border-gray-200\">\n        <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n          <a\n            href=\"/\"\n            className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n          >\n            ThemeDrops\n          </a>\n          <div className=\"flex items-center gap-3\">\n            <CreateThemeLink />\n            <AuthControls />\n          </div>\n        </div>\n      </header>\n\n      <main className=\"max-w-4xl mx-auto px-6 py-10 space-y-10\">\n        {/* Theme header */}\n        <div className=\"space-y-3\">\n          <div className=\"flex items-start justify-between gap-4\">\n            <div className=\"space-y-1 flex-1\">\n              {editing ? (\n                <input\n                  type=\"text\"\n                  value={editName}\n                  onChange={(e) => setEditName(e.target.value)}\n                  className=\"text-3xl font-bold text-gray-900 w-full border border-gray-300 rounded-lg px-3 py-1 focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                />\n              ) : (\n                <h1 className=\"text-3xl font-bold text-gray-900\">\n                  {theme.name}\n                </h1>\n              )}\n              {author && (\n                <p className=\"text-sm text-gray-500\">\n                  by{\" \"}\n                  <Link\n                    href={`/user/${author.username}`}\n                    className=\"font-medium text-gray-700 hover:text-blue-600 transition-colors\"\n                  >\n                    {author.displayName ?? author.username}\n                  </Link>\n                </p>\n              )}\n            </div>\n\n            <div className=\"flex items-center gap-2\">\n              {/* Owner controls */}\n              {isOwner && !editing && (\n                <>\n                  <button\n                    onClick={enterEditMode}\n                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors\"\n                  >\n                    Edit\n                  </button>\n                  {!confirmingDelete ? (\n                    <button\n                      onClick={() => setConfirmingDelete(true)}\n                      className=\"px-4 py-2 rounded-lg border border-red-200 bg-white text-sm font-medium text-red-600 hover:bg-red-50 transition-colors\"\n                    >\n                      Delete\n                    </button>\n                  ) : (\n                    <div className=\"flex items-center gap-2 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n                      <span className=\"text-sm text-red-700\">Delete this theme?</span>\n                      <button\n                        onClick={handleDelete}\n                        disabled={deleting}\n                        className=\"px-3 py-1 rounded bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition-colors disabled:opacity-50\"\n                      >\n                        {deleting ? \"Deleting...\" : \"Confirm\"}\n                      </button>\n                      <button\n                        onClick={() => {\n                          setConfirmingDelete(false);\n                          setDeleteError(null);\n                        }}\n                        disabled={deleting}\n                        className=\"px-3 py-1 rounded border border-red-200 text-sm text-red-600 hover:bg-red-100 transition-colors disabled:opacity-50\"\n                      >\n                        Cancel\n                      </button>\n                    </div>\n                  )}\n                </>\n              )}\n\n              {/* Edit mode controls */}\n              {editing && (\n                <>\n                  <button\n                    onClick={handleSave}\n                    disabled={saving || !editName.trim()}\n                    className=\"px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n                  >\n                    {saving ? \"Saving...\" : \"Save\"}\n                  </button>\n                  <button\n                    onClick={cancelEdit}\n                    disabled={saving}\n                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50\"\n                  >\n                    Cancel\n                  </button>\n                </>\n              )}\n\n              {/* Star button */}\n              {!editing && (\n                <button\n                  onClick={handleToggleStar}\n                  disabled={!currentUser}\n                  className={`flex items-center gap-1.5 px-4 py-2 rounded-lg border text-sm font-medium transition-colors ${\n                    isStarred\n                      ? \"bg-yellow-50 border-yellow-300 text-yellow-700\"\n                      : \"bg-white border-gray-200 text-gray-600 hover:bg-gray-50\"\n                  } ${!currentUser ? \"opacity-50 cursor-not-allowed\" : \"cursor-pointer\"}`}\n                  title={!currentUser ? \"Sign in to star themes\" : undefined}\n                >\n                  <span className=\"text-lg\">\n                    {isStarred ? \"\\u2605\" : \"\\u2606\"}\n                  </span>\n                  <span>{theme.starCount}</span>\n                </button>\n              )}\n            </div>\n          </div>\n\n          {/* Delete error */}\n          {deleteError && (\n            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n              {deleteError}\n            </p>\n          )}\n\n          {/* Save error */}\n          {saveError && (\n            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n              {saveError}\n            </p>\n          )}\n\n          {/* Description */}\n          {editing ? (\n            <textarea\n              value={editDescription}\n              onChange={(e) => setEditDescription(e.target.value)}\n              placeholder=\"Theme description...\"\n              rows={3}\n              className=\"w-full text-gray-600 leading-relaxed border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n            />\n          ) : (\n            theme.description && (\n              <p className=\"text-gray-600 leading-relaxed\">\n                {theme.description}\n              </p>\n            )\n          )}\n\n          {/* Visibility toggle */}\n          {editing && (\n            <div className=\"flex items-center gap-3\">\n              <span className=\"text-sm text-gray-600\">Visibility:</span>\n              <button\n                onClick={() => setEditIsPublic(!editIsPublic)}\n                className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${\n                  editIsPublic ? \"bg-blue-600\" : \"bg-gray-300\"\n                }`}\n              >\n                <span\n                  className={`inline-block h-4 w-4 rounded-full bg-white transition-transform ${\n                    editIsPublic ? \"translate-x-6\" : \"translate-x-1\"\n                  }`}\n                />\n              </button>\n              <span className=\"text-sm text-gray-500\">\n                {editIsPublic ? \"Public\" : \"Private\"}\n              </span>\n            </div>\n          )}\n\n          {theme.forkedFromId && forkedFrom && (\n            <p className=\"text-sm text-gray-400 italic\">\n              Forked from{\" \"}\n              <a\n                href={`/theme/${forkedFrom.slug}`}\n                className=\"text-blue-500 hover:underline\"\n              >\n                {forkedFrom.name}\n              </a>\n            </p>\n          )}\n\n          {!editing && (\n            <p className=\"text-xs text-gray-400 font-mono bg-gray-100 inline-block px-2 py-1 rounded\">\n              API: /api/themes/{theme.slug}\n            </p>\n          )}\n        </div>\n\n        {/* Color palette */}\n        <section className=\"space-y-4\">\n          <h2 className=\"text-lg font-semibold text-gray-800\">Color Palette</h2>\n          <div className=\"flex flex-wrap gap-6\">\n            {editing\n              ? COLOR_LABELS.map(({ key, label }) => (\n                  <EditableColorSwatch\n                    key={key}\n                    color={editColors[key] ?? \"#000000\"}\n                    label={label}\n                    onChange={(value) =>\n                      setEditColors((prev) => ({ ...prev, [key]: value }))\n                    }\n                  />\n                ))\n              : COLOR_LABELS.map(({ key, label }) => {\n                  const color = colors[key];\n                  if (!color) return null;\n                  return <ColorSwatch key={key} color={color} label={label} />;\n                })}\n          </div>\n        </section>\n\n        {/* Live preview */}\n        <section className=\"space-y-4\">\n          <h2 className=\"text-lg font-semibold text-gray-800\">Preview</h2>\n          <LivePreview colors={colors} />\n        </section>\n\n        {/* Fonts */}\n        {editing ? (\n          <section className=\"space-y-4\">\n            <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n            <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n              {FONT_KEYS.map((k) => (\n                <div\n                  key={k}\n                  className=\"bg-white rounded-lg border border-gray-200 p-4\"\n                >\n                  <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                    {k}\n                  </p>\n                  <input\n                    type=\"text\"\n                    value={editFonts[k] ?? \"\"}\n                    onChange={(e) =>\n                      setEditFonts((prev) => ({ ...prev, [k]: e.target.value }))\n                    }\n                    placeholder={`${k} font name`}\n                    className=\"w-full text-sm border border-gray-200 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n                  />\n                  {editFonts[k] && (\n                    <p\n                      className=\"text-sm text-gray-500 mt-2\"\n                      style={{ fontFamily: editFonts[k] }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  )}\n                </div>\n              ))}\n            </div>\n          </section>\n        ) : (\n          theme.fonts &&\n          (theme.fonts.sans || theme.fonts.serif || theme.fonts.mono) && (\n            <section className=\"space-y-4\">\n              <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n                {theme.fonts.sans && (\n                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                      Sans\n                    </p>\n                    <p\n                      className=\"text-lg\"\n                      style={{ fontFamily: theme.fonts.sans }}\n                    >\n                      {theme.fonts.sans}\n                    </p>\n                    <p\n                      className=\"text-sm text-gray-500 mt-1\"\n                      style={{ fontFamily: theme.fonts.sans }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  </div>\n                )}\n                {theme.fonts.serif && (\n                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                      Serif\n                    </p>\n                    <p\n                      className=\"text-lg\"\n                      style={{ fontFamily: theme.fonts.serif }}\n                    >\n                      {theme.fonts.serif}\n                    </p>\n                    <p\n                      className=\"text-sm text-gray-500 mt-1\"\n                      style={{ fontFamily: theme.fonts.serif }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  </div>\n                )}\n                {theme.fonts.mono && (\n                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                      Mono\n                    </p>\n                    <p\n                      className=\"text-lg font-mono\"\n                      style={{ fontFamily: theme.fonts.mono }}\n                    >\n                      {theme.fonts.mono}\n                    </p>\n                    <p\n                      className=\"text-sm text-gray-500 mt-1\"\n                      style={{ fontFamily: theme.fonts.mono }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  </div>\n                )}\n              </div>\n            </section>\n          )\n        )}\n\n        {/* Fork button */}\n        {currentUser && !editing && (\n          <div>\n            <button\n              onClick={handleFork}\n              disabled={forking}\n              className=\"px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors disabled:opacity-50\"\n            >\n              {forking ? \"Forking...\" : \"Fork this theme\"}\n            </button>\n          </div>\n        )}\n\n        {/* Comments */}\n        {!editing && (\n          <section className=\"space-y-6\">\n            <h2 className=\"text-lg font-semibold text-gray-800\">\n              Comments{\" \"}\n              {comments && comments.length > 0 && (\n                <span className=\"text-gray-400 font-normal\">\n                  ({comments.length})\n                </span>\n              )}\n            </h2>\n\n            {comments === undefined && (\n              <p className=\"text-gray-400 text-sm animate-pulse\">\n                Loading comments...\n              </p>\n            )}\n\n            {comments && comments.length === 0 && (\n              <p className=\"text-gray-400 text-sm\">No comments yet.</p>\n            )}\n\n            {comments && comments.length > 0 && (\n              <div className=\"space-y-4\">\n                {comments.map((comment) => (\n                  <div\n                    key={comment._id}\n                    className=\"bg-white rounded-lg border border-gray-200 p-4\"\n                  >\n                    <div className=\"flex items-center justify-between mb-2\">\n                      <div className=\"flex items-center gap-2\">\n                        {comment.author?.avatarUrl && (\n                          <img\n                            src={comment.author.avatarUrl}\n                            alt=\"\"\n                            className=\"w-6 h-6 rounded-full\"\n                          />\n                        )}\n                        <span className=\"text-sm font-medium text-gray-700\">\n                          {comment.author?.displayName ??\n                            comment.author?.username ??\n                            \"Unknown\"}\n                        </span>\n                      </div>\n                      {currentUser?._id === comment.userId && (\n                        <button\n                          onClick={() => handleDeleteComment(comment._id)}\n                          disabled={deletingCommentId === comment._id}\n                          className=\"text-xs text-gray-400 hover:text-red-500 transition-colors disabled:opacity-50\"\n                        >\n                          {deletingCommentId === comment._id ? \"Deleting...\" : \"Delete\"}\n                        </button>\n                      )}\n                    </div>\n                    <p className=\"text-sm text-gray-600\">{comment.body}</p>\n                  </div>\n                ))}\n              </div>\n            )}\n\n            {/* Add comment form */}\n            {currentUser && (\n              <form onSubmit={handleSubmitComment} className=\"flex gap-3\">\n                <input\n                  type=\"text\"\n                  value={commentBody}\n                  onChange={(e) => setCommentBody(e.target.value)}\n                  placeholder=\"Add a comment...\"\n                  className=\"flex-1 px-4 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n                />\n                <button\n                  type=\"submit\"\n                  disabled={!commentBody.trim() || submittingComment}\n                  className=\"px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n                >\n                  {submittingComment ? \"Posting...\" : \"Post\"}\n                </button>\n              </form>\n            )}\n          </section>\n        )}\n      </main>\n    </div>\n  );\n}\n","numLines":765,"startLine":1,"totalLines":765}}}
