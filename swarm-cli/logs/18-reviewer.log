{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019MRSMZacsbXoUd4CC4Yydp","type":"tool_result","content":"     1→import { v } from \"convex/values\";\n     2→import { query, mutation } from \"./_generated/server\";\n     3→\n     4→export const get = query({\n     5→  args: { id: v.id(\"users\") },\n     6→  handler: async (ctx, args) => {\n     7→    const user = await ctx.db.get(args.id);\n     8→    if (!user) return null;\n     9→    return {\n    10→      _id: user._id,\n    11→      username: user.username,\n    12→      displayName: user.displayName,\n    13→      avatarUrl: user.avatarUrl,\n    14→    };\n    15→  },\n    16→});\n    17→\n    18→export const getByUsername = query({\n    19→  args: { username: v.string() },\n    20→  handler: async (ctx, args) => {\n    21→    return await ctx.db\n    22→      .query(\"users\")\n    23→      .withIndex(\"by_username\", (q) => q.eq(\"username\", args.username))\n    24→      .unique();\n    25→  },\n    26→});\n    27→\n    28→export const getCurrentUser = query({\n    29→  args: {},\n    30→  handler: async (ctx) => {\n    31→    const identity = await ctx.auth.getUserIdentity();\n    32→    if (!identity) return null;\n    33→\n    34→    return await ctx.db\n    35→      .query(\"users\")\n    36→      .withIndex(\"by_token\", (q) =>\n    37→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    38→      )\n    39→      .unique();\n    40→  },\n    41→});\n    42→\n    43→export const updateProfile = mutation({\n    44→  args: {\n    45→    displayName: v.optional(v.string()),\n    46→    bio: v.optional(v.string()),\n    47→    avatarUrl: v.optional(v.string()),\n    48→  },\n    49→  handler: async (ctx, args) => {\n    50→    const identity = await ctx.auth.getUserIdentity();\n    51→    if (!identity) throw new Error(\"Not authenticated\");\n    52→\n    53→    const user = await ctx.db\n    54→      .query(\"users\")\n    55→      .withIndex(\"by_token\", (q) =>\n    56→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    57→      )\n    58→      .unique();\n    59→    if (!user) throw new Error(\"User not found\");\n    60→\n    61→    const updates: Record<string, unknown> = {};\n    62→    if (args.displayName !== undefined) updates.displayName = args.displayName;\n    63→    if (args.bio !== undefined) updates.bio = args.bio;\n    64→    if (args.avatarUrl !== undefined) updates.avatarUrl = args.avatarUrl;\n    65→\n    66→    await ctx.db.patch(user._id, updates);\n    67→  },\n    68→});\n    69→\n    70→export const ensureUser = mutation({\n    71→  args: {},\n    72→  handler: async (ctx) => {\n    73→    const identity = await ctx.auth.getUserIdentity();\n    74→    if (!identity) throw new Error(\"Not authenticated\");\n    75→\n    76→    const existing = await ctx.db\n    77→      .query(\"users\")\n    78→      .withIndex(\"by_token\", (q) =>\n    79→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    80→      )\n    81→      .unique();\n    82→\n    83→    if (existing) return existing._id;\n    84→\n    85→    const baseUsername =\n    86→      identity.nickname ??\n    87→      identity.email?.split(\"@\")[0] ??\n    88→      \"user\";\n    89→    let username = baseUsername;\n    90→    let suffix = 2;\n    91→    while (\n    92→      await ctx.db\n    93→        .query(\"users\")\n    94→        .withIndex(\"by_username\", (q) => q.eq(\"username\", username))\n    95→        .unique()\n    96→    ) {\n    97→      username = `${baseUsername}-${suffix}`;\n    98→      suffix++;\n    99→    }\n   100→    const displayName = identity.name ?? username;\n   101→\n   102→    return await ctx.db.insert(\"users\", {\n   103→      username,\n   104→      displayName,\n   105→      tokenIdentifier: identity.tokenIdentifier,\n   106→      avatarUrl: identity.pictureUrl,\n   107→    });\n   108→  },\n   109→});\n   110→"}]},"parent_tool_use_id":"toolu_01LeWsfRE2PCegvrqJ2RaRcE","session_id":"ec90dc