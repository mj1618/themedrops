,\n        starCount: theme.starCount,\n        colors: theme.colors,\n        fonts: theme.fonts ?? null,\n      });\n    }\n\n    return {\n      themes,\n      continueCursor: result.continueCursor,\n      isDone: result.isDone,\n    };\n  },\n});\n","numLines":59,"startLine":1,"totalLines":59}}}
