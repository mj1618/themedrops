       }\n   199→        @keyframes fadeIn {\n   200→          from { opacity: 0; }\n   201→          to { opacity: 1; }\n   202→        }\n   203→        @keyframes heroShift {\n   204→          0%, 100% { background-position: 0% 50%; }\n   205→          50% { background-position: 100% 50%; }\n   206→        }\n   207→      `}</style>\n   208→\n   209→      {/* Hero */}\n   210→      <header className=\"relative overflow-hidden border-b border-gray-200 bg-white\">\n   211→        {/* Animated gradient backdrop */}\n   212→        <div\n   213→          className=\"absolute inset-0 opacity-[0.035]\"\n   214→          style={{\n   215→            backgroundImage:\n   216→              \"radial-gradient(ellipse at 20% 50%, #6366f1, transparent 50%), radial-gradient(ellipse at 80% 50%, #f59e0b, transparent 50%), radial-gradient(ellipse at 50% 0%, #ec4899, transparent 50%)\",\n   217→            backgroundSize: \"200% 200%\",\n   218→            animation: \"heroShift 20s ease-in-out infinite\",\n   219→          }}\n   220→        />\n   221→\n   222→        <div className=\"relative max-w-6xl mx-auto px-6 py-16 sm:py-20\">\n   223→          <div className=\"absolute top-6 right-6 flex items-center gap-3\">\n   224→            <CreateThemeLink />\n   225→            <AuthControls />\n   226→          </div>\n   227→          <div className=\"max-w-2xl\">\n   228→            <h1 className=\"text-4xl sm:text-5xl font-bold tracking-tight text-gray-900\">\n   229→              Theme\n   230→              <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-amber-500\">\n   231→                Drops\n   232→              </span>\n   233→            </h1>\n   234→            <p className=\"mt-4 text-lg text-gray-500 leading-relaxed max-w-lg\">\n   235→              Discover, share, and remix color and typography themes for any\n   236→              application.\n   237→            </p>\n   238→          </div>\n   239→\n   240→          {/* Search */}\n   241→          <div className=\"mt-8 max-w-xl relative\">\n   242→            <div className=\"absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none\">\n   243→              <svg\n   244→                width=\"18\"\n   245→                height=\"18\"\n   246→                viewBox=\"0 0 24 24\"\n   247→                fill=\"none\"\n   248→                stroke=\"currentColor\"\n   249→                strokeWidth=\"2\"\n   250→                strokeLinecap=\"round\"\n   251→                strokeLinejoin=\"round\"\n   252→              >\n   253→                <circle cx=\"11\" cy=\"11\" r=\"8\" />\n   254→                <line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\" />\n   255→              </svg>\n   256→            </div>\n   257→            <input\n   258→              ref={inputRef}\n   259→              type=\"text\"\n   260→              value={searchInput}\n   261→              onChange={(e) => setSearchInput(e.target.value)}\n   262→              placeholder=\"Search themes by name...\"\n   263→              className=\"w-full pl-11 pr-10 py-3.5 rounded-xl border border-gray-200 bg-white text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400 transition-all shadow-sm\"\n   264→            />\n   265→            {searchInput && (\n   266→              <button\n   267→                onClick={handleClearSearch}\n   268→                className=\"absolute right-3 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors\"\n   269→              >\n   270→                <svg\n   271→                  width=\"14\"\n   272→                  height=\"14\"\n   273→                  viewBox=\"0 0 24 24\"\n   274→                  fill=\"none\"\n   275→                  stroke=\"currentColor\"\n   276→                  strokeWidth=\"2\"\n   277→                  strokeLinecap=\"round\"\n   278→                  strokeLinejoin=\"round\"\n   279→                >\n   280→                  <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\" />\n   281→                  <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\" />\n   282→                </svg>\n   283→              </button>\n   284→            )}\n   285→          </div>\n   286→        </div>\n   287→      </header>\n   288→\n   289→      {/* Gallery */}\n   290→      <main className=\"max-w-6xl mx-auto px-6 py-10\">\n   291→        {/* Status bar */}\n   292→        {isSearching && !isLoading && (\n   293→          <p className=\"text-sm text-gray-500 mb-6\" style={{ animation: \"fadeIn 0.3s ease-out\" }}>\n   294→            {themes && themes.length > 0\n   295→              ? `${themes.length} result${themes.length === 1 ? \"\" : \"s\"} for \"${debouncedSearch}\"`\n   296→              : `No themes found for \"${debouncedSearch}\"`}\n   297→          </p>\n   298→        )}\n   299→\n   300→        {/* Loading skeleton grid */}\n   301→        {isLoading && (\n   302→          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n   303→            {[...Array(6)].map((_, i) => (\n   304→              <CardSkeleton key={i} />\n   305→            ))}\n   306→          </div>\n   307→        )}\n   308→\n   309→        {/* Theme grid */}\n   310→        {!isLoading && themes && themes.length > 0 && (\n   311→          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n   312→            {themes.map((theme, i) => (\n   313→              <ThemeCard\n   314→                key={theme._id}\n   315→                theme={theme}\n   316→                index={i}\n   317→              />\n   318→            ))}\n   319→          </div>\n   320→        )}\n   321→\n   322→        {/* Empty state (no themes at all) */}\n   323→        {!isLoading && !isSearching && themes && themes.length === 0 && (\n   324→          <div className