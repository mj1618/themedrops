{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SEGPdgSGFxv5E3kDer8jsD","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { useParams, useRouter } from \"next/navigation\";\n     4→import { useQuery, useMutation } from \"convex/react\";\n     5→import { api } from \"../../../../convex/_generated/api\";\n     6→import { useState } from \"react\";\n     7→import Link from \"next/link\";\n     8→import AuthControls from \"../../components/AuthControls\";\n     9→import CreateThemeLink from \"../../components/CreateThemeLink\";\n    10→\n    11→const COLOR_LABELS: { key: string; label: string }[] = [\n    12→  { key: \"background\", label: \"Background\" },\n    13→  { key: \"foreground\", label: \"Foreground\" },\n    14→  { key: \"primary\", label: \"Primary\" },\n    15→  { key: \"secondary\", label: \"Secondary\" },\n    16→  { key: \"accent\", label: \"Accent\" },\n    17→  { key: \"muted\", label: \"Muted\" },\n    18→];\n    19→\n    20→const FONT_KEYS = [\"sans\", \"serif\", \"mono\"] as const;\n    21→\n    22→function ColorSwatch({ color, label }: { color: string; label: string }) {\n    23→  return (\n    24→    <div className=\"flex flex-col items-center gap-2\">\n    25→      <div\n    26→        className=\"w-16 h-16 rounded-xl border border-gray-200 shadow-sm\"\n    27→        style={{ backgroundColor: color }}\n    28→      />\n    29→      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n    30→      <span className=\"text-xs font-mono text-gray-400\">{color}</span>\n    31→    </div>\n    32→  );\n    33→}\n    34→\n    35→function EditableColorSwatch({\n    36→  color,\n    37→  label,\n    38→  onChange,\n    39→}: {\n    40→  color: string;\n    41→  label: string;\n    42→  onChange: (value: string) => void;\n    43→}) {\n    44→  return (\n    45→    <div className=\"flex flex-col items-center gap-2\">\n    46→      <label className=\"relative w-16 h-16 rounded-xl border border-gray-200 shadow-sm cursor-pointer overflow-hidden\">\n    47→        <div\n    48→          className=\"absolute inset-0\"\n    49→          style={{ backgroundColor: color }}\n    50→        />\n    51→        <input\n    52→          type=\"color\"\n    53→          value={color}\n    54→          onChange={(e) => onChange(e.target.value)}\n    55→          className=\"absolute inset-0 opacity-0 cursor-pointer\"\n    56→        />\n    57→      </label>\n    58→      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n    59→      <input\n    60→        type=\"text\"\n    61→        value={color}\n    62→        onChange={(e) => onChange(e.target.value)}\n    63→        className=\"text-xs font-mono text-gray-600 w-20 text-center border border-gray-200 rounded px-1 py-0.5 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n    64→      />\n    65→    </div>\n    66→  );\n    67→}\n    68→\n    69→function LivePreview({\n    70→  colors,\n    71→}: {\n    72→  colors: Record<string, string | undefined>;\n    73→}) {\n    74→  return (\n    75→    <div\n    76→      className=\"rounded-xl border p-6 space-y-4\"\n    77→      style={{\n    78→        backgroundColor: colors.background ?? \"#ffffff\",\n    79→        color: colors.foreground ?? \"#000000\",\n    80→        borderColor: colors.muted ?? \"#e5e7eb\",\n    81→      }}\n    82→    >\n    83→      <h3 className=\"text-lg font-semibold\">Live Preview</h3>\n    84→      <p style={{ color: colors.muted ?? \"#6b7280\" }} className=\"text-sm\">\n    85→        This is how the theme looks when applied to a card.\n    86→      </p>\n    87→      <div className=\"flex gap-3\">\n    88→        <button\n    89→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    90→          style={{ backgroundColor: colors.primary ?? \"#3b82f6\" }}\n    91→        >\n    92→          Primary\n    93→        </button>\n    94→        <button\n    95→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    96→          style={{ backgroundColor: colors.secondary ?? \"#6366f1\" }}\n    97→        >\n    98→          Secondary\n    99→        </button>\n   100→        <button\n   101→          className=\"px-4 py-2 rounded-lg text-sm font-medium border\"\n   102→          style={{\n   103→            backgroundColor: colors.accent ?? \"#f59e0b\",\n   104→            borderColor: colors.muted ?? \"#e5e7eb\",\n   105→          }}\n   106→        >\n   107→          Accent\n   108→        </button>\n   109→      </div>\n   110→    </div>\n   111→  );\n   112→}\n   113→\n   114→export default function ThemeDetailPage() {\n   115→  const params = useParams<{ slug: string }>();\n   116→  const router = useRouter();\n   117→  const slug = params.slug;\n   118→\n   119→  const theme = useQuery(api.themes.getBySlug, { slug });\n   120→  const author = useQuery(\n   121→    api.users.get,\n   122→    theme ? { id: theme.authorId } : \"skip\"\n   123→  );\n   124→  const currentUser = useQuery(api.users.getCurrentUser);\n   125→\n   126→  // Stars\n   127→  const isStarred = useQuery(\n   128→    api.stars.isStarred,\n   129→    theme ? { themeId: theme._id } : \"skip\"\n   130→  );\n   131→  const toggleStar = useMutation(api.stars.toggle);\n   132→\n   133→  // Comments\n   134→  const comments = useQuery(\n   135→    api.comments.listByTheme,\n   136→    theme ? { themeId: theme._id } : \"skip\"\n   137→  );\n   138→  const createComment = useMutation(api.comments.create);\n   139→  const [commentBody, setCommentBody] = useState(\"\");\n   140→  const [submittingComment, setSubmittingComment] = useState(false);\n   141→\n   142→  // Fork\n   143→  const forkTheme = useMutation(api.themes.fork);\n   144→  const [forking, setForking] = useState(false);\n   145→\n   146→  // Forked-from theme info (for link)\n   147→  const forkedFrom = useQuery(\n   148→    api.themes.getBasicInfo,\n   149→    theme?.forkedFromId ? { id: theme.forkedFromId } : \"skip\"\n   150→  );\n   151→\n   152→  // Edit/Delete mutations\n   153→  const updateTheme = useMutation(api.themes.update);\n   154→  const removeTheme = useMutation(api.themes.remove);\n   155→\n   156→  // Edit mode state\n   157→  const [editing, setEditing] = useState(false);\n   158→  const [editName, setEditName] = useState(\"\");\n   159→  const [editDescription, setEditDescription] = useState(\"\");\n   160→  const [editIsPublic, setEditIsPublic] = useState(true);\n   161→  const [editColors, setEditColors] = useState<Record<string, string>>({});\n   162→  const [editFonts, setEditFonts] = useState<Record<string, string>>({});\n   163→  const [saving, setSaving] = useState(false);\n   164→  const [saveError, setSaveError] = useState<string | null>(null);\n   165→\n   166→  // Delete state\n   167→  const [confirmingDelete, setConfirmingDelete] = useState(false);\n   168→  const [deleting, setDeleting] = useState(false);\n   169→  const [deleteError, setDeleteError] = useState<string | null>(null);\n   170→\n   171→  // Owner detection\n   172→  const isOwner = !!(currentUser && theme && currentUser._id === theme.authorId);\n   173→\n   174→  function enterEditMode() {\n   175→    if (!theme) return;\n   176→    setEditName(theme.name);\n   177→    setEditDescription(theme.description ?? \"\");\n   178→    setEditIsPublic(theme.isPublic);\n   179→    const c: Record<string, string> = {};\n   180→    const themeColors = theme.colors as Record<string, string | undefined>;\n   181→    for (const { key } of COLOR_LABELS) {\n   182→      if (themeColors[key]) c[key] = themeColors[key]!;\n   183→    }\n   184→    setEditColors(c);\n   185→    const f: Record<string, string> = {};\n   186→    if (theme.fonts) {\n   187→      for (const k of FONT_KEYS) {\n   188→        if (theme.fonts[k]) f[k] = theme.fonts[k]!;\n   189→      }\n   190→    }\n   191→    setEditFonts(f);\n   192→    setSaveError(null);\n   193→    setEditing(true);\n   194→  }\n   195→\n   196→  function cancelEdit() {\n   197→    setEditing(false);\n   198→    setSaveError(null);\n   199→  }\n   200→\n   201→  async function handleSave() {\n   202→    if (!theme) return;\n   203→    setSaving(true);\n   204→    setSaveError(null);\n   205→    try {\n   206→      const updates: Record<string, unknown> = { id: theme._id };\n   207→      if (editName !== theme.name) updates.name = editName;\n   208→      if (editDescription !== (theme.description ?? \"\"))\n   209→        updates.description = editDescription;\n   210→      if (editIsPublic !== theme.isPublic) updates.isPublic = editIsPublic;\n   211→\n   212→      // Colors: always send all edited colors\n   213→      const origColors = theme.colors as Record<string, string | undefined>;\n   214→      const colorsChanged = COLOR_LABELS.some(\n   215→        ({ key }) => (editColors[key] ?? \"\") !== (origColors[key] ?? \"\")\n   216→      );\n   217→      if (colorsChanged) updates.colors = editColors;\n   218→\n   219→      // Fonts: send if changed\n   220→      const origFonts = (theme.fonts ?? {}) as Record<string, string | undefined>;\n   221→      const fontsChanged = FONT_KEYS.some(\n   222→        (k) => (editFonts[k] ?? \"\") !== (origFonts[k] ?? \"\")\n   223→      );\n   224→      if (fontsChanged) {\n   225→        const fontPayload: Record<string, string> = {};\n   226→        for (const k of FONT_KEYS) {\n   227→          if (editFonts[k]?.trim()) fontPayload[k] = editFonts[k];\n   228→        }\n   229→        updates.fonts = fontPayload;\n   230→      }\n   231→\n   232→      const result = await updateTheme(updates as Parameters<typeof updateTheme>[0]);\n   233→      setEditing(false);\n   234→\n   235→      // If name changed, the slug changed server-side — redirect using the returned slug\n   236→      if (editName !== theme.name && result?.slug) {\n   237→        router.push(`/theme/${result.slug}`);\n   238→      }\n   239→    } catch (err) {\n   240→      setSaveError(err instanceof Error ? err.message : \"Failed to save\");\n   241→    } finally {\n   242→      setSaving(false);\n   243→    }\n   244→  }\n   245→\n   246→  async function handleDelete() {\n   247→    if (!theme) return;\n   248→    setDeleting(true);\n   249→    setDeleteError(null);\n   250→    try {\n   251→      await removeTheme({ id: theme._id });\n   252→      router.push(\"/\");\n   253→    } catch (err) {\n   254→      setDeleteError(err instanceof Error ? err.message : \"Failed to delete\");\n   255→      setDeleting(false);\n   256→    }\n   257→  }\n   258→\n   259→  // Loading state\n   260→  if (theme === undefined) {\n   261→    return (\n   262→      <div className=\"min-h-screen flex items-center justify-center\">\n   263→        <div className=\"animate-pulse text-gray-400 text-lg\">\n   264→          Loading theme...\n   265→        </div>\n   266→      </div>\n   267→    );\n   268→  }\n   269→\n   270→  // Not found\n   271→  if (theme === null) {\n   272→    return (\n   273→      <div className=\"min-h-screen flex flex-col items-center justify-center gap-4\">\n   274→        <h1 className=\"text-2xl font-bold text-gray-800\">Theme not found</h1>\n   275→        <p className=\"text-gray-500\">\n   276→          This theme doesn&apos;t exist or is private.\n   277→        </p>\n   278→        <a href=\"/\" className=\"text-blue-600 hover:underline text-sm\">\n   279→          Back to gallery\n   280→        </a>\n   281→      </div>\n   282→    );\n   283→  }\n   284→\n   285→  const colors = editing\n   286→    ? (editColors as Record<string, string | undefined>)\n   287→    : (theme.colors as Record<string, string | undefined>);\n   288→\n   289→  async function handleToggleStar() {\n   290→    if (!theme || !currentUser) return;\n   291→    await toggleStar({ themeId: theme._id });\n   292→  }\n   293→\n   294→  async function handleSubmitComment(e: React.FormEvent) {\n   295→    e.preventDefault();\n   296→    if (!theme || !commentBody.trim()) return;\n   297→    setSubmittingComment(true);\n   298→    try {\n   299→      await createComment({ themeId: theme._id, body: commentBody.trim() });\n   300→      setCommentBody(\"\");\n   301→    } finally {\n   302→      setSubmittingComment(false);\n   303→    }\n   304→  }\n   305→\n   306→  async function handleFork() {\n   307→    if (!theme) return;\n   308→    setForking(true);\n   309→    try {\n   310→      const result = await forkTheme({ id: theme._id });\n   311→      if (result) {\n   312→        router.push(`/theme/${result.slug}`);\n   313→      }\n   314→    } catch {\n   315→      // Fork may fail if not authenticated\n   316→    } finally {\n   317→      setForking(false);\n   318→    }\n   319→  }\n   320→\n   321→  return (\n   322→    <div className=\"min-h-screen bg-gray-50\">\n   323→      {/* Header */}\n   324→      <header className=\"bg-white border-b border-gray-200\">\n   325→        <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n   326→          <a\n   327→            href=\"/\"\n   328→            className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n   329→          >\n   330→            ThemeDrops\n   331→          </a>\n   332→          <div className=\"flex items-center gap-3\">\n   333→            <CreateThemeLink />\n   334→            <AuthControls />\n   335→          </div>\n   336→        </div>\n   337→      </header>\n   338→\n   339→      <main className=\"max-w-4xl mx-auto px-6 py-10 space-y-10\">\n   340→        {/* Theme header */}\n   341→        <div className=\"space-y-3\">\n   342→          <div className=\"flex items-start justify-between gap-4\">\n   343→            <div className=\"space-y-1 flex-1\">\n   344→              {editing ? (\n   345→                <input\n   346→                  type=\"text\"\n   347→                  value={editName}\n   348→                  onChange={(e) => setEditName(e.target.value)}\n   349→                  className=\"text-3xl font-bold text-gray-900 w-full border border-gray-300 rounded-lg px-3 py-1 focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   350→                />\n   351→              ) : (\n   352→                <h1 className=\"text-3xl font-bold text-gray-900\">\n   353→                  {theme.name}\n   354→                </h1>\n   355→              )}\n   356→              {author && (\n   357→                <p className=\"text-sm text-gray-500\">\n   358→                  by{\" \"}\n   359→                  <Link\n   360→                    href={`/user/${author.username}`}\n   361→                    className=\"font-medium text-gray-700 hover:text-blue-600 transition-colors\"\n   362→                  >\n   363→                    {author.displayName ?? author.username}\n   364→                  </Link>\n   365→                </p>\n   366→              )}\n   367→            </div>\n   368→\n   369→            <div className=\"flex items-center gap-2\">\n   370→              {/* Owner controls */}\n   371→              {isOwner && !editing && (\n   372→                <>\n   373→                  <button\n   374→                    onClick={enterEditMode}\n   375→                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors\"\n   376→                  >\n   377→                    Edit\n   378→                  </button>\n   379→                  {!confirmingDelete ? (\n   380→                    <button\n   381→                      onClick={() => setConfirmingDelete(true)}\n   382→                      className=\"px-4 py-2 rounded-lg border border-red-200 bg-white text-sm font-medium text-red-600 hover:bg-red-50 transition-colors\"\n   383→                    >\n   384→                      Delete\n   385→                    </button>\n   386→                  ) : (\n   387→                    <div className=\"flex items-center gap-2 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   388→                      <span className=\"text-sm text-red-700\">Delete this theme?</span>\n   389→                      <button\n   390→                        onClick={handleDelete}\n   391→                        disabled={deleting}\n   392→                        className=\"px-3 py-1 rounded bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition-colors disabled:opacity-50\"\n   393→                      >\n   394→                        {deleting ? \"Deleting...\" : \"Confirm\"}\n   395→                      </button>\n   396→                      <button\n   397→                        onClick={() => {\n   398→                          setConfirmingDelete(false);\n   399→                          setDeleteError(null);\n   400→                        }}\n   401→                        disabled={deleting}\n   402→                        className=\"px-3 py-1 rounded border border-red-200 text-sm text-red-600 hover:bg-red-100 transition-colors disabled:opacity-50\"\n   403→                      >\n   404→                        Cancel\n   405→                      </button>\n   406→                    </div>\n   407→                  )}\n   408→                </>\n   409→              )}\n   410→\n   411→              {/* Edit mode controls */}\n   412→              {editing && (\n   413→                <>\n   414→                  <button\n   415→                    onClick={handleSave}\n   416→                    disabled={saving || !editName.trim()}\n   417→                    className=\"px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n   418→                  >\n   419→                    {saving ? \"Saving...\" : \"Save\"}\n   420→                  </button>\n   421→                  <button\n   422→                    onClick={cancelEdit}\n   423→                    disabled={saving}\n   424→                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50\"\n   425→                  >\n   426→                    Cancel\n   427→                  </button>\n   428→                </>\n   429→              )}\n   430→\n   431→              {/* Star button */}\n   432→              {!editing && (\n   433→                <button\n   434→                  onClick={handleToggleStar}\n   435→                  disabled={!currentUser}\n   436→                  className={`flex items-center gap-1.5 px-4 py-2 rounded-lg border text-sm font-medium transition-colors ${\n   437→                    isStarred\n   438→                      ? \"bg-yellow-50 border-yellow-300 text-yellow-700\"\n   439→                      : \"bg-white border-gray-200 text-gray-600 hover:bg-gray-50\"\n   440→                  } ${!currentUser ? \"opacity-50 cursor-not-allowed\" : \"cursor-pointer\"}`}\n   441→                  title={!currentUser ? \"Sign in to star themes\" : undefined}\n   442→                >\n   443→                  <span className=\"text-lg\">\n   444→                    {isStarred ? \"\\u2605\" : \"\\u2606\"}\n   445→                  </span>\n   446→                  <span>{theme.starCount}</span>\n   447→                </button>\n   448→              )}\n   449→            </div>\n   450→          </div>\n   451→\n   452→          {/* Delete error */}\n   453→          {deleteError && (\n   454→            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   455→              {deleteError}\n   456→            </p>\n   457→          )}\n   458→\n   459→          {/* Save error */}\n   460→          {saveError && (\n   461→            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   462→              {saveError}\n   463→            </p>\n   464→          )}\n   465→\n   466→          {/* Description */}\n   467→          {editing ? (\n   468→            <textarea\n   469→              value={editDescription}\n   470→              onChange={(e) => setEditDescription(e.target.value)}\n   471→              placeholder=\"Theme description...\"\n   472→              rows={3}\n   473→              className=\"w-full text-gray-600 leading-relaxed border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   474→            />\n   475→          ) : (\n   476→            theme.description && (\n   477→              <p className=\"text-gray-600 leading-relaxed\">\n   478→                {theme.description}\n   479→              </p>\n   480→            )\n   481→          )}\n   482→\n   483→          {/* Visibility toggle */}\n   484→          {editing && (\n   485→            <div className=\"flex items-center gap-3\">\n   486→              <span className=\"text-sm text-gray-600\">Visibility:</span>\n   487→              <button\n   488→                onClick={() => setEditIsPublic(!editIsPublic)}\n   489→                className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${\n   490→                  editIsPublic ? \"bg-blue-600\" : \"bg-gray-300\"\n   491→                }`}\n   492→              >\n   493→                <span\n   494→                  className={`inline-block h-4 w-4 rounded-full bg-white transition-transform ${\n   495→                    editIsPublic ? \"translate-x-6\" : \"translate-x-1\"\n   496→                  }`}\n   497→                />\n   498→              </button>\n   499→              <span className=\"text-sm text-gray-500\">\n   500→                {editIsPublic ? \"Public\" : \"Private\"}\n   501→              </span>\n   502→            </div>\n   503→          )}\n   504→\n   505→          {theme.forkedFromId && forkedFrom && (\n   506→            <p className=\"text-sm text-gray-400 italic\">\n   507→              Forked from{\" \"}\n   508→              <a\n   509→                href={`/theme/${forkedFrom.slug}`}\n   510→                className=\"text-blue-500 hover:underline\"\n   511→              >\n   512→                {forkedFrom.name}\n   513→              </a>\n   514→            </p>\n   515→          )}\n   516→\n   517→          {!editing && (\n   518→            <p className=\"text-xs text-gray-400 font-mono bg-gray-100 inline-block px-2 py-1 rounded\">\n   519→              API: /api/theme/{theme.slug}\n   520→            </p>\n   521→          )}\n   522→        </div>\n   523→\n   524→        {/* Color palette */}\n   525→        <section className=\"space-y-4\">\n   526→          <h2 className=\"text-lg font-semibold text-gray-800\">Color Palette</h2>\n   527→          <div className=\"flex flex-wrap gap-6\">\n   528→            {editing\n   529→              ? COLOR_LABELS.map(({ key, label }) => (\n   530→                  <EditableColorSwatch\n   531→                    key={key}\n   532→                    color={editColors[key] ?? \"#000000\"}\n   533→                    label={label}\n   534→                    onChange={(value) =>\n   535→                      setEditColors((prev) => ({ ...prev, [key]: value }))\n   536→                    }\n   537→                  />\n   538→                ))\n   539→              : COLOR_LABELS.map(({ key, label }) => {\n   540→                  const color = colors[key];\n   541→                  if (!color) return null;\n   542→                  return <ColorSwatch key={key} color={color} label={label} />;\n   543→                })}\n   544→          </div>\n   545→        </section>\n   546→\n   547→        {/* Live preview */}\n   548→        <section className=\"space-y-4\">\n   549→          <h2 className=\"text-lg font-semibold text-gray-800\">Preview</h2>\n   550→          <LivePreview colors={colors} />\n   551→        </section>\n   552→\n   553→        {/* Fonts */}\n   554→        {editing ? (\n   555→          <section className=\"space-y-4\">\n   556→            <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   557→            <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   558→              {FONT_KEYS.map((k) => (\n   559→                <div\n   560→                  key={k}\n   561→                  className=\"bg-white rounded-lg border border-gray-200 p-4\"\n   562→                >\n   563→                  <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   564→                    {k}\n   565→                  </p>\n   566→                  <input\n   567→                    type=\"text\"\n   568→                    value={editFonts[k] ?? \"\"}\n   569→                    onChange={(e) =>\n   570→                      setEditFonts((prev) => ({ ...prev, [k]: e.target.value }))\n   571→                    }\n   572→                    placeholder={`${k} font name`}\n   573→                    className=\"w-full text-sm border border-gray-200 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n   574→                  />\n   575→                  {editFonts[k] && (\n   576→                    <p\n   577→                      className=\"text-sm text-gray-500 mt-2\"\n   578→                      style={{ fontFamily: editFonts[k] }}\n   579→                    >\n   580→                      The quick brown fox jumps over the lazy dog.\n   581→                    </p>\n   582→                  )}\n   583→                </div>\n   584→              ))}\n   585→            </div>\n   586→          </section>\n   587→        ) : (\n   588→          theme.fonts &&\n   589→          (theme.fonts.sans || theme.fonts.serif || theme.fonts.mono) && (\n   590→            <section className=\"space-y-4\">\n   591→              <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   592→              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   593→                {theme.fonts.sans && (\n   594→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   595→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   596→                      Sans\n   597→                    </p>\n   598→                    <p\n   599→                      className=\"text-lg\"\n   600→                      style={{ fontFamily: theme.fonts.sans }}\n   601→                    >\n   602→                      {theme.fonts.sans}\n   603→                    </p>\n   604→                    <p\n   605→                      className=\"text-sm text-gray-500 mt-1\"\n   606→                      style={{ fontFamily: theme.fonts.sans }}\n   607→                    >\n   608→                      The quick brown fox jumps over the lazy dog.\n   609→                    </p>\n   610→                  </div>\n   611→                )}\n   612→                {theme.fonts.serif && (\n   613→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   614→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   615→                      Serif\n   616→                    </p>\n   617→                    <p\n   618→                      className=\"text-lg\"\n   619→                      style={{ fontFamily: theme.fonts.serif }}\n   620→                    >\n   621→                      {theme.fonts.serif}\n   622→                    </p>\n   623→                    <p\n   624→                      className=\"text-sm text-gray-500 mt-1\"\n   625→                      style={{ fontFamily: theme.fonts.serif }}\n   626→                    >\n   627→                      The quick brown fox jumps over the lazy dog.\n   628→                    </p>\n   629→                  </div>\n   630→                )}\n   631→                {theme.fonts.mono && (\n   632→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   633→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   634→                      Mono\n   635→                    </p>\n   636→                    <p\n   637→                      className=\"text-lg font-mono\"\n   638→                      style={{ fontFamily: theme.fonts.mono }}\n   639→                    >\n   640→                      {theme.fonts.mono}\n   641→                    </p>\n   642→                    <p\n   643→                      className=\"text-sm text-gray-500 mt-1\"\n   644→                      style={{ fontFamily: theme.fonts.mono }}\n   645→                    >\n   646→                      The quick brown fox jumps over the lazy dog.\n   647→                    </p>\n   648→                  </div>\n   649→                )}\n   650→              </div>\n   651→            </section>\n   652→          )\n   653→        )}\n   654→\n   655→        {/* Fork button */}\n   656→        {currentUser && !editing && (\n   657→          <div>\n   658→            <button\n   659→              onClick={handleFork}\n   660→              disabled={forking}\n   661→              className=\"px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors disabled:opacity-50\"\n   662→            >\n   663→              {forking ? \"Forking...\" : \"Fork this theme\"}\n   664→            </button>\n   665→          </div>\n   666→        )}\n   667→\n   668→        {/* Comments */}\n   669→        {!editing && (\n   670→          <section className=\"space-y-6\">\n   671→            <h2 className=\"text-lg font-semibold text-gray-800\">\n   672→              Comments{\" \"}\n   673→              {comments && comments.length > 0 && (\n   674→                <span className=\"text-gray-400 font-normal\">\n   675→                  ({comments.length})\n   676→                </span>\n   677→              )}\n   678→            </h2>\n   679→\n   680→            {comments === undefined && (\n   681→              <p className=\"text-gray-400 text-sm animate-pulse\">\n   682→                Loading comments...\n   683→              </p>\n   684→            )}\n   685→\n   686→            {comments && comments.length === 0 && (\n   687→              <p className=\"text-gray-400 text-sm\">No comments yet.</p>\n   688→            )}\n   689→\n   690→            {comments && comments.length > 0 && (\n   691→              <div className=\"space-y-4\">\n   692→                {comments.map((comment) => (\n   693→                  <div\n   694→                    key={comment._id}\n   695→                    className=\"bg-white rounded-lg border border-gray-200 p-4\"\n   696→                  >\n   697→                    <div className=\"flex items-center gap-2 mb-2\">\n   698→                      {comment.author?.avatarUrl && (\n   699→                        <img\n   700→                          src={comment.author.avatarUrl}\n   701→                          alt=\"\"\n   702→                          className=\"w-6 h-6 rounded-full\"\n   703→                        />\n   704→                      )}\n   705→                      <span className=\"text-sm font-medium text-gray-700\">\n   706→                        {comment.author?.displayName ??\n   707→                          comment.author?.username ??\n   708→                          \"Unknown\"}\n   709→                      </span>\n   710→                    </div>\n   711→                    <p className=\"text-sm text-gray-600\">{comment.body}</p>\n   712→                  </div>\n   713→                ))}\n   714→              </div>\n   715→            )}\n   716→\n   717→            {/* Add comment form */}\n   718→            {currentUser && (\n   719→              <form onSubmit={handleSubmitComment} className=\"flex gap-3\">\n   720→                <input\n   721→                  type=\"text\"\n   722→                  value={commentBody}\n   723→                  onChange={(e) => setCommentBody(e.target.value)}\n   724→                  placeholder=\"Add a comment...\"\n   725→                  className=\"flex-1 px-4 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n   726→                />\n   727→                <button\n   728→                  type=\"submit\"\n   729→                  disabled={!commentBody.trim() || submittingComment}\n   730→                  className=\"px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n   731→                >\n   732→                  {submittingComment ? \"Posting...\" : \"Post\"}\n   733→                </button>\n   734→              </form>\n   735→            )}\n   736→          </section>\n   737→        )}\n   738→      </main>\n   739→    </div>\n   740→  );\n   741→}\n   742→"}]},"parent_tool_use_id":"toolu_016hJAaxGpG4Zvrpxyt1D4EV","session_id":"531f43a4-ebc3-4fb3-8c9b-48ab32ad838e","uuid":"8638aa57-30e1-456f-9c5e-2acefb091d02","timestamp":"2026-03-28T00:14:48.839Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CabjbUVV9majXpBrXMfZQU","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { useParams } from \"next/navigation\";\n     4→import { useQuery, useMutation } from \"convex/react\";\n     5→import { api } from \"../../../../convex/_generated/api\";\n     6→import { Doc } from \"../../../../convex/_generated/dataModel\";\n     7→import { useState } from \"react\";\n     8→import Link from \"next/link\";\n     9→import AuthControls from \"../../components/AuthControls\";\n    10→import CreateThemeLink from \"../../components/CreateThemeLink\";\n    11→\n    12→const COLOR_KEYS = [\n    13→  \"background\",\n    14→  \"foreground\",\n    15→  \"primary\",\n    16→  \"secondary\",\n    17→  \"accent\",\n    18→  \"muted\",\n    19→] as const;\n    20→\n    21→function ThemeCard({ theme }: { theme: Doc<\"themes\"> }) {\n    22→  const colors = theme.colors;\n    23→  const primaryColor = colors.primary ?? colors.accent ?? \"#6366f1\";\n    24→  const bgColor = colors.background ?? \"#ffffff\";\n    25→  const fgColor = colors.foreground ?? \"#000000\";\n    26→\n    27→  return (\n    28→    <Link\n    29→      href={`/theme/${theme.slug}`}\n    30→      className=\"group relative flex flex-col rounded-2xl border border-gray-200/80 bg-white overflow-hidden transition-all duration-300 hover:shadow-xl hover:shadow-gray-200/50 hover:-translate-y-1 hover:border-gray-300/80\"\n    31→    >\n    32→      <div className=\"relative h-28 overflow-hidden\">\n    33→        <div className=\"absolute inset-0 flex\">\n    34→          {COLOR_KEYS.map((key) => {\n    35→            const color = colors[key];\n    36→            if (!color) return null;\n    37→            return (\n    38→              <div\n    39→                key={key}\n    40→                className=\"flex-1 transition-all duration-300 group-hover:flex-[1.2]\"\n    41→                style={{ backgroundColor: color }}\n    42→              />\n    43→            );\n    44→          })}\n    45→        </div>\n    46→        <div className=\"absolute bottom-0 left-0 right-0 h-8 bg-gradient-to-t from-white to-transparent\" />\n    47→      </div>\n    48→\n    49→      <div className=\"flex flex-col flex-1 px-5 pb-5 pt-3\">\n    50→        <h3 className=\"text-base font-semibold text-gray-900 tracking-tight group-hover:text-gray-700 transition-colors truncate\">\n    51→          {theme.name}\n    52→        </h3>\n    53→\n    54→        {theme.description && (\n    55→          <p className=\"text-xs text-gray-500 mt-2 line-clamp-2 leading-relaxed\">\n    56→            {theme.description}\n    57→          </p>\n    58→        )}\n    59→\n    60→        <div className=\"mt-auto pt-4 flex items-center justify-between\">\n    61→          <div className=\"flex gap-1\">\n    62→            {COLOR_KEYS.map((key) => {\n    63→              const color = colors[key];\n    64→              if (!color) return null;\n    65→              return (\n    66→                <div\n    67→                  key={key}\n    68→                  className=\"w-4 h-4 rounded-full border border-gray-200/60 shadow-sm\"\n    69→                  style={{ backgroundColor: color }}\n    70→                  title={`${key}: ${color}`}\n    71→                />\n    72→              );\n    73→            })}\n    74→          </div>\n    75→\n    76→          <div className=\"flex items-center gap-1 text-xs text-gray-400\">\n    77→            <span className=\"text-amber-400\">&#9733;</span>\n    78→            <span>{theme.starCount}</span>\n    79→          </div>\n    80→        </div>\n    81→\n    82→        <div\n    83→          className=\"mt-3 rounded-lg px-3 py-2 flex items-center justify-between\"\n    84→          style={{ backgroundColor: bgColor }}\n    85→        >\n    86→          <span\n    87→            className=\"text-[10px] font-medium truncate\"\n    88→            style={{ color: fgColor }}\n    89→          >\n    90→            Aa Preview\n    91→          </span>\n    92→          <div\n    93→            className=\"w-10 h-4 rounded\"\n    94→            style={{ backgroundColor: primaryColor }}\n    95→          />\n    96→        </div>\n    97→      </div>\n    98→    </Link>\n    99→  );\n   100→}\n   101→\n   102→export default function UserProfilePage() {\n   103→  const params = useParams<{ username: string }>();\n   104→  const username = params.username;\n   105→\n   106→  const user = useQuery(api.users.getByUsername, { username });\n   107→  const currentUser = useQuery(api.users.getCurrentUser);\n   108→  const userThemes = useQuery(\n   109→    api.themes.getByAuthor,\n   110→    user ? { authorId: user._id } : \"skip\"\n   111→  );\n   112→  const starredThemes = useQuery(\n   113→    api.stars.getStarredThemes,\n   114→    user ? { userId: user._id } : \"skip\"\n   115→  );\n   116→\n   117→  const updateProfile = useMutation(api.users.updateProfile);\n   118→\n   119→  const isOwner = !!(currentUser && user && currentUser._id === user._id);\n   120→\n   121→  // Edit state\n   122→  const [editing, setEditing] = useState(false);\n   123→  const [editDisplayName, setEditDisplayName] = useState(\"\");\n   124→  const [editBio, setEditBio] = useState(\"\");\n   125→  const [saving, setSaving] = useState(false);\n   126→  const [saveError, setSaveError] = useState<string | null>(null);\n   127→\n   128→  // Tab state\n   129→  const [activeTab, setActiveTab] = useState<\"themes\" | \"starred\">(\"themes\");\n   130→\n   131→  function enterEditMode() {\n   132→    if (!user) return;\n   133→    setEditDisplayName(user.displayName ?? \"\");\n   134→    setEditBio(user.bio ?? \"\");\n   135→    setSaveError(null);\n   136→    setEditing(true);\n   137→  }\n   138→\n   139→  function cancelEdit() {\n   140→    setEditing(false);\n   141→    setSaveError(null);\n   142→  }\n   143→\n   144→  async function handleSave() {\n   145→    setSaving(true);\n   146→    setSaveError(null);\n   147→    try {\n   148→      await updateProfile({\n   149→        displayName: editDisplayName.trim(),\n   150→        bio: editBio.trim(),\n   151→      });\n   152→      setEditing(false);\n   153→    } catch (err) {\n   154→      setSaveError(err instanceof Error ? err.message : \"Failed to save\");\n   155→    } finally {\n   156→      setSaving(false);\n   157→    }\n   158→  }\n   159→\n   160→  // Loading\n   161→  if (user === undefined) {\n   162→    return (\n   163→      <div className=\"min-h-screen bg-gray-50\">\n   164→        <header className=\"bg-white border-b border-gray-200\">\n   165→          <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n   166→            <Link\n   167→              href=\"/\"\n   168→              className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n   169→            >\n   170→              ThemeDrops\n   171→            </Link>\n   172→            <div className=\"flex items-center gap-3\">\n   173→              <CreateThemeLink />\n   174→              <AuthControls />\n   175→            </div>\n   176→          </div>\n   177→        </header>\n   178→        <div className=\"flex items-center justify-center py-32\">\n   179→          <div className=\"animate-pulse text-gray-400 text-lg\">\n   180→            Loading profile...\n   181→          </div>\n   182→        </div>\n   183→      </div>\n   184→    );\n   185→  }\n   186→\n   187→  // Not found\n   188→  if (user === null) {\n   189→    return (\n   190→      <div className=\"min-h-screen bg-gray-50\">\n   191→        <header className=\"bg-white border-b border-gray-200\">\n   192→          <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n   193→            <Link\n   194→              href=\"/\"\n   195→              className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n   196→            >\n   197→              ThemeDrops\n   198→            </Link>\n   199→            <div className=\"flex items-center gap-3\">\n   200→              <CreateThemeLink />\n   201→              <AuthControls />\n   202→            </div>\n   203→          </div>\n   204→        </header>\n   205→        <div className=\"flex flex-col items-center justify-center py-32 gap-4\">\n   206→          <h1 className=\"text-2xl font-bold text-gray-800\">User not found</h1>\n   207→          <p className=\"text-gray-500\">\n   208→            The user &quot;{username}&quot; doesn&apos;t exist.\n   209→          </p>\n   210→          <Link href=\"/\" className=\"text-blue-600 hover:underline text-sm\">\n   211→            Back to gallery\n   212→          </Link>\n   213→        </div>\n   214→      </div>\n   215→    );\n   216→  }\n   217→\n   218→  const themeCount = userThemes?.length ?? 0;\n   219→  const starCount = starredThemes?.length ?? 0;\n   220→  const initial = (user.displayName ?? user.username ?? \"?\")[0].toUpperCase();\n   221→\n   222→  return (\n   223→    <div className=\"min-h-screen bg-gray-50\">\n   224→      {/* Header */}\n   225→      <header className=\"bg-white border-b border-gray-200\">\n   226→        <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n   227→          <Link\n   228→            href=\"/\"\n   229→            className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n   230→          >\n   231→            ThemeDrops\n   232→          </Link>\n   233→          <div className=\"flex items-center gap-3\">\n   234→            <CreateThemeLink />\n   235→            <AuthControls />\n   236→          </div>\n   237→        </div>\n   238→      </header>\n   239→\n   240→      <main className=\"max-w-4xl mx-auto px-6 py-10 space-y-8\">\n   241→        {/* Profile header */}\n   242→        <div className=\"bg-white rounded-2xl border border-gray-200 p-6 sm:p-8\">\n   243→          <div className=\"flex items-start gap-6\">\n   244→            {/* Avatar */}\n   245→            {user.avatarUrl ? (\n   246→              <img\n   247→                src={user.avatarUrl}\n   248→                alt={user.displayName ?? user.username}\n   249→                className=\"w-20 h-20 rounded-full border border-gray-200 object-cover flex-shrink-0\"\n   250→              />\n   251→            ) : (\n   252→              <div className=\"w-20 h-20 rounded-full bg-gradient-to-br from-indigo-400 to-purple-500 flex items-center justify-center text-white text-2xl font-bold flex-shrink-0\">\n   253→                {initial}\n   254→              </div>\n   255→            )}\n   256→\n   257→            {/* Info */}\n   258→            <div className=\"flex-1 min-w-0\">\n   259→              {editing ? (\n   260→                <div className=\"space-y-3\">\n   261→                  <div>\n   262→                    <label className=\"text-xs text-gray-500 font-medium\">\n   263→                      Display Name\n   264→                    </label>\n   265→                    <input\n   266→                      type=\"text\"\n   267→                      value={editDisplayName}\n   268→                      onChange={(e) => setEditDisplayName(e.target.value)}\n   269→                      placeholder=\"Display name\"\n   270→                      className=\"w-full mt-1 px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   271→                    />\n   272→                  </div>\n   273→                  <div>\n   274→                    <label className=\"text-xs text-gray-500 font-medium\">\n   275→                      Bio\n   276→                    </label>\n   277→                    <textarea\n   278→                      value={editBio}\n   279→                      onChange={(e) => setEditBio(e.target.value)}\n   280→                      placeholder=\"Tell us about yourself...\"\n   281→                      rows={3}\n   282→                      className=\"w-full mt-1 px-3 py-2 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   283→                    />\n   284→                  </div>\n   285→                  {saveError && (\n   286→                    <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   287→                      {saveError}\n   288→                    </p>\n   289→                  )}\n   290→                  <div className=\"flex gap-2\">\n   291→                    <button\n   292→                      onClick={handleSave}\n   293→                      disabled={saving}\n   294→                      className=\"px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n   295→                    >\n   296→                      {saving ? \"Saving...\" : \"Save\"}\n   297→                    </button>\n   298→                    <button\n   299→                      onClick={cancelEdit}\n   300→                      disabled={saving}\n   301→                      className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50\"\n   302→                    >\n   303→                      Cancel\n   304→                    </button>\n   305→                  </div>\n   306→                </div>\n   307→              ) : (\n   308→                <>\n   309→                  <div className=\"flex items-center gap-3\">\n   310→                    <h1 className=\"text-2xl font-bold text-gray-900 truncate\">\n   311→                      {user.displayName ?? user.username}\n   312→                    </h1>\n   313→                    {isOwner && (\n   314→                      <button\n   315→                        onClick={enterEditMode}\n   316→                        className=\"px-3 py-1.5 rounded-lg border border-gray-200 bg-white text-xs font-medium text-gray-600 hover:bg-gray-50 transition-colors flex-shrink-0\"\n   317→                      >\n   318→                        Edit Profile\n   319→                      </button>\n   320→                    )}\n   321→                  </div>\n   322→                  <p className=\"text-sm text-gray-500 mt-0.5\">\n   323→                    @{user.username}\n   324→                  </p>\n   325→                  {user.bio && (\n   326→                    <p className=\"text-sm text-gray-600 mt-3 leading-relaxed\">\n   327→                      {user.bio}\n   328→                    </p>\n   329→                  )}\n   330→                </>\n   331→              )}\n   332→            </div>\n   333→          </div>\n   334→\n   335→          {/* Stats */}\n   336→          {!editing && (\n   337→            <div className=\"flex gap-6 mt-6 pt-6 border-t border-gray-100\">\n   338→              <div className=\"text-center\">\n   339→                <div className=\"text-lg font-semibold text-gray-900\">\n   340→                  {themeCount}\n   341→                </div>\n   342→                <div className=\"text-xs text-gray-500\">\n   343→                  {themeCount === 1 ? \"Theme\" : \"Themes\"}\n   344→                </div>\n   345→              </div>\n   346→              <div className=\"text-center\">\n   347→                <div className=\"text-lg font-semibold text-gray-900\">\n   348→                  {starCount}\n   349→                </div>\n   350→                <div className=\"text-xs text-gray-500\">\n   351→                  {starCount === 1 ? \"Star\" : \"Stars\"}\n   352→                </div>\n   353→              </div>\n   354→            </div>\n   355→          )}\n   356→        </div>\n   357→\n   358→        {/* Tabs */}\n   359→        <div className=\"flex gap-1 border-b border-gray-200\">\n   360→          <button\n   361→            onClick={() => setActiveTab(\"themes\")}\n   362→            className={`px-4 py-2.5 text-sm font-medium transition-colors border-b-2 -mb-px ${\n   363→              activeTab === \"themes\"\n   364→                ? \"border-gray-900 text-gray-900\"\n   365→                : \"border-transparent text-gray-500 hover:text-gray-700\"\n   366→            }`}\n   367→          >\n   368→            Themes {themeCount > 0 && `(${themeCount})`}\n   369→          </button>\n   370→          <button\n   371→            onClick={() => setActiveTab(\"starred\")}\n   372→            className={`px-4 py-2.5 text-sm font-medium transition-colors border-b-2 -mb-px ${\n   373→              activeTab === \"starred\"\n   374→                ? \"border-gray-900 text-gray-900\"\n   375→                : \"border-transparent text-gray-500 hover:text-gray-700\"\n   376→            }`}\n   377→          >\n   378→            Starred {starCount > 0 && `(${starCount})`}\n   379→          </button>\n   380→        </div>\n   381→\n   382→        {/* Theme grid */}\n   383→        {activeTab === \"themes\" && (\n   384→          <>\n   385→            {userThemes === undefined && (\n   386→              <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n   387→                {[...Array(3)].map((_, i) => (\n   388→                  <div\n   389→                    key={i}\n   390→                    className=\"flex flex-col rounded-2xl border border-gray-100 bg-white overflow-hidden animate-pulse\"\n   391→                  >\n   392→                    <div className=\"h-28 bg-gray-100\" />\n   393→                    <div className=\"px-5 pb-5 pt-3 space-y-3\">\n   394→                      <div className=\"h-4 bg-gray-100 rounded w-2/3\" />\n   395→                      <div className=\"h-3 bg-gray-50 rounded w-full mt-4\" />\n   396→                    </div>\n   397→                  </div>\n   398→                ))}\n   399→              </div>\n   400→            )}\n   401→\n   402→            {userThemes && userThemes.length > 0 && (\n   403→              <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n   404→                {userThemes.map((theme) => (\n   405→                  <ThemeCard key={theme._id} theme={theme} />\n   406→                ))}\n   407→              </div>\n   408→            )}\n   409→\n   410→            {userThemes && userThemes.length === 0 && (\n   411→              <div className=\"text-center py-16\">\n   412→                <div className=\"text-4xl mb-3 opacity-60\">&#127912;</div>\n   413→                <h2 className=\"text-lg font-semibold text-gray-700\">\n   414→                  No themes yet\n   415→                </h2>\n   416→                <p className=\"text-gray-400 mt-1 text-sm\">\n   417→                  {isOwner\n   418→                    ? \"Create your first theme to get started!\"\n   419→                    : \"This user hasn't created any themes yet.\"}\n   420→                </p>\n   421→              </div>\n   422→            )}\n   423→          </>\n   424→        )}\n   425→\n   426→        {activeTab === \"starred\" && (\n   427→          <>\n   428→            {starredThemes === undefined && (\n   429→              <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n   430→                {[...Array(3)].map((_, i) => (\n   431→                  <div\n   432→                    key={i}\n   433→                    className=\"flex flex-col rounded-2xl border border-gray-100 bg-white overflow-hidden animate-pulse\"\n   434→                  >\n   435→                    <div className=\"h-28 bg-gray-100\" />\n   436→                    <div className=\"px-5 pb-5 pt-3 space-y-3\">\n   437→                      <div className=\"h-4 bg-gray-100 rounded w-2/3\" />\n   438→                      <div className=\"h-3 bg-gray-50 rounded w-full mt-4\" />\n   439→                    </div>\n   440→                  </div>\n   441→                ))}\n   442→              </div>\n   443→            )}\n   444→\n   445→            {starredThemes && starredThemes.length > 0 && (\n   446→              <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n   447→                {starredThemes.map((theme) => (\n   448→                  <ThemeCard key={theme._id} theme={theme} />\n   449→                ))}\n   450→              </div>\n   451→            )}\n   452→\n   453→            {starredThemes && starredThemes.length === 0 && (\n   454→              <div className=\"text-center py-16\">\n   455→                <div className=\"text-4xl mb-3 opacity-60\">&#9734;</div>\n   456→                <h2 className=\"text-lg font-semibold text-gray-700\">\n   457→                  No starred themes\n   458→                </h2>\n   459→                <p className=\"text-gray-400 mt-1 text-sm\">\n   460→                  {isOwner\n   461→                    ? \"Star themes you like and they'll show up here.\"\n   462→                    : \"This user hasn't starred any themes yet.\"}\n   463→                </p>\n   464→              </div>\n   465→            )}\n   466→          </>\n   467→        )}\n   468→      </main>\n   469→    </div>\n   470→  );\n   471→}\n   472→"}]},"parent_tool_use_id":"toolu_016hJAaxGpG4Zvrpxyt1D4EV","session_id":"531f43a4-ebc3-4fb3-8c9b-48ab32ad838e","uuid":"158ae880-51ae-4efb-a9d5-8d002b4cf2cb","timestamp":"2026-03-28T00:14:48.850Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018tz3ebBWW4tyaLevjSeEHY","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { useState } from \"react\";\n     4→import { useRouter } from \"next/navigation\";\n     5→import { useConvexAuth, useMutation } from \"convex/react\";\n     6→import { api } from \"../../../convex/_generated/api\";\n     7→import AuthControls from \"../components/AuthControls\";\n     8→\n     9→const COLOR_FIELDS = [\n    10→  { key: \"background\", label: \"Background\", default: \"#ffffff\" },\n    11→  { key: \"foreground\", label: \"Foreground\", default: \"#111111\" },\n    12→  { key: \"primary\", label: \"Primary\", default: \"#3b82f6\" },\n    13→  { key: \"secondary\", label: \"Secondary\", default: \"#6366f1\" },\n    14→  { key: \"accent\", label: \"Accent\", default: \"#f59e0b\" },\n    15→  { key: \"muted\", label: \"Muted\", default: \"#6b7280\" },\n    16→] as const;\n    17→\n    18→function LivePreview({\n    19→  colors,\n    20→}: {\n    21→  colors: Record<string, string>;\n    22→}) {\n    23→  return (\n    24→    <div\n    25→      className=\"rounded-xl border p-6 space-y-4\"\n    26→      style={{\n    27→        backgroundColor: colors.background,\n    28→        color: colors.foreground,\n    29→        borderColor: colors.muted,\n    30→      }}\n    31→    >\n    32→      <h3 className=\"text-lg font-semibold\">Live Preview</h3>\n    33→      <p style={{ color: colors.muted }} className=\"text-sm\">\n    34→        This is how the theme looks when applied to a card.\n    35→      </p>\n    36→      <div className=\"flex gap-3\">\n    37→        <button\n    38→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    39→          style={{ backgroundColor: colors.primary }}\n    40→        >\n    41→          Primary\n    42→        </button>\n    43→        <button\n    44→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    45→          style={{ backgroundColor: colors.secondary }}\n    46→        >\n    47→          Secondary\n    48→        </button>\n    49→        <button\n    50→          className=\"px-4 py-2 rounded-lg text-sm font-medium border\"\n    51→          style={{\n    52→            backgroundColor: colors.accent,\n    53→            borderColor: colors.muted,\n    54→          }}\n    55→        >\n    56→          Accent\n    57→        </button>\n    58→      </div>\n    59→    </div>\n    60→  );\n    61→}\n    62→\n    63→export default function CreateThemePage() {\n    64→  const router = useRouter();\n    65→  const { isAuthenticated, isLoading: authLoading } = useConvexAuth();\n    66→  const createTheme = useMutation(api.themes.create);\n    67→\n    68→  const [name, setName] = useState(\"\");\n    69→  const [description, setDescription] = useState(\"\");\n    70→  const [isPublic, setIsPublic] = useState(true);\n    71→  const [colors, setColors] = useState<Record<string, string>>(\n    72→    Object.fromEntries(COLOR_FIELDS.map((f) => [f.key, f.default]))\n    73→  );\n    74→  const [fonts, setFonts] = useState({ sans: \"\", serif: \"\", mono: \"\" });\n    75→  const [submitting, setSubmitting] = useState(false);\n    76→  const [error, setError] = useState(\"\");\n    77→\n    78→  function updateColor(key: string, value: string) {\n    79→    setColors((prev) => ({ ...prev, [key]: value }));\n    80→  }\n    81→\n    82→  async function handleSubmit(e: React.FormEvent) {\n    83→    e.preventDefault();\n    84→    if (!name.trim()) return;\n    85→\n    86→    setSubmitting(true);\n    87→    setError(\"\");\n    88→\n    89→    try {\n    90→      const fontsArg =\n    91→        fonts.sans || fonts.serif || fonts.mono\n    92→          ? {\n    93→              ...(fonts.sans ? { sans: fonts.sans } : {}),\n    94→              ...(fonts.serif ? { serif: fonts.serif } : {}),\n    95→              ...(fonts.mono ? { mono: fonts.mono } : {}),\n    96→            }\n    97→          : undefined;\n    98→\n    99→      const result = await createTheme({\n   100→        name: name.trim(),\n   101→        description: description.trim() || undefined,\n   102→        isPublic,\n   103→        colors,\n   104→        fonts: fontsArg,\n   105→      });\n   106→\n   107→      if (result) {\n   108→        router.push(`/theme/${result.slug}`);\n   109→      }\n   110→    } catch (err) {\n   111→      setError(err instanceof Error ? err.message : \"Failed to create theme\");\n   112→    } finally {\n   113→      setSubmitting(false);\n   114→    }\n   115→  }\n   116→\n   117→  if (authLoading) {\n   118→    return (\n   119→      <div className=\"min-h-screen flex items-center justify-center\">\n   120→        <div className=\"animate-pulse text-gray-400 text-lg\">Loading...</div>\n   121→      </div>\n   122→    );\n   123→  }\n   124→\n   125→  return (\n   126→    <div className=\"min-h-screen bg-gray-50\">\n   127→      {/* Header */}\n   128→      <header className=\"bg-white border-b border-gray-200\">\n   129→        <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n   130→          <a\n   131→            href=\"/\"\n   132→            className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n   133→          >\n   134→            ThemeDrops\n   135→          </a>\n   136→          <AuthControls />\n   137→        </div>\n   138→      </header>\n   139→\n   140→      <main className=\"max-w-4xl mx-auto px-6 py-10\">\n   141→        {!isAuthenticated ? (\n   142→          <div className=\"text-center py-20\">\n   143→            <div className=\"text-5xl mb-4\">&#128274;</div>\n   144→            <h1 className=\"text-2xl font-bold text-gray-800\">\n   145→              Sign in to create a theme\n   146→            </h1>\n   147→            <p className=\"text-gray-500 mt-2 text-sm max-w-sm mx-auto\">\n   148→              You need to be signed in to create and share themes with the\n   149→              community.\n   150→            </p>\n   151→          </div>\n   152→        ) : (\n   153→          <div className=\"space-y-10\">\n   154→            <div className=\"space-y-1\">\n   155→              <h1 className=\"text-3xl font-bold text-gray-900\">\n   156→                Create a Theme\n   157→              </h1>\n   158→              <p className=\"text-gray-500 text-sm\">\n   159→                Pick your colors, choose your fonts, and share it with the\n   160→                world.\n   161→              </p>\n   162→            </div>\n   163→\n   164→            <form onSubmit={handleSubmit} className=\"space-y-8\">\n   165→              {/* Name & Description */}\n   166→              <section className=\"space-y-4\">\n   167→                <h2 className=\"text-lg font-semibold text-gray-800\">Details</h2>\n   168→                <div className=\"grid grid-cols-1 gap-4\">\n   169→                  <div>\n   170→                    <label\n   171→                      htmlFor=\"name\"\n   172→                      className=\"block text-sm font-medium text-gray-700 mb-1\"\n   173→                    >\n   174→                      Name <span className=\"text-red-400\">*</span>\n   175→                    </label>\n   176→                    <input\n   177→                      id=\"name\"\n   178→                      type=\"text\"\n   179→                      required\n   180→                      value={name}\n   181→                      onChange={(e) => setName(e.target.value)}\n   182→                      placeholder=\"My Awesome Theme\"\n   183→                      className=\"w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400 transition-all\"\n   184→                    />\n   185→                  </div>\n   186→                  <div>\n   187→                    <label\n   188→                      htmlFor=\"description\"\n   189→                      className=\"block text-sm font-medium text-gray-700 mb-1\"\n   190→                    >\n   191→                      Description\n   192→                    </label>\n   193→                    <textarea\n   194→                      id=\"description\"\n   195→                      value={description}\n   196→                      onChange={(e) => setDescription(e.target.value)}\n   197→                      placeholder=\"A brief description of your theme...\"\n   198→                      rows={3}\n   199→                      className=\"w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400 transition-all resize-none\"\n   200→                    />\n   201→                  </div>\n   202→                </div>\n   203→              </section>\n   204→\n   205→              {/* Visibility toggle */}\n   206→              <section className=\"space-y-4\">\n   207→                <h2 className=\"text-lg font-semibold text-gray-800\">\n   208→                  Visibility\n   209→                </h2>\n   210→                <div className=\"flex items-center gap-3\">\n   211→                  <button\n   212→                    type=\"button\"\n   213→                    onClick={() => setIsPublic(true)}\n   214→                    className={`px-4 py-2 rounded-lg text-sm font-medium border transition-colors ${\n   215→                      isPublic\n   216→                        ? \"bg-gray-900 text-white border-gray-900\"\n   217→                        : \"bg-white text-gray-600 border-gray-200 hover:bg-gray-50\"\n   218→                    }`}\n   219→                  >\n   220→                    Public\n   221→                  </button>\n   222→                  <button\n   223→                    type=\"button\"\n   224→                    onClick={() => setIsPublic(false)}\n   225→                    className={`px-4 py-2 rounded-lg text-sm font-medium border transition-colors ${\n   226→                      !isPublic\n   227→                        ? \"bg-gray-900 text-white border-gray-900\"\n   228→                        : \"bg-white text-gray-600 border-gray-200 hover:bg-gray-50\"\n   229→                    }`}\n   230→                  >\n   231→                    Private\n   232→                  </button>\n   233→                </div>\n   234→              </section>\n   235→\n   236→              {/* Colors */}\n   237→              <section className=\"space-y-4\">\n   238→                <h2 className=\"text-lg font-semibold text-gray-800\">Colors</h2>\n   239→                <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4\">\n   240→                  {COLOR_FIELDS.map(({ key, label }) => (\n   241→                    <div\n   242→                      key={key}\n   243→                      className=\"flex items-center gap-3 bg-white rounded-xl border border-gray-200 px-4 py-3\"\n   244→                    >\n   245→                      <input\n   246→                        type=\"color\"\n   247→                        value={colors[key]}\n   248→                        onChange={(e) => updateColor(key, e.target.value)}\n   249→                        className=\"w-10 h-10 rounded-lg border border-gray-200 cursor-pointer p-0.5\"\n   250→                      />\n   251→                      <div className=\"flex-1 min-w-0\">\n   252→                        <p className=\"text-sm font-medium text-gray-700\">\n   253→                          {label}\n   254→                        </p>\n   255→                        <input\n   256→                          type=\"text\"\n   257→                          value={colors[key]}\n   258→                          onChange={(e) => updateColor(key, e.target.value)}\n   259→                          className=\"w-full text-xs font-mono text-gray-500 bg-transparent border-none p-0 focus:outline-none focus:text-gray-900\"\n   260→                        />\n   261→                      </div>\n   262→                    </div>\n   263→                  ))}\n   264→                </div>\n   265→              </section>\n   266→\n   267→              {/* Live Preview */}\n   268→              <section className=\"space-y-4\">\n   269→                <h2 className=\"text-lg font-semibold text-gray-800\">\n   270→                  Preview\n   271→                </h2>\n   272→                <LivePreview colors={colors} />\n   273→              </section>\n   274→\n   275→              {/* Fonts */}\n   276→              <section className=\"space-y-4\">\n   277→                <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   278→                <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   279→                  {([\"sans\", \"serif\", \"mono\"] as const).map((fontKey) => (\n   280→                    <div key={fontKey}>\n   281→                      <label className=\"block text-sm font-medium text-gray-700 mb-1 capitalize\">\n   282→                        {fontKey}\n   283→                      </label>\n   284→                      <input\n   285→                        type=\"text\"\n   286→                        value={fonts[fontKey]}\n   287→                        onChange={(e) =>\n   288→                          setFonts((prev) => ({\n   289→                            ...prev,\n   290→                            [fontKey]: e.target.value,\n   291→                          }))\n   292→                        }\n   293→                        placeholder={\n   294→                          fontKey === \"sans\"\n   295→                            ? \"Inter\"\n   296→                            : fontKey === \"serif\"\n   297→                              ? \"Georgia\"\n   298→                              : \"Fira Code\"\n   299→                        }\n   300→                        className=\"w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400 transition-all\"\n   301→                      />\n   302→                    </div>\n   303→                  ))}\n   304→                </div>\n   305→              </section>\n   306→\n   307→              {/* Error */}\n   308→              {error && (\n   309→                <div className=\"rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700\">\n   310→                  {error}\n   311→                </div>\n   312→              )}\n   313→\n   314→              {/* Submit */}\n   315→              <div className=\"flex items-center gap-4\">\n   316→                <button\n   317→                  type=\"submit\"\n   318→                  disabled={submitting || !name.trim()}\n   319→                  className=\"px-6 py-3 rounded-xl bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed\"\n   320→                >\n   321→                  {submitting ? \"Creating...\" : \"Create Theme\"}\n   322→                </button>\n   323→                <a\n   324→                  href=\"/\"\n   325→                  className=\"text-sm text-gray-500 hover:text-gray-700 transition-colors\"\n   326→                >\n   327→                  Cancel\n   328→                </a>\n   329→              </div>\n   330→            </form>\n   331→          </div>\n   332→        )}\n   333→      </main>\n   334→    </div>\n   335→  );\n   336→}\n   337→"}]},"parent_tool_use_id":"toolu_016hJAaxGpG4Zvrpxyt1D4EV","session_id":"531f43a4-ebc3-4fb3-8c9b-48ab32ad838e","uuid":"ad3cfeb6-501a-4e6c-a3f9-ebc2bb29cc54","timestamp":"2026-03-28T00:14:49.055Z"}
