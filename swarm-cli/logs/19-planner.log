{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NTWT5gG7JJ5WryEGVkaVof","type":"tool_result","content":"     1→import { v } from \"convex/values\";\n     2→import { query, mutation } from \"./_generated/server\";\n     3→\n     4→export const isStarred = query({\n     5→  args: { themeId: v.id(\"themes\") },\n     6→  handler: async (ctx, args) => {\n     7→    const identity = await ctx.auth.getUserIdentity();\n     8→    if (!identity) return false;\n     9→\n    10→    const user = await ctx.db\n    11→      .query(\"users\")\n    12→      .withIndex(\"by_token\", (q) =>\n    13→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    14→      )\n    15→      .unique();\n    16→    if (!user) return false;\n    17→\n    18→    const star = await ctx.db\n    19→      .query(\"stars\")\n    20→      .withIndex(\"by_user_and_theme\", (q) =>\n    21→        q.eq(\"userId\", user._id).eq(\"themeId\", args.themeId)\n    22→      )\n    23→      .unique();\n    24→\n    25→    return star !== null;\n    26→  },\n    27→});\n    28→\n    29→export const toggle = mutation({\n    30→  args: { themeId: v.id(\"themes\") },\n    31→  handler: async (ctx, args) => {\n    32→    const identity = await ctx.auth.getUserIdentity();\n    33→    if (!identity) throw new Error(\"Not authenticated\");\n    34→\n    35→    const user = await ctx.db\n    36→      .query(\"users\")\n    37→      .withIndex(\"by_token\", (q) =>\n    38→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    39→      )\n    40→      .unique();\n    41→    if (!user) throw new Error(\"User not found\");\n    42→\n    43→    const theme = await ctx.db.get(args.themeId);\n    44→    if (!theme) throw new Error(\"Theme not found\");\n    45→    if (!theme.isPublic && theme.authorId !== user._id) {\n    46→      throw new Error(\"Not authorized\");\n    47→    }\n    48→\n    49→    const existing = await ctx.db\n    50→      .query(\"stars\")\n    51→      .withIndex(\"by_user_and_theme\", (q) =>\n    52→        q.eq(\"userId\", user._id).eq(\"themeId\", args.themeId)\n    53→      )\n    54→      .unique();\n    55→\n    56→    if (existing) {\n    57→      await ctx.db.delete(existing._id);\n    58→      await ctx.db.patch(args.themeId, {\n    59→        starCount: Math.max(0, theme.starCount - 1),\n    60→      });\n    61→      return false;\n    62→    } else {\n    63→      await ctx.db.insert(\"stars\", {\n    64→        userId: user._id,\n    65→        themeId: args.themeId,\n    66→      });\n    67→      await ctx.db.patch(args.themeId, {\n    68→        starCount: theme.starCount + 1,\n    69→      });\n    70→      return true;\n    71→    }\n    72→  },\n    73→});\n    74→\n    75→export const getStarredThemes = query({\n    76→  args: { userId: v.id(\"users\") },\n    77→  handler: async (ctx, args) => {\n    78→    const identity = await ctx.auth.getUserIdentity();\n    79→    let currentUserId = null;\n    80→    if (identity) {\n    81→      const viewer = await ctx.db\n    82→        .query(\"users\")\n    83→        .withIndex(\"by_token\", (q) =>\n    84→          q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    85→        )\n    86→        .unique();\n    87→      if (viewer) currentUserId = viewer._id;\n    88→    }\n    89→\n    90→    const stars = await ctx.db\n    91→      .query(\"stars\")\n    92→      .withIndex(\"by_user_and_theme\", (q) => q.eq(\"userId\", args.userId))\n    93→      .take(50);\n    94→\n    95→    const themes = [];\n    96→    for (const star of stars) {\n    97→      const theme = await ctx.db.get(star.themeId);\n    98→      if (theme && (theme.isPublic || theme.authorId === currentUserId)) {\n    99→        themes.push(theme);\n   100→      }\n   101→    }\n   102→    return themes;\n   103→  },\n   104→});\n   105→"}]},"parent_tool_use_id":"toolu_016hJAaxGpG4Zvrpxyt1D4EV","session_id":"531f43a4-ebc3-4fb3-8c9b-48ab32ad838e","uuid":"28c9d317-a799-4771-a3f4-bcf055f8022c","timestamp":"2026-03-28T00:14:49.220Z"}
