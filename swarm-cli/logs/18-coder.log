{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vfo4YonboTEBbu8mmmqyC9","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { usePaginatedQuery, useQuery } from \"convex/react\";\n     4→import { api } from \"../../convex/_generated/api\";\n     5→import { Doc } from \"../../convex/_generated/dataModel\";\n     6→import { useState, useEffect, useRef, useCallback } from \"react\";\n     7→import Link from \"next/link\";\n     8→import AuthControls from \"./components/AuthControls\";\n     9→import CreateThemeLink from \"./components/CreateThemeLink\";\n    10→\n    11→const COLOR_KEYS = [\n    12→  \"background\",\n    13→  \"foreground\",\n    14→  \"primary\",\n    15→  \"secondary\",\n    16→  \"accent\",\n    17→  \"muted\",\n    18→] as const;\n    19→\n    20→function useDebounce(value: string, delay: number) {\n    21→  const [debounced, setDebounced] = useState(value);\n    22→  useEffect(() => {\n    23→    const timer = setTimeout(() => setDebounced(value), delay);\n    24→    return () => clearTimeout(timer);\n    25→  }, [value, delay]);\n    26→  return debounced;\n    27→}\n    28→\n    29→function ThemeCard({\n    30→  theme,\n    31→  index,\n    32→}: {\n    33→  theme: Doc<\"themes\">;\n    34→  index: number;\n    35→}) {\n    36→  const author = useQuery(api.users.get, { id: theme.authorId });\n    37→  const colors = theme.colors;\n    38→  const primaryColor = colors.primary ?? colors.accent ?? \"#6366f1\";\n    39→  const bgColor = colors.background ?? \"#ffffff\";\n    40→  const fgColor = colors.foreground ?? \"#000000\";\n    41→\n    42→  return (\n    43→    <Link\n    44→      href={`/theme/${theme.slug}`}\n    45→      className=\"group relative flex flex-col rounded-2xl border border-gray-200/80 bg-white overflow-hidden transition-all duration-300 hover:shadow-xl hover:shadow-gray-200/50 hover:-translate-y-1 hover:border-gray-300/80\"\n    46→      style={{\n    47→        animationDelay: `${index * 60}ms`,\n    48→        animation: \"cardIn 0.5s ease-out both\",\n    49→      }}\n    50→    >\n    51→      {/* Color bar — the hero of each card */}\n    52→      <div className=\"relative h-28 overflow-hidden\">\n    53→        <div className=\"absolute inset-0 flex\">\n    54→          {COLOR_KEYS.map((key) => {\n    55→            const color = colors[key];\n    56→            if (!color) return null;\n    57→            return (\n    58→              <div\n    59→                key={key}\n    60→                className=\"flex-1 transition-all duration-300 group-hover:flex-[1.2]\"\n    61→                style={{ backgroundColor: color }}\n    62→              />\n    63→            );\n    64→          })}\n    65→        </div>\n    66→        {/* Subtle overlay fade at bottom */}\n    67→        <div className=\"absolute bottom-0 left-0 right-0 h-8 bg-gradient-to-t from-white to-transparent\" />\n    68→      </div>\n    69→\n    70→      {/* Card content */}\n    71→      <div className=\"flex flex-col flex-1 px-5 pb-5 pt-3\">\n    72→        <h3 className=\"text-base font-semibold text-gray-900 tracking-tight group-hover:text-gray-700 transition-colors truncate\">\n    73→          {theme.name}\n    74→        </h3>\n    75→\n    76→        {author && (\n    77→          <p className=\"text-xs text-gray-400 mt-0.5 truncate\">\n    78→            {author.displayName ?? author.username}\n    79→          </p>\n    80→        )}\n    81→\n    82→        {theme.description && (\n    83→          <p className=\"text-xs text-gray-500 mt-2 line-clamp-2 leading-relaxed\">\n    84→            {theme.description}\n    85→          </p>\n    86→        )}\n    87→\n    88→        <div className=\"mt-auto pt-4 flex items-center justify-between\">\n    89→          {/* Mini swatch row */}\n    90→          <div className=\"flex gap-1\">\n    91→            {COLOR_KEYS.map((key) => {\n    92→              const color = colors[key];\n    93→              if (!color) return null;\n    94→              return (\n    95→                <div\n    96→                  key={key}\n    97→                  className=\"w-4 h-4 rounded-full border border-gray-200/60 shadow-sm\"\n    98→                  style={{ backgroundColor: color }}\n    99→                  title={`${key}: ${color}`}\n   100→                />\n   101→              );\n   102→            })}\n   103→          </div>\n   104→\n   105→          {/* Star count */}\n   106→          <div className=\"flex items-center gap-1 text-xs text-gray-400\">\n   107→            <span className=\"text-amber-400\">&#9733;</span>\n   108→            <span>{theme.starCount}</span>\n   109→          </div>\n   110→        </div>\n   111→\n   112→        {/* Preview strip at bottom */}\n   113→        <div\n   114→          className=\"mt-3 rounded-lg px-3 py-2 flex items-center justify-between\"\n   115→          style={{ backgroundColor: bgColor }}\n   116→        >\n   117→          <span\n   118→            className=\"text-[10px] font-medium truncate\"\n   119→            style={{ color: fgColor }}\n   120→          >\n   121→            Aa Preview\n   122→          </span>\n   123→          <div\n   124→            className=\"w-10 h-4 rounded\"\n   125→            style={{ backgroundColor: primaryColor }}\n   126→          />\n   127→        </div>\n   128→      </div>\n   129→    </Link>\n   130→  );\n   131→}\n   132→\n   133→function CardSkeleton() {\n   134→  return (\n   135→    <div className=\"flex flex-col rounded-2xl border border-gray-100 bg-white overflow-hidden animate-pulse\">\n   136→      <div className=\"h-28 bg-gray-100\" />\n   137→      <div className=\"px-5 pb-5 pt-3 space-y-3\">\n   138→        <div className=\"h-4 bg-gray-100 rounded w-2/3\" />\n   139→        <div className=\"h-3 bg-gray-50 rounded w-1/3\" />\n   140→        <div className=\"h-3 bg-gray-50 rounded w-full mt-4\" />\n   141→        <div className=\"flex justify-between items-center pt-2\">\n   142→          <div className=\"flex gap-1\">\n   143→            {[...Array(6)].map((_, i) => (\n   144→              <div key={i} className=\"w-4 h-4 rounded-full bg-gray-100\" />\n   145→            ))}\n   146→          </div>\n   147→          <div className=\"h-3 w-6 bg-gray-100 rounded\" />\n   148→        </div>\n   149→      </div>\n   150→    </div>\n   151→  );\n   152→}\n   153→\n   154→export default function Home() {\n   155→  const [searchInput, setSearchInput] = useState(\"\");\n   156→  const debouncedSearch = useDebounce(searchInput, 300);\n   157→  const isSearching = debouncedSearch.length > 0;\n   158→\n   159→  const {\n   160→    results: pagedThemes,\n   161→    status,\n   162→    loadMore,\n   163→  } = usePaginatedQuery(api.themes.list, {}, { initialNumItems: 20 });\n   164→\n   165→  const searchResults = useQuery(\n   166→    api.themes.search,\n   167→    isSearching ? { name: debouncedSearch } : \"skip\"\n   168→  );\n   169→\n   170→  const themes = isSearching ? searchResults : pagedThemes;\n   171→  const isLoading = themes === undefined;\n   172→\n   173→  const inputRef = useRef<HTMLInputElement>(null);\n   174→\n   175→  const handleClearSearch = useCallback(() => {\n   176→    setSearchInput(\"\");\n   177→    inputRef.current?.focus();\n   178→  }, []);\n   179→\n   180→  return (\n   181→    <div className=\"min-h-screen bg-gray-50\">\n   182→      <style>{`\n   183→        @keyframes cardIn {\n   184→          from {\n   185→            opacity: 0;\n   186→            transform: translateY(12px);\n   187→          }\n   188→          to {\n   189→            opacity: 1;\n   190→            transform: translateY(0);\n   191→          }\n   192→        }\n   193→        @keyframes fadeIn {\n   194→          from { opacity: 0; }\n   195→          to { opacity: 1; }\n   196→        }\n   197→        @keyframes heroShift {\n   198→          0%, 100% { background-position: 0% 50%; }\n   199→          50% { background-position: 100% 50%; }\n   200→        }\n   201→      `}</style>\n   202→\n   203→      {/* Hero */}\n   204→      <header className=\"relative overflow-hidden border-b border-gray-200 bg-white\">\n   205→        {/* Animated gradient backdrop */}\n   206→        <div\n   207→          className=\"absolute inset-0 opacity-[0.035]\"\n   208→          style={{\n   209→            backgroundImage:\n   210→              \"radial-gradient(ellipse at 20% 50%, #6366f1, transparent 50%), radial-gradient(ellipse at 80% 50%, #f59e0b, transparent 50%), radial-gradient(ellipse at 50% 0%, #ec4899, transparent 50%)\",\n   211→            backgroundSize: \"200% 200%\",\n   212→            animation: \"heroShift 20s ease-in-out infinite\",\n   213→          }}\n   214→        />\n   215→\n   216→        <div className=\"relative max-w-6xl mx-auto px-6 py-16 sm:py-20\">\n   217→          <div className=\"absolute top-6 right-6 flex items-center gap-3\">\n   218→            <CreateThemeLink />\n   219→            <AuthControls />\n   220→          </div>\n   221→          <div className=\"max-w-2xl\">\n   222→            <h1 className=\"text-4xl sm:text-5xl font-bold tracking-tight text-gray-900\">\n   223→              Theme\n   224→              <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-amber-500\">\n   225→                Drops\n   226→              </span>\n   227→            </h1>\n   228→            <p className=\"mt-4 text-lg text-gray-500 leading-relaxed max-w-lg\">\n   229→              Discover, share, and remix color and typography themes for any\n   230→              application.\n   231→            </p>\n   232→          </div>\n   233→\n   234→          {/* Search */}\n   235→          <div className=\"mt-8 max-w-xl relative\">\n   236→            <div className=\"absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none\">\n   237→              <svg\n   238→                width=\"18\"\n   239→                height=\"18\"\n   240→                viewBox=\"0 0 24 24\"\n   241→                fill=\"none\"\n   242→                stroke=\"currentColor\"\n   243→                strokeWidth=\"2\"\n   244→                strokeLinecap=\"round\"\n   245→                strokeLinejoin=\"round\"\n   246→              >\n   247→                <circle cx=\"11\" cy=\"11\" r=\"8\" />\n   248→                <line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\" />\n   249→              </svg>\n   250→            </div>\n   251→            <input\n   252→              ref={inputRef}\n   253→              type=\"text\"\n   254→              value={searchInput}\n   255→              onChange={(e) => setSearchInput(e.target.value)}\n   256→              placeholder=\"Search themes by name...\"\n   257→              className=\"w-full pl-11 pr-10 py-3.5 rounded-xl border border-gray-200 bg-white text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400 transition-all shadow-sm\"\n   258→            />\n   259→            {searchInput && (\n   260→              <button\n   261→                onClick={handleClearSearch}\n   262→                className=\"absolute right-3 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors\"\n   263→              >\n   264→                <svg\n   265→                  width=\"14\"\n   266→                  height=\"14\"\n   267→                  viewBox=\"0 0 24 24\"\n   268→                  fill=\"none\"\n   269→                  stroke=\"currentColor\"\n   270→                  strokeWidth=\"2\"\n   271→                  strokeLinecap=\"round\"\n   272→                  strokeLinejoin=\"round\"\n   273→                >\n   274→                  <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\" />\n   275→                  <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\" />\n   276→                </svg>\n   277→              </button>\n   278→            )}\n   279→          </div>\n   280→        </div>\n   281→      </header>\n   282→\n   283→      {/* Gallery */}\n   284→      <main className=\"max-w-6xl mx-auto px-6 py-10\">\n   285→        {/* Status bar */}\n   286→        {isSearching && !isLoading && (\n   287→          <p className=\"text-sm text-gray-500 mb-6\" style={{ animation: \"fadeIn 0.3s ease-out\" }}>\n   288→            {themes && themes.length > 0\n   289→              ? `${themes.length} result${themes.length === 1 ? \"\" : \"s\"} for \"${debouncedSearch}\"`\n   290→              : `No themes found for \"${debouncedSearch}\"`}\n   291→          </p>\n   292→        )}\n   293→\n   294→        {/* Loading skeleton grid */}\n   295→        {isLoading && (\n   296→          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n   297→            {[...Array(6)].map((_, i) => (\n   298→              <CardSkeleton key={i} />\n   299→            ))}\n   300→          </div>\n   301→        )}\n   302→\n   303→        {/* Theme grid */}\n   304→        {!isLoading && themes && themes.length > 0 && (\n   305→          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n   306→            {themes.map((theme, i) => (\n   307→              <ThemeCard\n   308→                key={theme._id}\n   309→                theme={theme}\n   310→                index={i}\n   311→              />\n   312→            ))}\n   313→          </div>\n   314→        )}\n   315→\n   316→        {/* Empty state (no themes at all) */}\n   317→        {!isLoading && !isSearching && themes && themes.length === 0 && (\n   318→          <div className=\"text-center py-20\">\n   319→            <div className=\"text-5xl mb-4\">&#127912;</div>\n   320→            <h2 className=\"text-xl font-semibold text-gray-800\">\n   321→              No themes yet\n   322→            </h2>\n   323→            <p className=\"text-gray-500 mt-2 text-sm max-w-sm mx-auto\">\n   324→              Be the first to create and share a theme with the community.\n   325→            </p>\n   326→          </div>\n   327→        )}\n   328→\n   329→        {/* No search results */}\n   330→        {!isLoading && isSearching && themes && themes.length === 0 && (\n   331→          <div className=\"text-center py-20\" style={{ animation: \"fadeIn 0.3s ease-out\" }}>\n   332→            <div className=\"text-4xl mb-3 opacity-60\">&#128269;</div>\n   333→            <h2 className=\"text-lg font-semibold text-gray-700\">\n   334→              No matches\n   335→            </h2>\n   336→            <p className=\"text-gray-400 mt-1 text-sm\">\n   337→              Try a different search term.\n   338→            </p>\n   339→          </div>\n   340→        )}\n   341→\n   342→        {/* Load more */}\n   343→        {!isSearching && status === \"CanLoadMore\" && (\n   344→          <div className=\"flex justify-center mt-10\">\n   345→            <button\n   346→              onClick={() => loadMore(20)}\n   347→              className=\"px-8 py-3 rounded-xl border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-all shadow-sm active:scale-[0.98]\"\n   348→            >\n   349→              Load more themes\n   350→            </button>\n   351→          </div>\n   352→        )}\n   353→\n   354→        {!isSearching && status === \"LoadingMore\" && (\n   355→          <div className=\"flex justify-center mt-10\">\n   356→            <div className=\"text-sm text-gray-400 animate-pulse\">\n   357→              Loading more...\n   358→            </div>\n   359→          </div>\n   360→        )}\n   361→      </main>\n   362→    </div>\n   363→  );\n   364→}\n   365→"}]},"parent_tool_use_id":null,"session_id":"2ee1c275-4822-470d-95d7-c91f2b4b25ff","uuid":"25d1cce5-12e7-4c8d-8360-e00b923d28b6","timestamp":"2026-03-28T00:03:28.160Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/matt/code/themedrops/app/src/app/page.tsx","content":"\"use client\";\n\nimport { usePaginatedQuery, useQuery } from \"convex/react\";\nimport { api } from \"../../convex/_generated/api\";\nimport { Doc } from \"../../convex/_generated/dataModel\";\nimport { useState, useEffect, useRef, useCallback } from \"react\";\nimport Link from \"next/link\";\nimport AuthControls from \"./components/AuthControls\";\nimport CreateThemeLink from \"./components/CreateThemeLink\";\n\nconst COLOR_KEYS = [\n  \"background\",\n  \"foreground\",\n  \"primary\",\n  \"secondary\",\n  \"accent\",\n  \"muted\",\n] as const;\n\nfunction useDebounce(value: string, delay: number) {\n  const [debounced, setDebounced] = useState(value);\n  useEffect(() => {\n    const timer = setTimeout(() => setDebounced(value), delay);\n    return () => clearTimeout(timer);\n  }, [value, delay]);\n  return debounced;\n}\n\nfunction ThemeCard({\n  theme,\n  index,\n}: {\n  theme: Doc<\"themes\">;\n  index: number;\n}) {\n  const author = useQuery(api.users.get, { id: theme.authorId });\n  const colors = theme.colors;\n  const primaryColor = colors.primary ?? colors.accent ?? \"#6366f1\";\n  const bgColor = colors.background ?? \"#ffffff\";\n  const fgColor = colors.foreground ?? \"#000000\";\n\n  return (\n    <Link\n      href={`/theme/${theme.slug}`}\n      className=\"group relative flex flex-col rounded-2xl border border-gray-200/80 bg-white overflow-hidden transition-all duration-300 hover:shadow-xl hover:shadow-gray-200/50 hover:-translate-y-1 hover:border-gray-300/80\"\n      style={{\n        animationDelay: `${index * 60}ms`,\n        animation: \"cardIn 0.5s ease-out both\",\n      }}\n    >\n      {/* Color bar — the hero of each card */}\n      <div className=\"relative h-28 overflow-hidden\">\n        <div className=\"absolute inset-0 flex\">\n          {COLOR_KEYS.map((key) => {\n            const color = colors[key];\n            if (!color) return null;\n            return (\n              <div\n                key={key}\n                className=\"flex-1 transition-all duration-300 group-hover:flex-[1.2]\"\n                style={{ backgroundColor: color }}\n              />\n            );\n          })}\n        </div>\n        {/* Subtle overlay fade at bottom */}\n        <div className=\"absolute bottom-0 left-0 right-0 h-8 bg-gradient-to-t from-white to-transparent\" />\n      </div>\n\n      {/* Card content */}\n      <div className=\"flex flex-col flex-1 px-5 pb-5 pt-3\">\n        <h3 className=\"text-base font-semibold text-gray-900 tracking-tight group-hover:text-gray-700 transition-colors truncate\">\n          {theme.name}\n        </h3>\n\n        {author && (\n          <p className=\"text-xs text-gray-400 mt-0.5 truncate\">\n            {author.displayName ?? author.username}\n          </p>\n        )}\n\n        {theme.description && (\n          <p className=\"text-xs text-gray-500 mt-2 line-clamp-2 leading-relaxed\">\n            {theme.description}\n          </p>\n        )}\n\n        <div className=\"mt-auto pt-4 flex items-center justify-between\">\n          {/* Mini swatch row */}\n          <div className=\"flex gap-1\">\n            {COLOR_KEYS.map((key) => {\n              const color = colors[key];\n              if (!color) return null;\n              return (\n                <div\n                  key={key}\n                  className=\"w-4 h-4 rounded-full border border-gray-200/60 shadow-sm\"\n                  style={{ backgroundColor: color }}\n                  title={`${key}: ${color}`}\n                />\n              );\n            })}\n          </div>\n\n          {/* Star count */}\n          <div className=\"flex items-center gap-1 text-xs text-gray-400\">\n            <span className=\"text-amber-400\">&#9733;</span>\n            <span>{theme.starCount}</span>\n          </div>\n        </div>\n\n        {/* Preview strip at bottom */}\n        <div\n          className=\"mt-3 rounded-lg px-3 py-2 flex items-center justify-between\"\n          style={{ backgroundColor: bgColor }}\n        >\n          <span\n            className=\"text-[10px] font-medium truncate\"\n            style={{ color: fgColor }}\n          >\n            Aa Preview\n          </span>\n          <div\n            className=\"w-10 h-4 rounded\"\n            style={{ backgroundColor: primaryColor }}\n          />\n        </div>\n      </div>\n    </Link>\n  );\n}\n\nfunction CardSkeleton() {\n  return (\n    <div className=\"flex flex-col rounded-2xl border border-gray-100 bg-white overflow-hidden animate-pulse\">\n      <div className=\"h-28 bg-gray-100\" />\n      <div className=\"px-5 pb-5 pt-3 space-y-3\">\n        <div className=\"h-4 bg-gray-100 rounded w-2/3\" />\n        <div className=\"h-3 bg-gray-50 rounded w-1/3\" />\n        <div className=\"h-3 bg-gray-50 rounded w-full mt-4\" />\n        <div className=\"flex justify-between items-center pt-2\">\n          <div className=\"flex gap-1\">\n            {[...Array(6)].map((_, i) => (\n              <div key={i} className=\"w-4 h-4 rounded-full bg-gray-100\" />\n            ))}\n          </div>\n          <div className=\"h-3 w-6 bg-gray-100 rounded\" />\n        </div>\n      </div>\n    </div>\n  );\n}\n\nexport default function Home() {\n  const [searchInput, setSearchInput] = useState(\"\");\n  const debouncedSearch = useDebounce(searchInput, 300);\n  const isSearching = debouncedSearch.length > 0;\n\n  const {\n    results: pagedThemes,\n    status,\n    loadMore,\n  } = usePaginatedQuery(api.themes.list, {}, { initialNumItems: 20 });\n\n  const searchResults = useQuery(\n    api.themes.search,\n    isSearching ? { name: debouncedSearch } : \"skip\"\n  );\n\n  const themes = isSearching ? searchResults : pagedThemes;\n  const isLoading = themes === undefined;\n\n  const inputRef = useRef<HTMLInputElement>(null);\n\n  const handleClearSearch = useCallback(() => {\n    setSearchInput(\"\");\n    inputRef.current?.focus();\n  }, []);\n\n  return (\n    <div className=\"min-h-screen bg-gray-50\">\n      <style>{`\n        @keyframes cardIn {\n          from {\n            opacity: 0;\n            transform: translateY(12px);\n          }\n          to {\n            opacity: 1;\n            transform: translateY(0);\n          }\n        }\n        @keyframes fadeIn {\n          from { opacity: 0; }\n          to { opacity: 1; }\n        }\n        @keyframes heroShift {\n          0%, 100% { background-position: 0% 50%; }\n          50% { background-position: 100% 50%; }\n        }\n      `}</style>\n\n      {/* Hero */}\n      <header className=\"relative overflow-hidden border-b border-gray-200 bg-white\">\n        {/* Animated gradient backdrop */}\n        <div\n          className=\"absolute inset-0 opacity-[0.035]\"\n          style={{\n            backgroundImage:\n              \"radial-gradient(ellipse at 20% 50%, #6366f1, transparent 50%), radial-gradient(ellipse at 80% 50%, #f59e0b, transparent 50%), radial-gradient(ellipse at 50% 0%, #ec4899, transparent 50%)\",\n            backgroundSize: \"200% 200%\",\n            animation: \"heroShift 20s ease-in-out infinite\",\n          }}\n        />\n\n        <div className=\"relative max-w-6xl mx-auto px-6 py-16 sm:py-20\">\n          <div className=\"absolute top-6 right-6 flex items-center gap-3\">\n            <CreateThemeLink />\n            <AuthControls />\n          </div>\n          <div className=\"max-w-2xl\">\n            <h1 className=\"text-4xl sm:text-5xl font-bold tracking-tight text-gray-900\">\n              Theme\n              <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 via-purple-500 to-amber-500\">\n                Drops\n              </span>\n            </h1>\n            <p className=\"mt-4 text-lg text-gray-500 leading-relaxed max-w-lg\">\n              Discover, share, and remix color and typography themes for any\n              application.\n            </p>\n          </div>\n\n          {/* Search */}\n          <div className=\"mt-8 max-w-xl relative\">\n            <div className=\"absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none\">\n              <svg\n                width=\"18\"\n                height=\"18\"\n                viewBox=\"0 0 24 24\"\n                fill=\"none\"\n                stroke=\"currentColor\"\n                strokeWidth=\"2\"\n                strokeLinecap=\"round\"\n                strokeLinejoin=\"round\"\n              >\n                <circle cx=\"11\" cy=\"11\" r=\"8\" />\n                <line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\" />\n              </svg>\n            </div>\n            <input\n              ref={inputRef}\n              type=\"text\"\n              value={searchInput}\n              onChange={(e) => setSearchInput(e.target.value)}\n              placeholder=\"Search themes by name...\"\n              className=\"w-full pl-11 pr-10 py-3.5 rounded-xl border border-gray-200 bg-white text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-400 transition-all shadow-sm\"\n            />\n            {searchInput && (\n              <button\n                onClick={handleClearSearch}\n                className=\"absolute right-3 top-1/2 -translate-y-1/2 w-6 h-6 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors\"\n              >\n                <svg\n                  width=\"14\"\n                  height=\"14\"\n                  viewBox=\"0 0 24 24\"\n                  fill=\"none\"\n                  stroke=\"currentColor\"\n                  strokeWidth=\"2\"\n                  strokeLinecap=\"round\"\n                  strokeLinejoin=\"round\"\n                >\n                  <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\" />\n                  <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\" />\n                </svg>\n              </button>\n            )}\n          </div>\n        </div>\n      </header>\n\n      {/* Gallery */}\n      <main className=\"max-w-6xl mx-auto px-6 py-10\">\n        {/* Status bar */}\n        {isSearching && !isLoading && (\n          <p className=\"text-sm text-gray-500 mb-6\" style={{ animation: \"fadeIn 0.3s ease-out\" }}>\n            {themes && themes.length > 0\n              ? `${themes.length} result${themes.length === 1 ? \"\" : \"s\"} for \"${debouncedSearch}\"`\n              : `No themes found for \"${debouncedSearch}\"`}\n          </p>\n        )}\n\n        {/* Loading skeleton grid */}\n        {isLoading && (\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n            {[...Array(6)].map((_, i) => (\n              <CardSkeleton key={i} />\n            ))}\n          </div>\n        )}\n\n        {/* Theme grid */}\n        {!isLoading && themes && themes.length > 0 && (\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\">\n            {themes.map((theme, i) => (\n              <ThemeCard\n                key={theme._id}\n                theme={theme}\n                index={i}\n              />\n            ))}\n          </div>\n        )}\n\n        {/* Empty state (no themes at all) */}\n        {!isLoading && !isSearching && themes && themes.length === 0 && (\n          <div className=\"text-center py-20\">\n            <div className=\"text-5xl mb-4\">&#127912;</div>\n            <h2 className=\"text-xl font-semibold text-gray-800\">\n              No themes yet\n            </h2>\n            <p className=\"text-gray-500 mt-2 text-sm max-w-sm mx-auto\">\n              Be the first to create and share a theme with the community.\n            </p>\n          </div>\n        )}\n\n        {/* No search results */}\n        {!isLoading && isSearching && themes && themes.length === 0 && (\n          <div className=\"text-center py-20\" style={{ animation: \"fadeIn 0.3s ease-out\" }}>\n            <div className=\"text-4xl mb-3 opacity-60\">&#128269;</div>\n            <h2 className=\"text-lg font-semibold text-gray-700\">\n              No matches\n            </h2>\n            <p className=\"text-gray-400 mt-1 text-sm\">\n              Try a different search term.\n            </p>\n          </div>\n        )}\n\n        {/* Load more */}\n        {!isSearching && status === \"CanLoadMore\" && (\n          <div className=\"flex justify-center mt-10\">\n            <button\n              onClick={() => loadMore(20)}\n              className=\"px-8 py-3 rounded-xl border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 hover:border-gray-300 transition-all shadow-sm active:scale-[0.98]\"\n            >\n              Load more themes\n            </button>\n          </div>\n        )}\n\n        {!isSearching && status === \"LoadingMore\" && (\n          <div className=\"flex justify-center mt-10\">\n            <div className=\"text-sm text-gray-400 animate-pulse\">\n              Loading more...\n            </div>\n          </div>\n        )}\n      </main>\n    </div>\n  );\n}\n","numLines":365,"startLine":1,"totalLines":365}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QWKeYRBxg8QDwUDbAixrkA","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { useParams, useRouter } from \"next/navigation\";\n     4→import { useQuery, useMutation } from \"convex/react\";\n     5→import { api } from \"../../../../convex/_generated/api\";\n     6→import { useState } from \"react\";\n     7→import AuthControls from \"../../components/AuthControls\";\n     8→import CreateThemeLink from \"../../components/CreateThemeLink\";\n     9→\n    10→const COLOR_LABELS: { key: string; label: string }[] = [\n    11→  { key: \"background\", label: \"Background\" },\n    12→  { key: \"foreground\", label: \"Foreground\" },\n    13→  { key: \"primary\", label: \"Primary\" },\n    14→  { key: \"secondary\", label: \"Secondary\" },\n    15→  { key: \"accent\", label: \"Accent\" },\n    16→  { key: \"muted\", label: \"Muted\" },\n    17→];\n    18→\n    19→const FONT_KEYS = [\"sans\", \"serif\", \"mono\"] as const;\n    20→\n    21→function ColorSwatch({ color, label }: { color: string; label: string }) {\n    22→  return (\n    23→    <div className=\"flex flex-col items-center gap-2\">\n    24→      <div\n    25→        className=\"w-16 h-16 rounded-xl border border-gray-200 shadow-sm\"\n    26→        style={{ backgroundColor: color }}\n    27→      />\n    28→      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n    29→      <span className=\"text-xs font-mono text-gray-400\">{color}</span>\n    30→    </div>\n    31→  );\n    32→}\n    33→\n    34→function EditableColorSwatch({\n    35→  color,\n    36→  label,\n    37→  onChange,\n    38→}: {\n    39→  color: string;\n    40→  label: string;\n    41→  onChange: (value: string) => void;\n    42→}) {\n    43→  return (\n    44→    <div className=\"flex flex-col items-center gap-2\">\n    45→      <label className=\"relative w-16 h-16 rounded-xl border border-gray-200 shadow-sm cursor-pointer overflow-hidden\">\n    46→        <div\n    47→          className=\"absolute inset-0\"\n    48→          style={{ backgroundColor: color }}\n    49→        />\n    50→        <input\n    51→          type=\"color\"\n    52→          value={color}\n    53→          onChange={(e) => onChange(e.target.value)}\n    54→          className=\"absolute inset-0 opacity-0 cursor-pointer\"\n    55→        />\n    56→      </label>\n    57→      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n    58→      <input\n    59→        type=\"text\"\n    60→        value={color}\n    61→        onChange={(e) => onChange(e.target.value)}\n    62→        className=\"text-xs font-mono text-gray-600 w-20 text-center border border-gray-200 rounded px-1 py-0.5 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n    63→      />\n    64→    </div>\n    65→  );\n    66→}\n    67→\n    68→function LivePreview({\n    69→  colors,\n    70→}: {\n    71→  colors: Record<string, string | undefined>;\n    72→}) {\n    73→  return (\n    74→    <div\n    75→      className=\"rounded-xl border p-6 space-y-4\"\n    76→      style={{\n    77→        backgroundColor: colors.background ?? \"#ffffff\",\n    78→        color: colors.foreground ?? \"#000000\",\n    79→        borderColor: colors.muted ?? \"#e5e7eb\",\n    80→      }}\n    81→    >\n    82→      <h3 className=\"text-lg font-semibold\">Live Preview</h3>\n    83→      <p style={{ color: colors.muted ?? \"#6b7280\" }} className=\"text-sm\">\n    84→        This is how the theme looks when applied to a card.\n    85→      </p>\n    86→      <div className=\"flex gap-3\">\n    87→        <button\n    88→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    89→          style={{ backgroundColor: colors.primary ?? \"#3b82f6\" }}\n    90→        >\n    91→          Primary\n    92→        </button>\n    93→        <button\n    94→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    95→          style={{ backgroundColor: colors.secondary ?? \"#6366f1\" }}\n    96→        >\n    97→          Secondary\n    98→        </button>\n    99→        <button\n   100→          className=\"px-4 py-2 rounded-lg text-sm font-medium border\"\n   101→          style={{\n   102→            backgroundColor: colors.accent ?? \"#f59e0b\",\n   103→            borderColor: colors.muted ?? \"#e5e7eb\",\n   104→          }}\n   105→        >\n   106→          Accent\n   107→        </button>\n   108→      </div>\n   109→    </div>\n   110→  );\n   111→}\n   112→\n   113→export default function ThemeDetailPage() {\n   114→  const params = useParams<{ slug: string }>();\n   115→  const router = useRouter();\n   116→  const slug = params.slug;\n   117→\n   118→  const theme = useQuery(api.themes.getBySlug, { slug });\n   119→  const author = useQuery(\n   120→    api.users.get,\n   121→    theme ? { id: theme.authorId } : \"skip\"\n   122→  );\n   123→  const currentUser = useQuery(api.users.getCurrentUser);\n   124→\n   125→  // Stars\n   126→  const isStarred = useQuery(\n   127→    api.stars.isStarred,\n   128→    theme ? { themeId: theme._id } : \"skip\"\n   129→  );\n   130→  const toggleStar = useMutation(api.stars.toggle);\n   131→\n   132→  // Comments\n   133→  const comments = useQuery(\n   134→    api.comments.listByTheme,\n   135→    theme ? { themeId: theme._id } : \"skip\"\n   136→  );\n   137→  const createComment = useMutation(api.comments.create);\n   138→  const [commentBody, setCommentBody] = useState(\"\");\n   139→  const [submittingComment, setSubmittingComment] = useState(false);\n   140→\n   141→  // Fork\n   142→  const forkTheme = useMutation(api.themes.fork);\n   143→  const [forking, setForking] = useState(false);\n   144→\n   145→  // Forked-from theme info (for link)\n   146→  const forkedFrom = useQuery(\n   147→    api.themes.getBasicInfo,\n   148→    theme?.forkedFromId ? { id: theme.forkedFromId } : \"skip\"\n   149→  );\n   150→\n   151→  // Edit/Delete mutations\n   152→  const updateTheme = useMutation(api.themes.update);\n   153→  const removeTheme = useMutation(api.themes.remove);\n   154→\n   155→  // Edit mode state\n   156→  const [editing, setEditing] = useState(false);\n   157→  const [editName, setEditName] = useState(\"\");\n   158→  const [editDescription, setEditDescription] = useState(\"\");\n   159→  const [editIsPublic, setEditIsPublic] = useState(true);\n   160→  const [editColors, setEditColors] = useState<Record<string, string>>({});\n   161→  const [editFonts, setEditFonts] = useState<Record<string, string>>({});\n   162→  const [saving, setSaving] = useState(false);\n   163→  const [saveError, setSaveError] = useState<string | null>(null);\n   164→\n   165→  // Delete state\n   166→  const [confirmingDelete, setConfirmingDelete] = useState(false);\n   167→  const [deleting, setDeleting] = useState(false);\n   168→  const [deleteError, setDeleteError] = useState<string | null>(null);\n   169→\n   170→  // Owner detection\n   171→  const isOwner = !!(currentUser && theme && currentUser._id === theme.authorId);\n   172→\n   173→  function enterEditMode() {\n   174→    if (!theme) return;\n   175→    setEditName(theme.name);\n   176→    setEditDescription(theme.description ?? \"\");\n   177→    setEditIsPublic(theme.isPublic);\n   178→    const c: Record<string, string> = {};\n   179→    const themeColors = theme.colors as Record<string, string | undefined>;\n   180→    for (const { key } of COLOR_LABELS) {\n   181→      if (themeColors[key]) c[key] = themeColors[key]!;\n   182→    }\n   183→    setEditColors(c);\n   184→    const f: Record<string, string> = {};\n   185→    if (theme.fonts) {\n   186→      for (const k of FONT_KEYS) {\n   187→        if (theme.fonts[k]) f[k] = theme.fonts[k]!;\n   188→      }\n   189→    }\n   190→    setEditFonts(f);\n   191→    setSaveError(null);\n   192→    setEditing(true);\n   193→  }\n   194→\n   195→  function cancelEdit() {\n   196→    setEditing(false);\n   197→    setSaveError(null);\n   198→  }\n   199→\n   200→  async function handleSave() {\n   201→    if (!theme) return;\n   202→    setSaving(true);\n   203→    setSaveError(null);\n   204→    try {\n   205→      const updates: Record<string, unknown> = { id: theme._id };\n   206→      if (editName !== theme.name) updates.name = editName;\n   207→      if (editDescription !== (theme.description ?? \"\"))\n   208→        updates.description = editDescription;\n   209→      if (editIsPublic !== theme.isPublic) updates.isPublic = editIsPublic;\n   210→\n   211→      // Colors: always send all edited colors\n   212→      const origColors = theme.colors as Record<string, string | undefined>;\n   213→      const colorsChanged = COLOR_LABELS.some(\n   214→        ({ key }) => (editColors[key] ?? \"\") !== (origColors[key] ?? \"\")\n   215→      );\n   216→      if (colorsChanged) updates.colors = editColors;\n   217→\n   218→      // Fonts: send if changed\n   219→      const origFonts = (theme.fonts ?? {}) as Record<string, string | undefined>;\n   220→      const fontsChanged = FONT_KEYS.some(\n   221→        (k) => (editFonts[k] ?? \"\") !== (origFonts[k] ?? \"\")\n   222→      );\n   223→      if (fontsChanged) {\n   224→        const fontPayload: Record<string, string> = {};\n   225→        for (const k of FONT_KEYS) {\n   226→          if (editFonts[k]?.trim()) fontPayload[k] = editFonts[k];\n   227→        }\n   228→        updates.fonts = fontPayload;\n   229→      }\n   230→\n   231→      const result = await updateTheme(updates as Parameters<typeof updateTheme>[0]);\n   232→      setEditing(false);\n   233→\n   234→      // If name changed, the slug changed server-side — redirect using the returned slug\n   235→      if (editName !== theme.name && result?.slug) {\n   236→        router.push(`/theme/${result.slug}`);\n   237→      }\n   238→    } catch (err) {\n   239→      setSaveError(err instanceof Error ? err.message : \"Failed to save\");\n   240→    } finally {\n   241→      setSaving(false);\n   242→    }\n   243→  }\n   244→\n   245→  async function handleDelete() {\n   246→    if (!theme) return;\n   247→    setDeleting(true);\n   248→    setDeleteError(null);\n   249→    try {\n   250→      await removeTheme({ id: theme._id });\n   251→      router.push(\"/\");\n   252→    } catch (err) {\n   253→      setDeleteError(err instanceof Error ? err.message : \"Failed to delete\");\n   254→      setDeleting(false);\n   255→    }\n   256→  }\n   257→\n   258→  // Loading state\n   259→  if (theme === undefined) {\n   260→    return (\n   261→      <div className=\"min-h-screen flex items-center justify-center\">\n   262→        <div className=\"animate-pulse text-gray-400 text-lg\">\n   263→          Loading theme...\n   264→        </div>\n   265→      </div>\n   266→    );\n   267→  }\n   268→\n   269→  // Not found\n   270→  if (theme === null) {\n   271→    return (\n   272→      <div className=\"min-h-screen flex flex-col items-center justify-center gap-4\">\n   273→        <h1 className=\"text-2xl font-bold text-gray-800\">Theme not found</h1>\n   274→        <p className=\"text-gray-500\">\n   275→          This theme doesn&apos;t exist or is private.\n   276→        </p>\n   277→        <a href=\"/\" className=\"text-blue-600 hover:underline text-sm\">\n   278→          Back to gallery\n   279→        </a>\n   280→      </div>\n   281→    );\n   282→  }\n   283→\n   284→  const colors = editing\n   285→    ? (editColors as Record<string, string | undefined>)\n   286→    : (theme.colors as Record<string, string | undefined>);\n   287→\n   288→  async function handleToggleStar() {\n   289→    if (!theme || !currentUser) return;\n   290→    await toggleStar({ themeId: theme._id });\n   291→  }\n   292→\n   293→  async function handleSubmitComment(e: React.FormEvent) {\n   294→    e.preventDefault();\n   295→    if (!theme || !commentBody.trim()) return;\n   296→    setSubmittingComment(true);\n   297→    try {\n   298→      await createComment({ themeId: theme._id, body: commentBody.trim() });\n   299→      setCommentBody(\"\");\n   300→    } finally {\n   301→      setSubmittingComment(false);\n   302→    }\n   303→  }\n   304→\n   305→  async function handleFork() {\n   306→    if (!theme) return;\n   307→    setForking(true);\n   308→    try {\n   309→      const result = await forkTheme({ id: theme._id });\n   310→      if (result) {\n   311→        router.push(`/theme/${result.slug}`);\n   312→      }\n   313→    } catch {\n   314→      // Fork may fail if not authenticated\n   315→    } finally {\n   316→      setForking(false);\n   317→    }\n   318→  }\n   319→\n   320→  return (\n   321→    <div className=\"min-h-screen bg-gray-50\">\n   322→      {/* Header */}\n   323→      <header className=\"bg-white border-b border-gray-200\">\n   324→        <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n   325→          <a\n   326→            href=\"/\"\n   327→            className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n   328→          >\n   329→            ThemeDrops\n   330→          </a>\n   331→          <div className=\"flex items-center gap-3\">\n   332→            <CreateThemeLink />\n   333→            <AuthControls />\n   334→          </div>\n   335→        </div>\n   336→      </header>\n   337→\n   338→      <main className=\"max-w-4xl mx-auto px-6 py-10 space-y-10\">\n   339→        {/* Theme header */}\n   340→        <div className=\"space-y-3\">\n   341→          <div className=\"flex items-start justify-between gap-4\">\n   342→            <div className=\"space-y-1 flex-1\">\n   343→              {editing ? (\n   344→                <input\n   345→                  type=\"text\"\n   346→                  value={editName}\n   347→                  onChange={(e) => setEditName(e.target.value)}\n   348→                  className=\"text-3xl font-bold text-gray-900 w-full border border-gray-300 rounded-lg px-3 py-1 focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   349→                />\n   350→              ) : (\n   351→                <h1 className=\"text-3xl font-bold text-gray-900\">\n   352→                  {theme.name}\n   353→                </h1>\n   354→              )}\n   355→              {author && (\n   356→                <p className=\"text-sm text-gray-500\">\n   357→                  by{\" \"}\n   358→                  <span className=\"font-medium text-gray-700\">\n   359→                    {author.displayName ?? author.username}\n   360→                  </span>\n   361→                </p>\n   362→              )}\n   363→            </div>\n   364→\n   365→            <div className=\"flex items-center gap-2\">\n   366→              {/* Owner controls */}\n   367→              {isOwner && !editing && (\n   368→                <>\n   369→                  <button\n   370→                    onClick={enterEditMode}\n   371→                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors\"\n   372→                  >\n   373→                    Edit\n   374→                  </button>\n   375→                  {!confirmingDelete ? (\n   376→                    <button\n   377→                      onClick={() => setConfirmingDelete(true)}\n   378→                      className=\"px-4 py-2 rounded-lg border border-red-200 bg-white text-sm font-medium text-red-600 hover:bg-red-50 transition-colors\"\n   379→                    >\n   380→                      Delete\n   381→                    </button>\n   382→                  ) : (\n   383→                    <div className=\"flex items-center gap-2 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   384→                      <span className=\"text-sm text-red-700\">Delete this theme?</span>\n   385→                      <button\n   386→                        onClick={handleDelete}\n   387→                        disabled={deleting}\n   388→                        className=\"px-3 py-1 rounded bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition-colors disabled:opacity-50\"\n   389→                      >\n   390→                        {deleting ? \"Deleting...\" : \"Confirm\"}\n   391→                      </button>\n   392→                      <button\n   393→                        onClick={() => {\n   394→                          setConfirmingDelete(false);\n   395→                          setDeleteError(null);\n   396→                        }}\n   397→                        disabled={deleting}\n   398→                        className=\"px-3 py-1 rounded border border-red-200 text-sm text-red-600 hover:bg-red-100 transition-colors disabled:opacity-50\"\n   399→                      >\n   400→                        Cancel\n   401→                      </button>\n   402→                    </div>\n   403→                  )}\n   404→                </>\n   405→              )}\n   406→\n   407→              {/* Edit mode controls */}\n   408→              {editing && (\n   409→                <>\n   410→                  <button\n   411→                    onClick={handleSave}\n   412→                    disabled={saving || !editName.trim()}\n   413→                    className=\"px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n   414→                  >\n   415→                    {saving ? \"Saving...\" : \"Save\"}\n   416→                  </button>\n   417→                  <button\n   418→                    onClick={cancelEdit}\n   419→                    disabled={saving}\n   420→                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50\"\n   421→                  >\n   422→                    Cancel\n   423→                  </button>\n   424→                </>\n   425→              )}\n   426→\n   427→              {/* Star button */}\n   428→              {!editing && (\n   429→                <button\n   430→                  onClick={handleToggleStar}\n   431→                  disabled={!currentUser}\n   432→                  className={`flex items-center gap-1.5 px-4 py-2 rounded-lg border text-sm font-medium transition-colors ${\n   433→                    isStarred\n   434→                      ? \"bg-yellow-50 border-yellow-300 text-yellow-700\"\n   435→                      : \"bg-white border-gray-200 text-gray-600 hover:bg-gray-50\"\n   436→                  } ${!currentUser ? \"opacity-50 cursor-not-allowed\" : \"cursor-pointer\"}`}\n   437→                  title={!currentUser ? \"Sign in to star themes\" : undefined}\n   438→                >\n   439→                  <span className=\"text-lg\">\n   440→                    {isStarred ? \"\\u2605\" : \"\\u2606\"}\n   441→                  </span>\n   442→                  <span>{theme.starCount}</span>\n   443→                </button>\n   444→              )}\n   445→            </div>\n   446→          </div>\n   447→\n   448→          {/* Delete error */}\n   449→          {deleteError && (\n   450→            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   451→              {deleteError}\n   452→            </p>\n   453→          )}\n   454→\n   455→          {/* Save error */}\n   456→          {saveError && (\n   457→            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   458→              {saveError}\n   459→            </p>\n   460→          )}\n   461→\n   462→          {/* Description */}\n   463→          {editing ? (\n   464→            <textarea\n   465→              value={editDescription}\n   466→              onChange={(e) => setEditDescription(e.target.value)}\n   467→              placeholder=\"Theme description...\"\n   468→              rows={3}\n   469→              className=\"w-full text-gray-600 leading-relaxed border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   470→            />\n   471→          ) : (\n   472→            theme.description && (\n   473→              <p className=\"text-gray-600 leading-relaxed\">\n   474→                {theme.description}\n   475→              </p>\n   476→            )\n   477→          )}\n   478→\n   479→          {/* Visibility toggle */}\n   480→          {editing && (\n   481→            <div className=\"flex items-center gap-3\">\n   482→              <span className=\"text-sm text-gray-600\">Visibility:</span>\n   483→              <button\n   484→                onClick={() => setEditIsPublic(!editIsPublic)}\n   485→                className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${\n   486→                  editIsPublic ? \"bg-blue-600\" : \"bg-gray-300\"\n   487→                }`}\n   488→              >\n   489→                <span\n   490→                  className={`inline-block h-4 w-4 rounded-full bg-white transition-transform ${\n   491→                    editIsPublic ? \"translate-x-6\" : \"translate-x-1\"\n   492→                  }`}\n   493→                />\n   494→              </button>\n   495→              <span className=\"text-sm text-gray-500\">\n   496→                {editIsPublic ? \"Public\" : \"Private\"}\n   497→              </span>\n   498→            </div>\n   499→          )}\n   500→\n   501→          {theme.forkedFromId && forkedFrom && (\n   502→            <p className=\"text-sm text-gray-400 italic\">\n   503→              Forked from{\" \"}\n   504→              <a\n   505→                href={`/theme/${forkedFrom.slug}`}\n   506→                className=\"text-blue-500 hover:underline\"\n   507→              >\n   508→                {forkedFrom.name}\n   509→              </a>\n   510→            </p>\n   511→          )}\n   512→\n   513→          {!editing && (\n   514→            <p className=\"text-xs text-gray-400 font-mono bg-gray-100 inline-block px-2 py-1 rounded\">\n   515→              API: /api/theme/{theme.slug}\n   516→            </p>\n   517→          )}\n   518→        </div>\n   519→\n   520→        {/* Color palette */}\n   521→        <section className=\"space-y-4\">\n   522→          <h2 className=\"text-lg font-semibold text-gray-800\">Color Palette</h2>\n   523→          <div className=\"flex flex-wrap gap-6\">\n   524→            {editing\n   525→              ? COLOR_LABELS.map(({ key, label }) => (\n   526→                  <EditableColorSwatch\n   527→                    key={key}\n   528→                    color={editColors[key] ?? \"#000000\"}\n   529→                    label={label}\n   530→                    onChange={(value) =>\n   531→                      setEditColors((prev) => ({ ...prev, [key]: value }))\n   532→                    }\n   533→                  />\n   534→                ))\n   535→              : COLOR_LABELS.map(({ key, label }) => {\n   536→                  const color = colors[key];\n   537→                  if (!color) return null;\n   538→                  return <ColorSwatch key={key} color={color} label={label} />;\n   539→                })}\n   540→          </div>\n   541→        </section>\n   542→\n   543→        {/* Live preview */}\n   544→        <section className=\"space-y-4\">\n   545→          <h2 className=\"text-lg font-semibold text-gray-800\">Preview</h2>\n   546→          <LivePreview colors={colors} />\n   547→        </section>\n   548→\n   549→        {/* Fonts */}\n   550→        {editing ? (\n   551→          <section className=\"space-y-4\">\n   552→            <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   553→            <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   554→              {FONT_KEYS.map((k) => (\n   555→                <div\n   556→                  key={k}\n   557→                  className=\"bg-white rounded-lg border border-gray-200 p-4\"\n   558→                >\n   559→                  <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   560→                    {k}\n   561→                  </p>\n   562→                  <input\n   563→                    type=\"text\"\n   564→                    value={editFonts[k] ?? \"\"}\n   565→                    onChange={(e) =>\n   566→                      setEditFonts((prev) => ({ ...prev, [k]: e.target.value }))\n   567→                    }\n   568→                    placeholder={`${k} font name`}\n   569→                    className=\"w-full text-sm border border-gray-200 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n   570→                  />\n   571→                  {editFonts[k] && (\n   572→                    <p\n   573→                      className=\"text-sm text-gray-500 mt-2\"\n   574→                      style={{ fontFamily: editFonts[k] }}\n   575→                    >\n   576→                      The quick brown fox jumps over the lazy dog.\n   577→                    </p>\n   578→                  )}\n   579→                </div>\n   580→              ))}\n   581→            </div>\n   582→          </section>\n   583→        ) : (\n   584→          theme.fonts &&\n   585→          (theme.fonts.sans || theme.fonts.serif || theme.fonts.mono) && (\n   586→            <section className=\"space-y-4\">\n   587→              <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   588→              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   589→                {theme.fonts.sans && (\n   590→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   591→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   592→                      Sans\n   593→                    </p>\n   594→                    <p\n   595→                      className=\"text-lg\"\n   596→                      style={{ fontFamily: theme.fonts.sans }}\n   597→                    >\n   598→                      {theme.fonts.sans}\n   599→                    </p>\n   600→                    <p\n   601→                      className=\"text-sm text-gray-500 mt-1\"\n   602→                      style={{ fontFamily: theme.fonts.sans }}\n   603→                    >\n   604→                      The quick brown fox jumps over the lazy dog.\n   605→                    </p>\n   606→                  </div>\n   607→                )}\n   608→                {theme.fonts.serif && (\n   609→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   610→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   611→                      Serif\n   612→                    </p>\n   613→                    <p\n   614→                      className=\"text-lg\"\n   615→                      style={{ fontFamily: theme.fonts.serif }}\n   616→                    >\n   617→                      {theme.fonts.serif}\n   618→                    </p>\n   619→                    <p\n   620→                      className=\"text-sm text-gray-500 mt-1\"\n   621→                      style={{ fontFamily: theme.fonts.serif }}\n   622→                    >\n   623→                      The quick brown fox jumps over the lazy dog.\n   624→                    </p>\n   625→                  </div>\n   626→                )}\n   627→                {theme.fonts.mono && (\n   628→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   629→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   630→                      Mono\n   631→                    </p>\n   632→                    <p\n   633→                      className=\"text-lg font-mono\"\n   634→                      style={{ fontFamily: theme.fonts.mono }}\n   635→                    >\n   636→                      {theme.fonts.mono}\n   637→                    </p>\n   638→                    <p\n   639→                      className=\"text-sm text-gray-500 mt-1\"\n   640→                      style={{ fontFamily: theme.fonts.mono }}\n   641→                    >\n   642→                      The quick brown fox jumps over the lazy dog.\n   643→                    </p>\n   644→                  </div>\n   645→                )}\n   646→              </div>\n   647→            </section>\n   648→          )\n   649→        )}\n   650→\n   651→        {/* Fork button */}\n   652→        {currentUser && !editing && (\n   653→          <div>\n   654→            <button\n   655→              onClick={handleFork}\n   656→              disabled={forking}\n   657→              className=\"px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors disabled:opacity-50\"\n   658→            >\n   659→              {forking ? \"Forking...\" : \"Fork this theme\"}\n   660→            </button>\n   661→          </div>\n   662→        )}\n   663→\n   664→        {/* Comments */}\n   665→        {!editing && (\n   666→          <section className=\"space-y-6\">\n   667→            <h2 className=\"text-lg font-semibold text-gray-800\">\n   668→              Comments{\" \"}\n   669→              {comments && comments.length > 0 && (\n   670→                <span className=\"text-gray-400 font-normal\">\n   671→                  ({comments.length})\n   672→                </span>\n   673→              )}\n   674→            </h2>\n   675→\n   676→            {comments === undefined && (\n   677→              <p className=\"text-gray-400 text-sm animate-pulse\">\n   678→                Loading comments...\n   679→              </p>\n   680→            )}\n   681→\n   682→            {comments && comments.length === 0 && (\n   683→              <p className=\"text-gray-400 text-sm\">No comments yet.</p>\n   684→            )}\n   685→\n   686→            {comments && comments.length > 0 && (\n   687→              <div className=\"space-y-4\">\n   688→                {comments.map((comment) => (\n   689→                  <div\n   690→                    key={comment._id}\n   691→                    className=\"bg-white rounded-lg border border-gray-200 p-4\"\n   692→                  >\n   693→                    <div className=\"flex items-center gap-2 mb-2\">\n   694→                      {comment.author?.avatarUrl && (\n   695→                        <img\n   696→                          src={comment.author.avatarUrl}\n   697→                          alt=\"\"\n   698→                          className=\"w-6 h-6 rounded-full\"\n   699→                        />\n   700→                      )}\n   701→                      <span className=\"text-sm font-medium text-gray-700\">\n   702→                        {comment.author?.displayName ??\n   703→                          comment.author?.username ??\n   704→                          \"Unknown\"}\n   705→                      </span>\n   706→                    </div>\n   707→                    <p className=\"text-sm text-gray-600\">{comment.body}</p>\n   708→                  </div>\n   709→                ))}\n   710→              </div>\n   711→            )}\n   712→\n   713→            {/* Add comment form */}\n   714→            {currentUser && (\n   715→              <form onSubmit={handleSubmitComment} className=\"flex gap-3\">\n   716→                <input\n   717→                  type=\"text\"\n   718→                  value={commentBody}\n   719→                  onChange={(e) => setCommentBody(e.target.value)}\n   720→                  placeholder=\"Add a comment...\"\n   721→                  className=\"flex-1 px-4 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n   722→                />\n   723→                <button\n   724→                  type=\"submit\"\n   725→                  disabled={!commentBody.trim() || submittingComment}\n   726→                  className=\"px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n   727→                >\n   728→                  {submittingComment ? \"Posting...\" : \"Post\"}\n   729→                </button>\n   730→              </form>\n   731→            )}\n   732→          </section>\n   733→        )}\n   734→      </main>\n   735→    </div>\n   736→  );\n   737→}\n   738→"}]},"parent_tool_use_id":null,"session_id":"2ee1c275-4822-470d-95d7-c91f2b4b25ff","uuid":"8330ade5-6275-40f5-856d-bf6bc1e47dda","timestamp":"2026-03-28T00:03:28.558Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/matt/code/themedrops/app/src/app/theme/[slug]/page.tsx","content":"\"use client\";\n\nimport { useParams, useRouter } from \"next/navigation\";\nimport { useQuery, useMutation } from \"convex/react\";\nimport { api } from \"../../../../convex/_generated/api\";\nimport { useState } from \"react\";\nimport AuthControls from \"../../components/AuthControls\";\nimport CreateThemeLink from \"../../components/CreateThemeLink\";\n\nconst COLOR_LABELS: { key: string; label: string }[] = [\n  { key: \"background\", label: \"Background\" },\n  { key: \"foreground\", label: \"Foreground\" },\n  { key: \"primary\", label: \"Primary\" },\n  { key: \"secondary\", label: \"Secondary\" },\n  { key: \"accent\", label: \"Accent\" },\n  { key: \"muted\", label: \"Muted\" },\n];\n\nconst FONT_KEYS = [\"sans\", \"serif\", \"mono\"] as const;\n\nfunction ColorSwatch({ color, label }: { color: string; label: string }) {\n  return (\n    <div className=\"flex flex-col items-center gap-2\">\n      <div\n        className=\"w-16 h-16 rounded-xl border border-gray-200 shadow-sm\"\n        style={{ backgroundColor: color }}\n      />\n      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n      <span className=\"text-xs font-mono text-gray-400\">{color}</span>\n    </div>\n  );\n}\n\nfunction EditableColorSwatch({\n  color,\n  label,\n  onChange,\n}: {\n  color: string;\n  label: string;\n  onChange: (value: string) => void;\n}) {\n  return (\n    <div className=\"flex flex-col items-center gap-2\">\n      <label className=\"relative w-16 h-16 rounded-xl border border-gray-200 shadow-sm cursor-pointer overflow-hidden\">\n        <div\n          className=\"absolute inset-0\"\n          style={{ backgroundColor: color }}\n        />\n        <input\n          type=\"color\"\n          value={color}\n          onChange={(e) => onChange(e.target.value)}\n          className=\"absolute inset-0 opacity-0 cursor-pointer\"\n        />\n      </label>\n      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n      <input\n        type=\"text\"\n        value={color}\n        onChange={(e) => onChange(e.target.value)}\n        className=\"text-xs font-mono text-gray-600 w-20 text-center border border-gray-200 rounded px-1 py-0.5 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n      />\n    </div>\n  );\n}\n\nfunction LivePreview({\n  colors,\n}: {\n  colors: Record<string, string | undefined>;\n}) {\n  return (\n    <div\n      className=\"rounded-xl border p-6 space-y-4\"\n      style={{\n        backgroundColor: colors.background ?? \"#ffffff\",\n        color: colors.foreground ?? \"#000000\",\n        borderColor: colors.muted ?? \"#e5e7eb\",\n      }}\n    >\n      <h3 className=\"text-lg font-semibold\">Live Preview</h3>\n      <p style={{ color: colors.muted ?? \"#6b7280\" }} className=\"text-sm\">\n        This is how the theme looks when applied to a card.\n      </p>\n      <div className=\"flex gap-3\">\n        <button\n          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n          style={{ backgroundColor: colors.primary ?? \"#3b82f6\" }}\n        >\n          Primary\n        </button>\n        <button\n          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n          style={{ backgroundColor: colors.secondary ?? \"#6366f1\" }}\n        >\n          Secondary\n        </button>\n        <button\n          className=\"px-4 py-2 rounded-lg text-sm font-medium border\"\n          style={{\n            backgroundColor: colors.accent ?? \"#f59e0b\",\n            borderColor: colors.muted ?? \"#e5e7eb\",\n          }}\n        >\n          Accent\n        </button>\n      </div>\n    </div>\n  );\n}\n\nexport default function ThemeDetailPage() {\n  const params = useParams<{ slug: string }>();\n  const router = useRouter();\n  const slug = params.slug;\n\n  const theme = useQuery(api.themes.getBySlug, { slug });\n  const author = useQuery(\n    api.users.get,\n    theme ? { id: theme.authorId } : \"skip\"\n  );\n  const currentUser = useQuery(api.users.getCurrentUser);\n\n  // Stars\n  const isStarred = useQuery(\n    api.stars.isStarred,\n    theme ? { themeId: theme._id } : \"skip\"\n  );\n  const toggleStar = useMutation(api.stars.toggle);\n\n  // Comments\n  const comments = useQuery(\n    api.comments.listByTheme,\n    theme ? { themeId: theme._id } : \"skip\"\n  );\n  const createComment = useMutation(api.comments.create);\n  const [commentBody, setCommentBody] = useState(\"\");\n  const [submittingComment, setSubmittingComment] = useState(false);\n\n  // Fork\n  const forkTheme = useMutation(api.themes.fork);\n  const [forking, setForking] = useState(false);\n\n  // Forked-from theme info (for link)\n  const forkedFrom = useQuery(\n    api.themes.getBasicInfo,\n    theme?.forkedFromId ? { id: theme.forkedFromId } : \"skip\"\n  );\n\n  // Edit/Delete mutations\n  const updateTheme = useMutation(api.themes.update);\n  const removeTheme = useMutation(api.themes.remove);\n\n  // Edit mode state\n  const [editing, setEditing] = useState(false);\n  const [editName, setEditName] = useState(\"\");\n  const [editDescription, setEditDescription] = useState(\"\");\n  const [editIsPublic, setEditIsPublic] = useState(true);\n  const [editColors, setEditColors] = useState<Record<string, string>>({});\n  const [editFonts, setEditFonts] = useState<Record<string, string>>({});\n  const [saving, setSaving] = useState(false);\n  const [saveError, setSaveError] = useState<string | null>(null);\n\n  // Delete state\n  const [confirmingDelete, setConfirmingDelete] = useState(false);\n  const [deleting, setDeleting] = useState(false);\n  const [deleteError, setDeleteError] = useState<string | null>(null);\n\n  // Owner detection\n  const isOwner = !!(currentUser && theme && currentUser._id === theme.authorId);\n\n  function enterEditMode() {\n    if (!theme) return;\n    setEditName(theme.name);\n    setEditDescription(theme.description ?? \"\");\n    setEditIsPublic(theme.isPublic);\n    const c: Record<string, string> = {};\n    const themeColors = theme.colors as Record<string, string | undefined>;\n    for (const { key } of COLOR_LABELS) {\n      if (themeColors[key]) c[key] = themeColors[key]!;\n    }\n    setEditColors(c);\n    const f: Record<string, string> = {};\n    if (theme.fonts) {\n      for (const k of FONT_KEYS) {\n        if (theme.fonts[k]) f[k] = theme.fonts[k]!;\n      }\n    }\n    setEditFonts(f);\n    setSaveError(null);\n    setEditing(true);\n  }\n\n  function cancelEdit() {\n    setEditing(false);\n    setSaveError(null);\n  }\n\n  async function handleSave() {\n    if (!theme) return;\n    setSaving(true);\n    setSaveError(null);\n    try {\n      const updates: Record<string, unknown> = { id: theme._id };\n      if (editName !== theme.name) updates.name = editName;\n      if (editDescription !== (theme.description ?? \"\"))\n        updates.description = editDescription;\n      if (editIsPublic !== theme.isPublic) updates.isPublic = editIsPublic;\n\n      // Colors: always send all edited colors\n      const origColors = theme.colors as Record<string, string | undefined>;\n      const colorsChanged = COLOR_LABELS.some(\n        ({ key }) => (editColors[key] ?? \"\") !== (origColors[key] ?? \"\")\n      );\n      if (colorsChanged) updates.colors = editColors;\n\n      // Fonts: send if changed\n      const origFonts = (theme.fonts ?? {}) as Record<string, string | undefined>;\n      const fontsChanged = FONT_KEYS.some(\n        (k) => (editFonts[k] ?? \"\") !== (origFonts[k] ?? \"\")\n      );\n      if (fontsChanged) {\n        const fontPayload: Record<string, string> = {};\n        for (const k of FONT_KEYS) {\n          if (editFonts[k]?.trim()) fontPayload[k] = editFonts[k];\n        }\n        updates.fonts = fontPayload;\n      }\n\n      const result = await updateTheme(updates as Parameters<typeof updateTheme>[0]);\n      setEditing(false);\n\n      // If name changed, the slug changed server-side — redirect using the returned slug\n      if (editName !== theme.name && result?.slug) {\n        router.push(`/theme/${result.slug}`);\n      }\n    } catch (err) {\n      setSaveError(err instanceof Error ? err.message : \"Failed to save\");\n    } finally {\n      setSaving(false);\n    }\n  }\n\n  async function handleDelete() {\n    if (!theme) return;\n    setDeleting(true);\n    setDeleteError(null);\n    try {\n      await removeTheme({ id: theme._id });\n      router.push(\"/\");\n    } catch (err) {\n      setDeleteError(err instanceof Error ? err.message : \"Failed to delete\");\n      setDeleting(false);\n    }\n  }\n\n  // Loading state\n  if (theme === undefined) {\n    return (\n      <div className=\"min-h-screen flex items-center justify-center\">\n        <div className=\"animate-pulse text-gray-400 text-lg\">\n          Loading theme...\n        </div>\n      </div>\n    );\n  }\n\n  // Not found\n  if (theme === null) {\n    return (\n      <div className=\"min-h-screen flex flex-col items-center justify-center gap-4\">\n        <h1 className=\"text-2xl font-bold text-gray-800\">Theme not found</h1>\n        <p className=\"text-gray-500\">\n          This theme doesn&apos;t exist or is private.\n        </p>\n        <a href=\"/\" className=\"text-blue-600 hover:underline text-sm\">\n          Back to gallery\n        </a>\n      </div>\n    );\n  }\n\n  const colors = editing\n    ? (editColors as Record<string, string | undefined>)\n    : (theme.colors as Record<string, string | undefined>);\n\n  async function handleToggleStar() {\n    if (!theme || !currentUser) return;\n    await toggleStar({ themeId: theme._id });\n  }\n\n  async function handleSubmitComment(e: React.FormEvent) {\n    e.preventDefault();\n    if (!theme || !commentBody.trim()) return;\n    setSubmittingComment(true);\n    try {\n      await createComment({ themeId: theme._id, body: commentBody.trim() });\n      setCommentBody(\"\");\n    } finally {\n      setSubmittingComment(false);\n    }\n  }\n\n  async function handleFork() {\n    if (!theme) return;\n    setForking(true);\n    try {\n      const result = await forkTheme({ id: theme._id });\n      if (result) {\n        router.push(`/theme/${result.slug}`);\n      }\n    } catch {\n      // Fork may fail if not authenticated\n    } finally {\n      setForking(false);\n    }\n  }\n\n  return (\n    <div className=\"min-h-screen bg-gray-50\">\n      {/* Header */}\n      <header className=\"bg-white border-b border-gray-200\">\n        <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n          <a\n            href=\"/\"\n            className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n          >\n            ThemeDrops\n          </a>\n          <div className=\"flex items-center gap-3\">\n            <CreateThemeLink />\n            <AuthControls />\n          </div>\n        </div>\n      </header>\n\n      <main className=\"max-w-4xl mx-auto px-6 py-10 space-y-10\">\n        {/* Theme header */}\n        <div className=\"space-y-3\">\n          <div className=\"flex items-start justify-between gap-4\">\n            <div className=\"space-y-1 flex-1\">\n              {editing ? (\n                <input\n                  type=\"text\"\n                  value={editName}\n                  onChange={(e) => setEditName(e.target.value)}\n                  className=\"text-3xl font-bold text-gray-900 w-full border border-gray-300 rounded-lg px-3 py-1 focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                />\n              ) : (\n                <h1 className=\"text-3xl font-bold text-gray-900\">\n                  {theme.name}\n                </h1>\n              )}\n              {author && (\n                <p className=\"text-sm text-gray-500\">\n                  by{\" \"}\n                  <span className=\"font-medium text-gray-700\">\n                    {author.displayName ?? author.username}\n                  </span>\n                </p>\n              )}\n            </div>\n\n            <div className=\"flex items-center gap-2\">\n              {/* Owner controls */}\n              {isOwner && !editing && (\n                <>\n                  <button\n                    onClick={enterEditMode}\n                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors\"\n                  >\n                    Edit\n                  </button>\n                  {!confirmingDelete ? (\n                    <button\n                      onClick={() => setConfirmingDelete(true)}\n                      className=\"px-4 py-2 rounded-lg border border-red-200 bg-white text-sm font-medium text-red-600 hover:bg-red-50 transition-colors\"\n                    >\n                      Delete\n                    </button>\n                  ) : (\n                    <div className=\"flex items-center gap-2 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n                      <span className=\"text-sm text-red-700\">Delete this theme?</span>\n                      <button\n                        onClick={handleDelete}\n                        disabled={deleting}\n                        className=\"px-3 py-1 rounded bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition-colors disabled:opacity-50\"\n                      >\n                        {deleting ? \"Deleting...\" : \"Confirm\"}\n                      </button>\n                      <button\n                        onClick={() => {\n                          setConfirmingDelete(false);\n                          setDeleteError(null);\n                        }}\n                        disabled={deleting}\n                        className=\"px-3 py-1 rounded border border-red-200 text-sm text-red-600 hover:bg-red-100 transition-colors disabled:opacity-50\"\n                      >\n                        Cancel\n                      </button>\n                    </div>\n                  )}\n                </>\n              )}\n\n              {/* Edit mode controls */}\n              {editing && (\n                <>\n                  <button\n                    onClick={handleSave}\n                    disabled={saving || !editName.trim()}\n                    className=\"px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n                  >\n                    {saving ? \"Saving...\" : \"Save\"}\n                  </button>\n                  <button\n                    onClick={cancelEdit}\n                    disabled={saving}\n                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50\"\n                  >\n                    Cancel\n                  </button>\n                </>\n              )}\n\n              {/* Star button */}\n              {!editing && (\n                <button\n                  onClick={handleToggleStar}\n                  disabled={!currentUser}\n                  className={`flex items-center gap-1.5 px-4 py-2 rounded-lg border text-sm font-medium transition-colors ${\n                    isStarred\n                      ? \"bg-yellow-50 border-yellow-300 text-yellow-700\"\n                      : \"bg-white border-gray-200 text-gray-600 hover:bg-gray-50\"\n                  } ${!currentUser ? \"opacity-50 cursor-not-allowed\" : \"cursor-pointer\"}`}\n                  title={!currentUser ? \"Sign in to star themes\" : undefined}\n                >\n                  <span className=\"text-lg\">\n                    {isStarred ? \"\\u2605\" : \"\\u2606\"}\n                  </span>\n                  <span>{theme.starCount}</span>\n                </button>\n              )}\n            </div>\n          </div>\n\n          {/* Delete error */}\n          {deleteError && (\n            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n              {deleteError}\n            </p>\n          )}\n\n          {/* Save error */}\n          {saveError && (\n            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n              {saveError}\n            </p>\n          )}\n\n          {/* Description */}\n          {editing ? (\n            <textarea\n              value={editDescription}\n              onChange={(e) => setEditDescription(e.target.value)}\n              placeholder=\"Theme description...\"\n              rows={3}\n              className=\"w-full text-gray-600 leading-relaxed border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n            />\n          ) : (\n            theme.description && (\n              <p className=\"text-gray-600 leading-relaxed\">\n                {theme.description}\n              </p>\n            )\n          )}\n\n          {/* Visibility toggle */}\n          {editing && (\n            <div className=\"flex items-center gap-3\">\n              <span className=\"text-sm text-gray-600\">Visibility:</span>\n              <button\n                onClick={() => setEditIsPublic(!editIsPublic)}\n                className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${\n                  editIsPublic ? \"bg-blue-600\" : \"bg-gray-300\"\n                }`}\n              >\n                <span\n                  className={`inline-block h-4 w-4 rounded-full bg-white transition-transform ${\n                    editIsPublic ? \"translate-x-6\" : \"translate-x-1\"\n                  }`}\n                />\n              </button>\n              <span className=\"text-sm text-gray-500\">\n                {editIsPublic ? \"Public\" : \"Private\"}\n              </span>\n            </div>\n          )}\n\n          {theme.forkedFromId && forkedFrom && (\n            <p className=\"text-sm text-gray-400 italic\">\n              Forked from{\" \"}\n              <a\n                href={`/theme/${forkedFrom.slug}`}\n                className=\"text-blue-500 hover:underline\"\n              >\n                {forkedFrom.name}\n              </a>\n            </p>\n          )}\n\n          {!editing && (\n            <p className=\"text-xs text-gray-400 font-mono bg-gray-100 inline-block px-2 py-1 rounded\">\n              API: /api/theme/{theme.slug}\n            </p>\n          )}\n        </div>\n\n        {/* Color palette */}\n        <section className=\"space-y-4\">\n          <h2 className=\"text-lg font-semibold text-gray-800\">Color Palette</h2>\n          <div className=\"flex flex-wrap gap-6\">\n            {editing\n              ? COLOR_LABELS.map(({ key, label }) => (\n                  <EditableColorSwatch\n                    key={key}\n                    color={editColors[key] ?? \"#000000\"}\n                    label={label}\n                    onChange={(value) =>\n                      setEditColors((prev) => ({ ...prev, [key]: value }))\n                    }\n                  />\n                ))\n              : COLOR_LABELS.map(({ key, label }) => {\n                  const color = colors[key];\n                  if (!color) return null;\n                  return <ColorSwatch key={key} color={color} label={label} />;\n                })}\n          </div>\n        </section>\n\n        {/* Live preview */}\n        <section className=\"space-y-4\">\n          <h2 className=\"text-lg font-semibold text-gray-800\">Preview</h2>\n          <LivePreview colors={colors} />\n        </section>\n\n        {/* Fonts */}\n        {editing ? (\n          <section className=\"space-y-4\">\n            <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n            <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n              {FONT_KEYS.map((k) => (\n                <div\n                  key={k}\n                  className=\"bg-white rounded-lg border border-gray-200 p-4\"\n                >\n                  <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                    {k}\n                  </p>\n                  <input\n                    type=\"text\"\n                    value={editFonts[k] ?? \"\"}\n                    onChange={(e) =>\n                      setEditFonts((prev) => ({ ...prev, [k]: e.target.value }))\n                    }\n                    placeholder={`${k} font name`}\n                    className=\"w-full text-sm border border-gray-200 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n                  />\n                  {editFonts[k] && (\n                    <p\n                      className=\"text-sm text-gray-500 mt-2\"\n                      style={{ fontFamily: editFonts[k] }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  )}\n                </div>\n              ))}\n            </div>\n          </section>\n        ) : (\n          theme.fonts &&\n          (theme.fonts.sans || theme.fonts.serif || theme.fonts.mono) && (\n            <section className=\"space-y-4\">\n              <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n                {theme.fonts.sans && (\n                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                      Sans\n                    </p>\n                    <p\n                      className=\"text-lg\"\n                      style={{ fontFamily: theme.fonts.sans }}\n                    >\n                      {theme.fonts.sans}\n                    </p>\n                    <p\n                      className=\"text-sm text-gray-500 mt-1\"\n                      style={{ fontFamily: theme.fonts.sans }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  </div>\n                )}\n                {theme.fonts.serif && (\n                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                      Serif\n                    </p>\n                    <p\n                      className=\"text-lg\"\n                      style={{ fontFamily: theme.fonts.serif }}\n                    >\n                      {theme.fonts.serif}\n                    </p>\n                    <p\n                      className=\"text-sm text-gray-500 mt-1\"\n                      style={{ fontFamily: theme.fonts.serif }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  </div>\n                )}\n                {theme.fonts.mono && (\n                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                      Mono\n                    </p>\n                    <p\n                      className=\"text-lg font-mono\"\n                      style={{ fontFamily: theme.fonts.mono }}\n                    >\n                      {theme.fonts.mono}\n                    </p>\n                    <p\n                      className=\"text-sm text-gray-500 mt-1\"\n                      style={{ fontFamily: theme.fonts.mono }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  </div>\n                )}\n              </div>\n            </section>\n          )\n        )}\n\n        {/* Fork button */}\n        {currentUser && !editing && (\n          <div>\n            <button\n              onClick={handleFork}\n              disabled={forking}\n              className=\"px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors disabled:opacity-50\"\n            >\n              {forking ? \"Forking...\" : \"Fork this theme\"}\n            </button>\n          </div>\n        )}\n\n        {/* Comments */}\n        {!editing && (\n          <section className=\"space-y-6\">\n            <h2 className=\"text-lg font-semibold text-gray-800\">\n              Comments{\" \"}\n              {comments && comments.length > 0 && (\n                <span className=\"text-gray-400 font-normal\">\n                  ({comments.length})\n                </span>\n              )}\n            </h2>\n\n            {comments === undefined && (\n              <p className=\"text-gray-400 text-sm animate-pulse\">\n                Loading comments...\n              </p>\n            )}\n\n            {comments && comments.length === 0 && (\n              <p className=\"text-gray-400 text-sm\">No comments yet.</p>\n            )}\n\n            {comments && comments.length > 0 && (\n              <div className=\"space-y-4\">\n                {comments.map((comment) => (\n                  <div\n                    key={comment._id}\n                    className=\"bg-white rounded-lg border border-gray-200 p-4\"\n                  >\n                    <div className=\"flex items-center gap-2 mb-2\">\n                      {comment.author?.avatarUrl && (\n                        <img\n                          src={comment.author.avatarUrl}\n                          alt=\"\"\n                          className=\"w-6 h-6 rounded-full\"\n                        />\n                      )}\n                      <span className=\"text-sm font-medium text-gray-700\">\n                        {comment.author?.displayName ??\n                          comment.author?.username ??\n                          \"Unknown\"}\n                      </span>\n                    </div>\n                    <p className=\"text-sm text-gray-600\">{comment.body}</p>\n                  </div>\n                ))}\n              </div>\n            )}\n\n            {/* Add comment form */}\n            {currentUser && (\n              <form onSubmit={handleSubmitComment} className=\"flex gap-3\">\n                <input\n                  type=\"text\"\n                  value={commentBody}\n                  onChange={(e) => setCommentBody(e.target.value)}\n                  placeholder=\"Add a comment...\"\n                  className=\"flex-1 px-4 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n                />\n                <button\n                  type=\"submit\"\n                  disabled={!commentBody.trim() || submittingComment}\n                  className=\"px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n                >\n                  {submittingComment ? \"Posting...\" : \"Post\"}\n                </button>\n              </form>\n            )}\n          </section>\n        )}\n      </main>\n    </div>\n  );\n}\n","numLines":738,"startLine":1,"totalLines":738}}}
