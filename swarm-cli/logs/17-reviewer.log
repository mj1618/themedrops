 429→                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50\"\n   430→                  >\n   431→                    Cancel\n   432→                  </button>\n   433→                </>\n   434→              )}\n   435→\n   436→              {/* Star button */}\n   437→              {!editing && (\n   438→                <button\n   439→                  onClick={handleToggleStar}\n   440→                  disabled={!currentUser}\n   441→                  className={`flex items-center gap-1.5 px-4 py-2 rounded-lg border text-sm font-medium transition-colors ${\n   442→                    isStarred\n   443→                      ? \"bg-yellow-50 border-yellow-300 text-yellow-700\"\n   444→                      : \"bg-white border-gray-200 text-gray-600 hover:bg-gray-50\"\n   445→                  } ${!currentUser ? \"opacity-50 cursor-not-allowed\" : \"cursor-pointer\"}`}\n   446→                  title={!currentUser ? \"Sign in to star themes\" : undefined}\n   447→                >\n   448→                  <span className=\"text-lg\">\n   449→                    {isStarred ? \"\\u2605\" : \"\\u2606\"}\n   450→                  </span>\n   451→                  <span>{theme.starCount}</span>\n   452→                </button>\n   453→              )}\n   454→            </div>\n   455→          </div>\n   456→\n   457→          {/* Delete error */}\n   458→          {deleteError && (\n   459→            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   460→              {deleteError}\n   461→            </p>\n   462→          )}\n   463→\n   464→          {/* Save error */}\n   465→          {saveError && (\n   466→            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   467→              {saveError}\n   468→            </p>\n   469→          )}\n   470→\n   471→          {/* Description */}\n   472→          {editing ? (\n   473→            <textarea\n   474→              value={editDescription}\n   475→              onChange={(e) => setEditDescription(e.target.value)}\n   476→              placeholder=\"Theme description...\"\n   477→              rows={3}\n   478→              className=\"w-full text-gray-600 leading-relaxed border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   479→            />\n   480→          ) : (\n   481→            theme.description && (\n   482→              <p className=\"text-gray-600 leading-relaxed\">\n   483→                {theme.description}\n   484→              </p>\n   485→            )\n   486→          )}\n   487→\n   488→          {/* Visibility toggle */}\n   489→          {editing && (\n   490→            <div className=\"flex items-center gap-3\">\n   491→              <span className=\"text-sm text-gray-600\">Visibility:</span>\n   492→              <button\n   493→                onClick={() => setEditIsPublic(!editIsPublic)}\n   494→                className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${\n   495→                  editIsPublic ? \"bg-blue-600\" : \"bg-gray-300\"\n   496→                }`}\n   497→              >\n   498→                <span\n   499→                  className={`inline-block h-4 w-4 rounded-full bg-white transition-transform ${\n   500→                    editIsPublic ? \"translate-x-6\" : \"translate-x-1\"\n   501→                  }`}\n   502→                />\n   503→              </button>\n   504→              <span className=\"text-sm text-gray-500\">\n   505→                {editIsPublic ? \"Public\" : \"Private\"}\n   506→              </span>\n   507→            </div>\n   508→          )}\n   509→\n   510→          {theme.forkedFromId && forkedFrom && (\n   511→            <p className=\"text-sm text-gray-400 italic\">\n   512→              Forked from{\" \"}\n   513→              <a\n   514→                href={`/theme/${forkedFrom.slug}`}\n   515→                className=\"text-blue-500 hover:underline\"\n   516→              >\n   517→                {forkedFrom.name}\n   518→              </a>\n   519→            </p>\n   520→          )}\n   521→\n   522→          {!editing && (\n   523→            <p className=\"text-xs text-gray-400 font-mono bg-gray-100 inline-block px-2 py-1 rounded\">\n   524→              API: /api/theme/{theme.slug}\n   525→            </p>\n   526→          )}\n   527→        </div>\n   528→\n   529→        {/* Color palette */}\n   530→        <section className=\"space-y-4\">\n   531→          <h2 className=\"text-lg font-semibold text-gray-800\">Color Palette</h2>\n   532→          <div className=\"flex flex-wrap gap-6\">\n   533→            {editing\n   534→              ? COLOR_LABELS.map(({ key, label }) => (\n   535→                  <EditableColorSwatch\n   536→                    key={key}\n   537→                    color={editColors[key] ?? \"#000000\"}\n   538→                    label={label}\n   539→                    onChange={(value) =>\n   540→                      setEditColors((prev) => ({ ...prev, [key]: value }))\n   541→                    }\n   542→                  />\n   543→                ))\n   544→              : COLOR_LABELS.map(({ key, label }) => {\n   545→                  const color = colors[key];\n   546→                  if (!color) return null;\n   547→                  return <ColorSwatch key={key} color={color} label={label} />;\n   548→                })}\n   549→          </div>\n   550→        </section>\n   551→\n   552→        {/* Live preview */}\n   553→        <section className=\"space-y-4\">\n   554→          <h2 className=\"text-lg font-semibold text-gray-800\">Preview</h2>\n   555→          <LivePreview colors={colors} />\n   556→        </section>\n   557→\n   558→        {/* Fonts */}\n   559→        {editing ? (\n   560→          <section className=\"space-y-4\">\n   561→            <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   562→            <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   563→              {FONT_KEYS.map((k) => (\n   564→                <div\n   565→                  key={k}\n   566→                  className=\"bg-white rounded-lg border border-gray-200 p-4\"\n   567→                >\n   568→                  <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   569→                    {k}\n   570→                  </p>\n   571→                  <input\n   572→                    type=\"text\"\n   573→                    value={editFonts[k] ?? \"\"}\n   574→                    onChange={(e) =>\n   575→                      setEditFonts((prev) => ({ ...prev, [k]: e.target.value }))\n   576→                    }\n   577→                    placeholder={`${k} font name`}\n   578→                    className=\"w-full text-sm border border-gray-200 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n   579→                  />\n   580→                  {editFonts[k] && (\n   581→                    <p\n   582→                      className=\"text-sm text-gray-500 mt-2\"\n   583→                      style={{ fontFamily: editFonts[k] }}\n   584→                    >\n   585→                      The quick brown fox jumps over the lazy dog.\n   586→                    </p>\n   587→                  )}\n   588→                </div>\n   589→              ))}\n   590→            </div>\n   591→          </section>\n   592→        ) : (\n   593→          theme.fonts &&\n   594→          (theme.fonts.sans || theme.fonts.serif || theme.fonts.mono) && (\n   595→            <section className=\"space-y-4\">\n   596→              <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   597→              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   598→                {theme.fonts.sans && (\n   599→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   600→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   601→                      Sans\n   602→                    </p>\n   603→                    <p\n   604→                      className=\"text-lg\"\n   605→                      style={{ fontFamily: theme.fonts.sans }}\n   606→                    >\n   607→                      {theme.fonts.sans}\n   608→                    </p>\n   609→                    <p\n   610→                      className=\"text-sm text-gray-500 mt-1\"\n   611→                      style={{ fontFamily: theme.fonts.sans }}\n   612→                    >\n   613→                      The quick brown fox jumps over the lazy dog.\n   614→                    </p>\n   615→                  </div>\n   616→                )}\n   617→                {theme.fonts.serif && (\n   618→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   619→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   620→                      Serif\n   621→                    </p>\n   622→                    <p\n   623→                      className=\"text-lg\"\n   624→                      style={{ fontFamily: theme.fonts.serif }}\n   625→                    >\n   626→                      {theme.fonts.serif}\n   627→                    </p>\n   628→                    <p\n   629→                      className=\"text-sm text-gray-500 mt-1\"\n   630→                      style={{ fontFamily: theme.fonts.serif }}\n   631→                    >\n   632→                      The quick brown fox jumps over the lazy dog.\n   633→                    </p>\n   634→                  </div>\n   635→                )}\n   636→                {theme.fonts.mono && (\n   637→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   638→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   639→                      Mono\n   640→                    </p>\n   641→                    <p\n   642→                      className=\"text-lg font-mono\"\n   643→                      style={{ fontFamily: theme.fonts.mono }}\n   644→                    >\n   645→                      {theme.fonts.mono}\n   646→                    </p>\n   647→                    <p\n   648→                      className=\"text-sm text-gray-500 mt-1\"\n   649→                      style={{ fontFamily: theme.fonts.mono }}\n   650→                    >\n   651→                      The quick brown fox jumps over the lazy dog.\n   652→                    </p>\n   653→                  </div>\n   654→                )}\n   655→              </div>\n   656→            </section>\n   657→          )\n   658→        )}\n   659→\n   660→        {/* Fork button */}\n   661→        {currentUser && !editing && (\n   662→          <div>\n   663→            <button\n   664→              onClick={handleFork}\n   665→              disabled={forking}\n   666→              className=\"px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors disabled:opacity-50\"\n   667→            >\n   668→              {forking ? \"Forking...\" : \"Fork this theme\"}\n   669→            </button>\n   670→          </div>\n   671→        )}\n   672→\n   673→        {/* Comments */}\n   674→        {!editing && (\n   675→          <section className=\"space-y-6\">\n   676→            <h2 className=\"text-lg font-semibold text-gray-800\">\n   677→              Comments{\" \"}\n   678→              {comments && comments.length > 0 && (\n   679→                <span className=\"text-gray-400 font-normal\">\n   680→                  ({comments.length})\n   681→                </span>\n   682→              )}\n   683→            </h2>\n   684→\n   685→            {comments === undefined && (\n   686→              <p className=\"text-gray-400 text-sm animate-pulse\">\n   687→                Loading comments...\n   688→              </p>\n   689→            )}\n   690→\n   691→            {comments && comments.length === 0 && (\n   692→              <p className=\"text-gray-400 text-sm\">No comments yet.</p>\n   693→            )}\n   694→\n   695→            {comments && comments.length > 0 && (\n   696→              <div className=\"space-y-4\">\n   697→                {comments.map((comment) => (\n   698→                  <div\n   699→                    key={comment._id}\n   700→                    className=\"bg-white rounded-lg border border-gray-200 p-4\"\n   701→                  >\n   702→                    <div className=\"flex items-center gap-2 mb-2\">\n   703→                      {comment.author?.avatarUrl && (\n   704→                        <img\n   705→                          src={comment.author.avatarUrl}\n   706→                          alt=\"\"\n   707→                          className=\"w-6 h-6 rounded-full\"\n   708→                        />\n   709→                      )}\n   710→                      <span className=\"text-sm font-medium text-gray-700\">\n   711→                        {comment.author?.displayName ??\n   712→                          comment.author?.username ??\n   713→                          \"Unknown\"}\n   714→                      </span>\n   715→                    </div>\n   716→                    <p className=\"text-sm text-gray-600\">{comment.body}</p>\n   717→                  </div>\n   718→                ))}\n   719→              </div>\n   720→            )}\n   721→\n   722→            {/* Add comment form */}\n   723→            {currentUser && (\n   724→              <form onSubmit={handleSubmitComment} className=\"flex gap-3\">\n   725→                <input\n   726→                  type=\"text\"\n   727→                  value={commentBody}\n   728→                  onChange={(e) => setCommentBody(e.target.value)}\n   729→                  placeholder=\"Add a comment...\"\n   730→                  className=\"flex-1 px-4 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n   731→                />\n   732→                <button\n   733→                  type=\"submit\"\n   734→                  disabled={!commentBody.trim() || submittingComment}\n   735→                  className=\"px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n   736→                >\n   737→                  {submittingComment ? \"Posting...\" : \"Post\"}\n   738→                </button>\n   739→              </form>\n   740→            )}\n   741→          </section>\n   742→        )}\n   743→      </main>\n   744→    </div>\n   745→  );\n   746→}\n   747→"}]},"parent_tool_use_id":null,"session_id":"ceec0539-6478-4eeb-897f-84ed3b4ac287","uuid":"5229c195-1454-4131-859f-5bfd007790e2","timestamp":"2026-03-27T23:54:34.075Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/matt/code/themedrops/app/src/app/theme/[slug]/page.tsx","content":"\"use client\";\n\nimport { useParams, useRouter } from \"next/navigation\";\nimport { useQuery, useMutation } from \"convex/react\";\nimport { api } from \"../../../../convex/_generated/api\";\nimport { useState } from \"react\";\nimport AuthControls from \"../../components/AuthControls\";\nimport CreateThemeLink from \"../../components/CreateThemeLink\";\n\nconst COLOR_LABELS: { key: string; label: string }[] = [\n  { key: \"background\", label: \"Background\" },\n  { key: \"foreground\", label: \"Foreground\" },\n  { key: \"primary\", label: \"Primary\" },\n  { key: \"secondary\", label: \"Secondary\" },\n  { key: \"accent\", label: \"Accent\" },\n  { key: \"muted\", label: \"Muted\" },\n];\n\nconst FONT_KEYS = [\"sans\", \"serif\", \"mono\"] as const;\n\nfunction ColorSwatch({ color, label }: { color: string; label: string }) {\n  return (\n    <div className=\"flex flex-col items-center gap-2\">\n      <div\n        className=\"w-16 h-16 rounded-xl border border-gray-200 shadow-sm\"\n        style={{ backgroundColor: color }}\n      />\n      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n      <span className=\"text-xs font-mono text-gray-400\">{color}</span>\n    </div>\n  );\n}\n\nfunction EditableColorSwatch({\n  color,\n  label,\n  onChange,\n}: {\n  color: string;\n  label: string;\n  onChange: (value: string) => void;\n}) {\n  return (\n    <div className=\"flex flex-col items-center gap-2\">\n      <label className=\"relative w-16 h-16 rounded-xl border border-gray-200 shadow-sm cursor-pointer overflow-hidden\">\n        <div\n          className=\"absolute inset-0\"\n          style={{ backgroundColor: color }}\n        />\n        <input\n          type=\"color\"\n          value={color}\n          onChange={(e) => onChange(e.target.value)}\n          className=\"absolute inset-0 opacity-0 cursor-pointer\"\n        />\n      </label>\n      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n      <input\n        type=\"text\"\n        value={color}\n        onChange={(e) => onChange(e.target.value)}\n        className=\"text-xs font-mono text-gray-600 w-20 text-center border border-gray-200 rounded px-1 py-0.5 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n      />\n    </div>\n  );\n}\n\nfunction LivePreview({\n  colors,\n}: {\n  colors: Record<string, string | undefined>;\n}) {\n  return (\n    <div\n      className=\"rounded-xl border p-6 space-y-4\"\n      style={{\n        backgroundColor: colors.background ?? \"#ffffff\",\n        color: colors.foreground ?? \"#000000\",\n        borderColor: colors.muted ?? \"#e5e7eb\",\n      }}\n    >\n      <h3 className=\"text-lg font-semibold\">Live Preview</h3>\n      <p style={{ color: colors.muted ?? \"#6b7280\" }} className=\"text-sm\">\n        This is how the theme looks when applied to a card.\n      </p>\n      <div className=\"flex gap-3\">\n        <button\n          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n          style={{ backgroundColor: colors.primary ?? \"#3b82f6\" }}\n        >\n          Primary\n        </button>\n        <button\n          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n          style={{ backgroundColor: colors.secondary ?? \"#6366f1\" }}\n        >\n          Secondary\n        </button>\n        <button\n          className=\"px-4 py-2 rounded-lg text-sm font-medium border\"\n          style={{\n            backgroundColor: colors.accent ?? \"#f59e0b\",\n            borderColor: colors.muted ?? \"#e5e7eb\",\n          }}\n        >\n          Accent\n        </button>\n      </div>\n    </div>\n  );\n}\n\nfunction slugify(name: string): string {\n  return name\n    .toLowerCase()\n    .trim()\n    .replace(/[^a-z0-9]+/g, \"-\")\n    .replace(/^-|-$/g, \"\");\n}\n\nexport default function ThemeDetailPage() {\n  const params = useParams<{ slug: string }>();\n  const router = useRouter();\n  const slug = params.slug;\n\n  const theme = useQuery(api.themes.getBySlug, { slug });\n  const author = useQuery(\n    api.users.get,\n    theme ? { id: theme.authorId } : \"skip\"\n  );\n  const currentUser = useQuery(api.users.getCurrentUser);\n\n  // Stars\n  const isStarred = useQuery(\n    api.stars.isStarred,\n    theme ? { themeId: theme._id } : \"skip\"\n  );\n  const toggleStar = useMutation(api.stars.toggle);\n\n  // Comments\n  const comments = useQuery(\n    api.comments.listByTheme,\n    theme ? { themeId: theme._id } : \"skip\"\n  );\n  const createComment = useMutation(api.comments.create);\n  const [commentBody, setCommentBody] = useState(\"\");\n  const [submittingComment, setSubmittingComment] = useState(false);\n\n  // Fork\n  const forkTheme = useMutation(api.themes.fork);\n  const [forking, setForking] = useState(false);\n\n  // Forked-from theme info (for link)\n  const forkedFrom = useQuery(\n    api.themes.getBasicInfo,\n    theme?.forkedFromId ? { id: theme.forkedFromId } : \"skip\"\n  );\n\n  // Edit/Delete mutations\n  const updateTheme = useMutation(api.themes.update);\n  const removeTheme = useMutation(api.themes.remove);\n\n  // Edit mode state\n  const [editing, setEditing] = useState(false);\n  const [editName, setEditName] = useState(\"\");\n  const [editDescription, setEditDescription] = useState(\"\");\n  const [editIsPublic, setEditIsPublic] = useState(true);\n  const [editColors, setEditColors] = useState<Record<string, string>>({});\n  const [editFonts, setEditFonts] = useState<Record<string, string>>({});\n  const [saving, setSaving] = useState(false);\n  const [saveError, setSaveError] = useState<string | null>(null);\n\n  // Delete state\n  const [confirmingDelete, setConfirmingDelete] = useState(false);\n  const [deleting, setDeleting] = useState(false);\n  const [deleteError, setDeleteError] = useState<string | null>(null);\n\n  // Owner detection\n  const isOwner = !!(currentUser && theme && currentUser._id === theme.authorId);\n\n  function enterEditMode() {\n    if (!theme) return;\n    setEditName(theme.name);\n    setEditDescription(theme.description ?? \"\");\n    setEditIsPublic(theme.isPublic);\n    const c: Record<string, string> = {};\n    const themeColors = theme.colors as Record<string, string | undefined>;\n    for (const { key } of COLOR_LABELS) {\n      if (themeColors[key]) c[key] = themeColors[key]!;\n    }\n    setEditColors(c);\n    const f: Record<string, string> = {};\n    if (theme.fonts) {\n      for (const k of FONT_KEYS) {\n        if (theme.fonts[k]) f[k] = theme.fonts[k]!;\n      }\n    }\n    setEditFonts(f);\n    setSaveError(null);\n    setEditing(true);\n  }\n\n  function cancelEdit() {\n    setEditing(false);\n    setSaveError(null);\n  }\n\n  async function handleSave() {\n    if (!theme) return;\n    setSaving(true);\n    setSaveError(null);\n    try {\n      const updates: Record<string, unknown> = { id: theme._id };\n      if (editName !== theme.name) updates.name = editName;\n      if (editDescription !== (theme.description ?? \"\"))\n        updates.description = editDescription;\n      if (editIsPublic !== theme.isPublic) updates.isPublic = editIsPublic;\n\n      // Colors: always send all edited colors\n      const origColors = theme.colors as Record<string, string | undefined>;\n      const colorsChanged = COLOR_LABELS.some(\n        ({ key }) => (editColors[key] ?? \"\") !== (origColors[key] ?? \"\")\n      );\n      if (colorsChanged) updates.colors = editColors;\n\n      // Fonts: send if changed\n      const origFonts = (theme.fonts ?? {}) as Record<string, string | undefined>;\n      const fontsChanged = FONT_KEYS.some(\n        (k) => (editFonts[k] ?? \"\") !== (origFonts[k] ?? \"\")\n      );\n      if (fontsChanged) {\n        const fontPayload: Record<string, string> = {};\n        for (const k of FONT_KEYS) {\n          if (editFonts[k]?.trim()) fontPayload[k] = editFonts[k];\n        }\n        updates.fonts = fontPayload;\n      }\n\n      await updateTheme(updates as Parameters<typeof updateTheme>[0]);\n      setEditing(false);\n\n      // If name changed, the slug changed server-side — redirect\n      if (editName !== theme.name) {\n        const newSlug = slugify(editName);\n        router.push(`/theme/${newSlug}`);\n      }\n    } catch (err) {\n      setSaveError(err instanceof Error ? err.message : \"Failed to save\");\n    } finally {\n      setSaving(false);\n    }\n  }\n\n  async function handleDelete() {\n    if (!theme) return;\n    setDeleting(true);\n    setDeleteError(null);\n    try {\n      await removeTheme({ id: theme._id });\n      router.push(\"/\");\n    } catch (err) {\n      setDeleteError(err instanceof Error ? err.message : \"Failed to delete\");\n      setDeleting(false);\n    }\n  }\n\n  // Loading state\n  if (theme === undefined) {\n    return (\n      <div className=\"min-h-screen flex items-center justify-center\">\n        <div className=\"animate-pulse text-gray-400 text-lg\">\n          Loading theme...\n        </div>\n      </div>\n    );\n  }\n\n  // Not found\n  if (theme === null) {\n    return (\n      <div className=\"min-h-screen flex flex-col items-center justify-center gap-4\">\n        <h1 className=\"text-2xl font-bold text-gray-800\">Theme not found</h1>\n        <p className=\"text-gray-500\">\n          This theme doesn&apos;t exist or is private.\n        </p>\n        <a href=\"/\" className=\"text-blue-600 hover:underline text-sm\">\n          Back to gallery\n        </a>\n      </div>\n    );\n  }\n\n  const colors = editing\n    ? (editColors as Record<string, string | undefined>)\n    : (theme.colors as Record<string, string | undefined>);\n\n  async function handleToggleStar() {\n    if (!theme || !currentUser) return;\n    await toggleStar({ themeId: theme._id });\n  }\n\n  async function handleSubmitComment(e: React.FormEvent) {\n    e.preventDefault();\n    if (!theme || !commentBody.trim()) return;\n    setSubmittingComment(true);\n    try {\n      await createComment({ themeId: theme._id, body: commentBody.trim() });\n      setCommentBody(\"\");\n    } finally {\n      setSubmittingComment(false);\n    }\n  }\n\n  async function handleFork() {\n    if (!theme) return;\n    setForking(true);\n    try {\n      const result = await forkTheme({ id: theme._id });\n      if (result) {\n        router.push(`/theme/${result.slug}`);\n      }\n    } catch {\n      // Fork may fail if not authenticated\n    } finally {\n      setForking(false);\n    }\n  }\n\n  return (\n    <div className=\"min-h-screen bg-gray-50\">\n      {/* Header */}\n      <header className=\"bg-white border-b border-gray-200\">\n        <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n          <a\n            href=\"/\"\n            className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n          >\n            ThemeDrops\n          </a>\n          <div className=\"flex items-center gap-3\">\n            <CreateThemeLink />\n            <AuthControls />\n          </div>\n        </div>\n      </header>\n\n      <main className=\"max-w-4xl mx-auto px-6 py-10 space-y-10\">\n        {/* Theme header */}\n        <div className=\"space-y-3\">\n          <div className=\"flex items-start justify-between gap-4\">\n            <div className=\"space-y-1 flex-1\">\n              {editing ? (\n                <input\n                  type=\"text\"\n                  value={editName}\n                  onChange={(e) => setEditName(e.target.value)}\n                  className=\"text-3xl font-bold text-gray-900 w-full border border-gray-300 rounded-lg px-3 py-1 focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                />\n              ) : (\n                <h1 className=\"text-3xl font-bold text-gray-900\">\n                  {theme.name}\n                </h1>\n              )}\n              {author && (\n                <p className=\"text-sm text-gray-500\">\n                  by{\" \"}\n                  <span className=\"font-medium text-gray-700\">\n                    {author.displayName ?? author.username}\n                  </span>\n                </p>\n              )}\n            </div>\n\n            <div className=\"flex items-center gap-2\">\n              {/* Owner controls */}\n              {isOwner && !editing && (\n                <>\n                  <button\n                    onClick={enterEditMode}\n                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors\"\n                  >\n                    Edit\n                  </button>\n                  {!confirmingDelete ? (\n                    <button\n                      onClick={() => setConfirmingDelete(true)}\n                      className=\"px-4 py-2 rounded-lg border border-red-200 bg-white text-sm font-medium text-red-600 hover:bg-red-50 transition-colors\"\n                    >\n                      Delete\n                    </button>\n                  ) : (\n                    <div className=\"flex items-center gap-2 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n                      <span className=\"text-sm text-red-700\">Delete this theme?</span>\n                      <button\n                        onClick={handleDelete}\n                        disabled={deleting}\n                        className=\"px-3 py-1 rounded bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition-colors disabled:opacity-50\"\n                      >\n                        {deleting ? \"Deleting...\" : \"Confirm\"}\n                      </button>\n                      <button\n                        onClick={() => {\n                          setConfirmingDelete(false);\n                          setDeleteError(null);\n                        }}\n                        disabled={deleting}\n                        className=\"px-3 py-1 rounded border border-red-200 text-sm text-red-600 hover:bg-red-100 transition-colors disabled:opacity-50\"\n                      >\n                        Cancel\n                      </button>\n                    </div>\n                  )}\n                </>\n              )}\n\n              {/* Edit mode controls */}\n              {editing && (\n                <>\n                  <button\n                    onClick={handleSave}\n                    disabled={saving || !editName.trim()}\n                    className=\"px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n                  >\n                    {saving ? \"Saving...\" : \"Save\"}\n                  </button>\n                  <button\n                    onClick={cancelEdit}\n                    disabled={saving}\n                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50\"\n                  >\n                    Cancel\n                  </button>\n                </>\n              )}\n\n              {/* Star button */}\n              {!editing && (\n                <button\n                  onClick={handleToggleStar}\n                  disabled={!currentUser}\n                  className={`flex items-center gap-1.5 px-4 py-2 rounded-lg border text-sm font-medium transition-colors ${\n                    isStarred\n                      ? \"bg-yellow-50 border-yellow-300 text-yellow-700\"\n                      : \"bg-white border-gray-200 text-gray-600 hover:bg-gray-50\"\n                  } ${!currentUser ? \"opacity-50 cursor-not-allowed\" : \"cursor-pointer\"}`}\n                  title={!currentUser ? \"Sign in to star themes\" : undefined}\n                >\n                  <span className=\"text-lg\">\n                    {isStarred ? \"\\u2605\" : \"\\u2606\"}\n                  </span>\n                  <span>{theme.starCount}</span>\n                </button>\n              )}\n            </div>\n          </div>\n\n          {/* Delete error */}\n          {deleteError && (\n            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n              {deleteError}\n            </p>\n          )}\n\n          {/* Save error */}\n          {saveError && (\n            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n              {saveError}\n            </p>\n          )}\n\n          {/* Description */}\n          {editing ? (\n            <textarea\n              value={editDescription}\n              onChange={(e) => setEditDescription(e.target.value)}\n              placeholder=\"Theme description...\"\n              rows={3}\n              className=\"w-full text-gray-600 leading-relaxed border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n            />\n          ) : (\n            theme.description && (\n              <p className=\"text-gray-600 leading-relaxed\">\n                {theme.description}\n              </p>\n            )\n          )}\n\n          {/* Visibility toggle */}\n          {editing && (\n            <div className=\"flex items-center gap-3\">\n              <span className=\"text-sm text-gray-600\">Visibility:</span>\n              <button\n                onClick={() => setEditIsPublic(!editIsPublic)}\n                className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${\n                  editIsPublic ? \"bg-blue-600\" : \"bg-gray-300\"\n                }`}\n              >\n                <span\n                  className={`inline-block h-4 w-4 rounded-full bg-white transition-transform ${\n                    editIsPublic ? \"translate-x-6\" : \"translate-x-1\"\n                  }`}\n                />\n              </button>\n              <span className=\"text-sm text-gray-500\">\n                {editIsPublic ? \"Public\" : \"Private\"}\n              </span>\n            </div>\n          )}\n\n          {theme.forkedFromId && forkedFrom && (\n            <p className=\"text-sm text-gray-400 italic\">\n              Forked from{\" \"}\n              <a\n                href={`/theme/${forkedFrom.slug}`}\n                className=\"text-blue-500 hover:underline\"\n              >\n                {forkedFrom.name}\n              </a>\n            </p>\n          )}\n\n          {!editing && (\n            <p className=\"text-xs text-gray-400 font-mono bg-gray-100 inline-block px-2 py-1 rounded\">\n              API: /api/theme/{theme.slug}\n            </p>\n          )}\n        </div>\n\n        {/* Color palette */}\n        <section className=\"space-y-4\">\n          <h2 className=\"text-lg font-semibold text-gray-800\">Color Palette</h2>\n          <div className=\"flex flex-wrap gap-6\">\n            {editing\n              ? COLOR_LABELS.map(({ key, label }) => (\n                  <EditableColorSwatch\n                    key={key}\n                    color={editColors[key] ?? \"#000000\"}\n                    label={label}\n                    onChange={(value) =>\n                      setEditColors((prev) => ({ ...prev, [key]: value }))\n                    }\n                  />\n                ))\n              : COLOR_LABELS.map(({ key, label }) => {\n                  const color = colors[key];\n                  if (!color) return null;\n                  return <ColorSwatch key={key} color={color} label={label} />;\n                })}\n          </div>\n        </section>\n\n        {/* Live preview */}\n        <section className=\"space-y-4\">\n          <h2 className=\"text-lg font-semibold text-gray-800\">Preview</h2>\n          <LivePreview colors={colors} />\n        </section>\n\n        {/* Fonts */}\n        {editing ? (\n          <section className=\"space-y-4\">\n            <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n            <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n              {FONT_KEYS.map((k) => (\n                <div\n                  key={k}\n                  className=\"bg-white rounded-lg border border-gray-200 p-4\"\n                >\n                  <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                    {k}\n                  </p>\n                  <input\n                    type=\"text\"\n                    value={editFonts[k] ?? \"\"}\n                    onChange={(e) =>\n                      setEditFonts((prev) => ({ ...prev, [k]: e.target.value }))\n                    }\n                    placeholder={`${k} font name`}\n                    className=\"w-full text-sm border border-gray-200 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n                  />\n                  {editFonts[k] && (\n                    <p\n                      className=\"text-sm text-gray-500 mt-2\"\n                      style={{ fontFamily: editFonts[k] }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  )}\n                </div>\n              ))}\n            </div>\n          </section>\n        ) : (\n          theme.fonts &&\n          (theme.fonts.sans || theme.fonts.serif || theme.fonts.mono) && (\n            <section className=\"space-y-4\">\n              <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n                {theme.fonts.sans && (\n                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                      Sans\n                    </p>\n                    <p\n                      className=\"text-lg\"\n                      style={{ fontFamily: theme.fonts.sans }}\n                    >\n                      {theme.fonts.sans}\n                    </p>\n                    <p\n                      className=\"text-sm text-gray-500 mt-1\"\n                      style={{ fontFamily: theme.fonts.sans }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  </div>\n                )}\n                {theme.fonts.serif && (\n                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                      Serif\n                    </p>\n                    <p\n                      className=\"text-lg\"\n                      style={{ fontFamily: theme.fonts.serif }}\n                    >\n                      {theme.fonts.serif}\n                    </p>\n                    <p\n                      className=\"text-sm text-gray-500 mt-1\"\n                      style={{ fontFamily: theme.fonts.serif }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  </div>\n                )}\n                {theme.fonts.mono && (\n                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                      Mono\n                    </p>\n                    <p\n                      className=\"text-lg font-mono\"\n                      style={{ fontFamily: theme.fonts.mono }}\n                    >\n                      {theme.fonts.mono}\n                    </p>\n                    <p\n                      className=\"text-sm text-gray-500 mt-1\"\n                      style={{ fontFamily: theme.fonts.mono }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  </div>\n                )}\n              </div>\n            </section>\n          )\n        )}\n\n        {/* Fork button */}\n        {currentUser && !editing && (\n          <div>\n            <button\n              onClick={handleFork}\n              disabled={forking}\n              className=\"px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors disabled:opacity-50\"\n            >\n              {forking ? \"Forking...\" : \"Fork this theme\"}\n            </button>\n          </div>\n        )}\n\n        {/* Comments */}\n        {!editing && (\n          <section className=\"space-y-6\">\n            <h2 className=\"text-lg font-semibold text-gray-800\">\n              Comments{\" \"}\n              {comments && comments.length > 0 && (\n                <span className=\"text-gray-400 font-normal\">\n                  ({comments.length})\n                </span>\n              )}\n            </h2>\n\n            {comments === undefined && (\n              <p className=\"text-gray-400 text-sm animate-pulse\">\n                Loading comments...\n              </p>\n            )}\n\n            {comments && comments.length === 0 && (\n              <p className=\"text-gray-400 text-sm\">No comments yet.</p>\n            )}\n\n            {comments && comments.length > 0 && (\n              <div className=\"space-y-4\">\n                {comments.map((comment) => (\n                  <div\n                    key={comment._id}\n                    className=\"bg-white rounded-lg border border-gray-200 p-4\"\n                  >\n                    <div className=\"flex items-center gap-2 mb-2\">\n                      {comment.author?.avatarUrl && (\n                        <img\n                          src={comment.author.avatarUrl}\n                          alt=\"\"\n                          className=\"w-6 h-6 rounded-full\"\n                        />\n                      )}\n                      <span className=\"text-sm font-medium text-gray-700\">\n                        {comment.author?.displayName ??\n                          comment.author?.username ??\n                          \"Unknown\"}\n                      </span>\n                    </div>\n                    <p className=\"text-sm text-gray-600\">{comment.body}</p>\n                  </div>\n                ))}\n              </div>\n            )}\n\n            {/* Add comment form */}\n            {currentUser && (\n              <form onSubmit={handleSubmitComment} className=\"flex gap-3\">\n                <input\n                  type=\"text\"\n                  value={commentBody}\n                  onChange={(e) => setCommentBody(e.target.value)}\n                  placeholder=\"Add a comment...\"\n                  className=\"flex-1 px-4 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n                />\n                <button\n                  type=\"submit\"\n                  disabled={!commentBody.trim() || submittingComment}\n                  className=\"px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n                >\n                  {submittingComment ? \"Posting...\" : \"Post\"}\n                </button>\n              </form>\n            )}\n          </section>\n        )}\n      </main>\n    </div>\n  );\n}\n","numLines":747,"startLine":1,"totalLines":747}}}
