{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LeBo28vV9hGWeLKaLrzj78","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { useParams, useRouter } from \"next/navigation\";\n     4→import { useQuery, useMutation } from \"convex/react\";\n     5→import { api } from \"../../../../convex/_generated/api\";\n     6→import { useState } from \"react\";\n     7→import AuthControls from \"../../components/AuthControls\";\n     8→import CreateThemeLink from \"../../components/CreateThemeLink\";\n     9→\n    10→const COLOR_LABELS: { key: string; label: string }[] = [\n    11→  { key: \"background\", label: \"Background\" },\n    12→  { key: \"foreground\", label: \"Foreground\" },\n    13→  { key: \"primary\", label: \"Primary\" },\n    14→  { key: \"secondary\", label: \"Secondary\" },\n    15→  { key: \"accent\", label: \"Accent\" },\n    16→  { key: \"muted\", label: \"Muted\" },\n    17→];\n    18→\n    19→const FONT_KEYS = [\"sans\", \"serif\", \"mono\"] as const;\n    20→\n    21→function ColorSwatch({ color, label }: { color: string; label: string }) {\n    22→  return (\n    23→    <div className=\"flex flex-col items-center gap-2\">\n    24→      <div\n    25→        className=\"w-16 h-16 rounded-xl border border-gray-200 shadow-sm\"\n    26→        style={{ backgroundColor: color }}\n    27→      />\n    28→      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n    29→      <span className=\"text-xs font-mono text-gray-400\">{color}</span>\n    30→    </div>\n    31→  );\n    32→}\n    33→\n    34→function EditableColorSwatch({\n    35→  color,\n    36→  label,\n    37→  onChange,\n    38→}: {\n    39→  color: string;\n    40→  label: string;\n    41→  onChange: (value: string) => void;\n    42→}) {\n    43→  return (\n    44→    <div className=\"flex flex-col items-center gap-2\">\n    45→      <label className=\"relative w-16 h-16 rounded-xl border border-gray-200 shadow-sm cursor-pointer overflow-hidden\">\n    46→        <div\n    47→          className=\"absolute inset-0\"\n    48→          style={{ backgroundColor: color }}\n    49→        />\n    50→        <input\n    51→          type=\"color\"\n    52→          value={color}\n    53→          onChange={(e) => onChange(e.target.value)}\n    54→          className=\"absolute inset-0 opacity-0 cursor-pointer\"\n    55→        />\n    56→      </label>\n    57→      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n    58→      <input\n    59→        type=\"text\"\n    60→        value={color}\n    61→        onChange={(e) => onChange(e.target.value)}\n    62→        className=\"text-xs font-mono text-gray-600 w-20 text-center border border-gray-200 rounded px-1 py-0.5 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n    63→      />\n    64→    </div>\n    65→  );\n    66→}\n    67→\n    68→function LivePreview({\n    69→  colors,\n    70→}: {\n    71→  colors: Record<string, string | undefined>;\n    72→}) {\n    73→  return (\n    74→    <div\n    75→      className=\"rounded-xl border p-6 space-y-4\"\n    76→      style={{\n    77→        backgroundColor: colors.background ?? \"#ffffff\",\n    78→        color: colors.foreground ?? \"#000000\",\n    79→        borderColor: colors.muted ?? \"#e5e7eb\",\n    80→      }}\n    81→    >\n    82→      <h3 className=\"text-lg font-semibold\">Live Preview</h3>\n    83→      <p style={{ color: colors.muted ?? \"#6b7280\" }} className=\"text-sm\">\n    84→        This is how the theme looks when applied to a card.\n    85→      </p>\n    86→      <div className=\"flex gap-3\">\n    87→        <button\n    88→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    89→          style={{ backgroundColor: colors.primary ?? \"#3b82f6\" }}\n    90→        >\n    91→          Primary\n    92→        </button>\n    93→        <button\n    94→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    95→          style={{ backgroundColor: colors.secondary ?? \"#6366f1\" }}\n    96→        >\n    97→          Secondary\n    98→        </button>\n    99→        <button\n   100→          className=\"px-4 py-2 rounded-lg text-sm font-medium border\"\n   101→          style={{\n   102→            backgroundColor: colors.accent ?? \"#f59e0b\",\n   103→            borderColor: colors.muted ?? \"#e5e7eb\",\n   104→          }}\n   105→        >\n   106→          Accent\n   107→        </button>\n   108→      </div>\n   109→    </div>\n   110→  );\n   111→}\n   112→\n   113→function slugify(name: string): string {\n   114→  return name\n   115→    .toLowerCase()\n   116→    .trim()\n   117→    .replace(/[^a-z0-9]+/g, \"-\")\n   118→    .replace(/^-|-$/g, \"\");\n   119→}\n   120→\n   121→export default function ThemeDetailPage() {\n   122→  const params = useParams<{ slug: string }>();\n   123→  const router = useRouter();\n   124→  const slug = params.slug;\n   125→\n   126→  const theme = useQuery(api.themes.getBySlug, { slug });\n   127→  const author = useQuery(\n   128→    api.users.get,\n   129→    theme ? { id: theme.authorId } : \"skip\"\n   130→  );\n   131→  const currentUser = useQuery(api.users.getCurrentUser);\n   132→\n   133→  // Stars\n   134→  const isStarred = useQuery(\n   135→    api.stars.isStarred,\n   136→    theme ? { themeId: theme._id } : \"skip\"\n   137→  );\n   138→  const toggleStar = useMutation(api.stars.toggle);\n   139→\n   140→  // Comments\n   141→  const comments = useQuery(\n   142→    api.comments.listByTheme,\n   143→    theme ? { themeId: theme._id } : \"skip\"\n   144→  );\n   145→  const createComment = useMutation(api.comments.create);\n   146→  const [commentBody, setCommentBody] = useState(\"\");\n   147→  const [submittingComment, setSubmittingComment] = useState(false);\n   148→\n   149→  // Fork\n   150→  const forkTheme = useMutation(api.themes.fork);\n   151→  const [forking, setForking] = useState(false);\n   152→\n   153→  // Forked-from theme info (for link)\n   154→  const forkedFrom = useQuery(\n   155→    api.themes.getBasicInfo,\n   156→    theme?.forkedFromId ? { id: theme.forkedFromId } : \"skip\"\n   157→  );\n   158→\n   159→  // Edit/Delete mutations\n   160→  const updateTheme = useMutation(api.themes.update);\n   161→  const removeTheme = useMutation(api.themes.remove);\n   162→\n   163→  // Edit mode state\n   164→  const [editing, setEditing] = useState(false);\n   165→  const [editName, setEditName] = useState(\"\");\n   166→  const [editDescription, setEditDescription] = useState(\"\");\n   167→  const [editIsPublic, setEditIsPublic] = useState(true);\n   168→  const [editColors, setEditColors] = useState<Record<string, string>>({});\n   169→  const [editFonts, setEditFonts] = useState<Record<string, string>>({});\n   170→  const [saving, setSaving] = useState(false);\n   171→  const [saveError, setSaveError] = useState<string | null>(null);\n   172→\n   173→  // Delete state\n   174→  const [confirmingDelete, setConfirmingDelete] = useState(false);\n   175→  const [deleting, setDeleting] = useState(false);\n   176→  const [deleteError, setDeleteError] = useState<string | null>(null);\n   177→\n   178→  // Owner detection\n   179→  const isOwner = !!(currentUser && theme && currentUser._id === theme.authorId);\n   180→\n   181→  function enterEditMode() {\n   182→    if (!theme) return;\n   183→    setEditName(theme.name);\n   184→    setEditDescription(theme.description ?? \"\");\n   185→    setEditIsPublic(theme.isPublic);\n   186→    const c: Record<string, string> = {};\n   187→    const themeColors = theme.colors as Record<string, string | undefined>;\n   188→    for (const { key } of COLOR_LABELS) {\n   189→      if (themeColors[key]) c[key] = themeColors[key]!;\n   190→    }\n   191→    setEditColors(c);\n   192→    const f: Record<string, string> = {};\n   193→    if (theme.fonts) {\n   194→      for (const k of FONT_KEYS) {\n   195→        if (theme.fonts[k]) f[k] = theme.fonts[k]!;\n   196→      }\n   197→    }\n   198→    setEditFonts(f);\n   199→    setSaveError(null);\n   200→    setEditing(true);\n   201→  }\n   202→\n   203→  function cancelEdit() {\n   204→    setEditing(false);\n   205→    setSaveError(null);\n   206→  }\n   207→\n   208→  async function handleSave() {\n   209→    if (!theme) return;\n   210→    setSaving(true);\n   211→    setSaveError(null);\n   212→    try {\n   213→      const updates: Record<string, unknown> = { id: theme._id };\n   214→      if (editName !== theme.name) updates.name = editName;\n   215→      if (editDescription !== (theme.description ?? \"\"))\n   216→        updates.description = editDescription;\n   217→      if (editIsPublic !== theme.isPublic) updates.isPublic = editIsPublic;\n   218→\n   219→      // Colors: always send all edited colors\n   220→      const origColors = theme.colors as Record<string, string | undefined>;\n   221→      const colorsChanged = COLOR_LABELS.some(\n   222→        ({ key }) => (editColors[key] ?? \"\") !== (origColors[key] ?? \"\")\n   223→      );\n   224→      if (colorsChanged) updates.colors = editColors;\n   225→\n   226→      // Fonts: send if changed\n   227→      const origFonts = (theme.fonts ?? {}) as Record<string, string | undefined>;\n   228→      const fontsChanged = FONT_KEYS.some(\n   229→        (k) => (editFonts[k] ?? \"\") !== (origFonts[k] ?? \"\")\n   230→      );\n   231→      if (fontsChanged) {\n   232→        const fontPayload: Record<string, string> = {};\n   233→        for (const k of FONT_KEYS) {\n   234→          if (editFonts[k]?.trim()) fontPayload[k] = editFonts[k];\n   235→        }\n   236→        updates.fonts = fontPayload;\n   237→      }\n   238→\n   239→      await updateTheme(updates as Parameters<typeof updateTheme>[0]);\n   240→      setEditing(false);\n   241→\n   242→      // If name changed, the slug changed server-side — redirect\n   243→      if (editName !== theme.name) {\n   244→        const newSlug = slugify(editName);\n   245→        router.push(`/theme/${newSlug}`);\n   246→      }\n   247→    } catch (err) {\n   248→      setSaveError(err instanceof Error ? err.message : \"Failed to save\");\n   249→    } finally {\n   250→      setSaving(false);\n   251→    }\n   252→  }\n   253→\n   254→  async function handleDelete() {\n   255→    if (!theme) return;\n   256→    setDeleting(true);\n   257→    setDeleteError(null);\n   258→    try {\n   259→      await removeTheme({ id: theme._id });\n   260→      router.push(\"/\");\n   261→    } catch (err) {\n   262→      setDeleteError(err instanceof Error ? err.message : \"Failed to delete\");\n   263→      setDeleting(false);\n   264→    }\n   265→  }\n   266→\n   267→  // Loading state\n   268→  if (theme === undefined) {\n   269→    return (\n   270→      <div className=\"min-h-screen flex items-center justify-center\">\n   271→        <div className=\"animate-pulse text-gray-400 text-lg\">\n   272→          Loading theme...\n   273→        </div>\n   274→      </div>\n   275→    );\n   276→  }\n   277→\n   278→  // Not found\n   279→  if (theme === null) {\n   280→    return (\n   281→      <div className=\"min-h-screen flex flex-col items-center justify-center gap-4\">\n   282→        <h1 className=\"text-2xl font-bold text-gray-800\">Theme not found</h1>\n   283→        <p className=\"text-gray-500\">\n   284→          This theme doesn&apos;t exist or is private.\n   285→        </p>\n   286→        <a href=\"/\" className=\"text-blue-600 hover:underline text-sm\">\n   287→          Back to gallery\n   288→        </a>\n   289→      </div>\n   290→    );\n   291→  }\n   292→\n   293→  const colors = editing\n   294→    ? (editColors as Record<string, string | undefined>)\n   295→    : (theme.colors as Record<string, string | undefined>);\n   296→\n   297→  async function handleToggleStar() {\n   298→    if (!theme || !currentUser) return;\n   299→    await toggleStar({ themeId: theme._id });\n   300→  }\n   301→\n   302→  async function handleSubmitComment(e: React.FormEvent) {\n   303→    e.preventDefault();\n   304→    if (!theme || !commentBody.trim()) return;\n   305→    setSubmittingComment(true);\n   306→    try {\n   307→      await createComment({ themeId: theme._id, body: commentBody.trim() });\n   308→      setCommentBody(\"\");\n   309→    } finally {\n   310→      setSubmittingComment(false);\n   311→    }\n   312→  }\n   313→\n   314→  async function handleFork() {\n   315→    if (!theme) return;\n   316→    setForking(true);\n   317→    try {\n   318→      const result = await forkTheme({ id: theme._id });\n   319→      if (result) {\n   320→        router.push(`/theme/${result.slug}`);\n   321→      }\n   322→    } catch {\n   323→      // Fork may fail if not authenticated\n   324→    } finally {\n   325→      setForking(false);\n   326→    }\n   327→  }\n   328→\n   329→  return (\n   330→    <div className=\"min-h-screen bg-gray-50\">\n   331→      {/* Header */}\n   332→      <header className=\"bg-white border-b border-gray-200\">\n   333→        <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n   334→          <a\n   335→            href=\"/\"\n   336→            className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n   337→          >\n   338→            ThemeDrops\n   339→          </a>\n   340→          <div className=\"flex items-center gap-3\">\n   341→            <CreateThemeLink />\n   342→            <AuthControls />\n   343→          </div>\n   344→        </div>\n   345→      </header>\n   346→\n   347→      <main className=\"max-w-4xl mx-auto px-6 py-10 space-y-10\">\n   348→        {/* Theme header */}\n   349→        <div className=\"space-y-3\">\n   350→          <div className=\"flex items-start justify-between gap-4\">\n   351→            <div className=\"space-y-1 flex-1\">\n   352→              {editing ? (\n   353→                <input\n   354→                  type=\"text\"\n   355→                  value={editName}\n   356→                  onChange={(e) => setEditName(e.target.value)}\n   357→                  className=\"text-3xl font-bold text-gray-900 w-full border border-gray-300 rounded-lg px-3 py-1 focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   358→                />\n   359→              ) : (\n   360→                <h1 className=\"text-3xl font-bold text-gray-900\">\n   361→                  {theme.name}\n   362→                </h1>\n   363→              )}\n   364→              {author && (\n   365→                <p className=\"text-sm text-gray-500\">\n   366→                  by{\" \"}\n   367→                  <span className=\"font-medium text-gray-700\">\n   368→                    {author.displayName ?? author.username}\n   369→                  </span>\n   370→                </p>\n   371→              )}\n   372→            </div>\n   373→\n   374→            <div className=\"flex items-center gap-2\">\n   375→              {/* Owner controls */}\n   376→              {isOwner && !editing && (\n   377→                <>\n   378→                  <button\n   379→                    onClick={enterEditMode}\n   380→                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors\"\n   381→                  >\n   382→                    Edit\n   383→                  </button>\n   384→                  {!confirmingDelete ? (\n   385→                    <button\n   386→                      onClick={() => setConfirmingDelete(true)}\n   387→                      className=\"px-4 py-2 rounded-lg border border-red-200 bg-white text-sm font-medium text-red-600 hover:bg-red-50 transition-colors\"\n   388→                    >\n   389→                      Delete\n   390→                    </button>\n   391→                  ) : (\n   392→                    <div className=\"flex