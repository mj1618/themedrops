{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RX1Ucm41QTdS1oEwHK5vnM","type":"tool_result","content":"     1→import { v } from \"convex/values\";\n     2→import { query, mutation, DatabaseReader } from \"./_generated/server\";\n     3→import { paginationOptsValidator } from \"convex/server\";\n     4→\n     5→export const list = query({\n     6→  args: { paginationOpts: paginationOptsValidator },\n     7→  handler: async (ctx, args) => {\n     8→    return await ctx.db\n     9→      .query(\"themes\")\n    10→      .withIndex(\"by_public_and_star_count\", (q) => q.eq(\"isPublic\", true))\n    11→      .order(\"desc\")\n    12→      .paginate(args.paginationOpts);\n    13→  },\n    14→});\n    15→\n    16→export const getBySlug = query({\n    17→  args: { slug: v.string() },\n    18→  handler: async (ctx, args) => {\n    19→    const theme = await ctx.db\n    20→      .query(\"themes\")\n    21→      .withIndex(\"by_slug\", (q) => q.eq(\"slug\", args.slug))\n    22→      .unique();\n    23→    if (!theme) return null;\n    24→    if (!theme.isPublic) {\n    25→      const identity = await ctx.auth.getUserIdentity();\n    26→      if (!identity) return null;\n    27→      const user = await ctx.db\n    28→        .query(\"users\")\n    29→        .withIndex(\"by_token\", (q) =>\n    30→          q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    31→        )\n    32→        .unique();\n    33→      if (!user || theme.authorId !== user._id) return null;\n    34→    }\n    35→    return theme;\n    36→  },\n    37→});\n    38→\n    39→export const getByAuthor = query({\n    40→  args: { authorId: v.id(\"users\") },\n    41→  handler: async (ctx, args) => {\n    42→    const identity = await ctx.auth.getUserIdentity();\n    43→    let currentUserId = null;\n    44→    if (identity) {\n    45→      const user = await ctx.db\n    46→        .query(\"users\")\n    47→        .withIndex(\"by_token\", (q) =>\n    48→          q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    49→        )\n    50→        .unique();\n    51→      if (user) currentUserId = user._id;\n    52→    }\n    53→\n    54→    const themes = await ctx.db\n    55→      .query(\"themes\")\n    56→      .withIndex(\"by_author\", (q) => q.eq(\"authorId\", args.authorId))\n    57→      .take(50);\n    58→\n    59→    if (currentUserId === args.authorId) return themes;\n    60→    return themes.filter((t) => t.isPublic);\n    61→  },\n    62→});\n    63→\n    64→export const getBasicInfo = query({\n    65→  args: { id: v.id(\"themes\") },\n    66→  handler: async (ctx, args) => {\n    67→    const theme = await ctx.db.get(args.id);\n    68→    if (!theme) return null;\n    69→    if (!theme.isPublic) {\n    70→      const identity = await ctx.auth.getUserIdentity();\n    71→      if (!identity) return null;\n    72→      const user = await ctx.db\n    73→        .query(\"users\")\n    74→        .withIndex(\"by_token\", (q) =>\n    75→          q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    76→        )\n    77→        .unique();\n    78→      if (!user || theme.authorId !== user._id) return null;\n    79→    }\n    80→    return { name: theme.name, slug: theme.slug };\n    81→  },\n    82→});\n    83→\n    84→export const search = query({\n    85→  args: { name: v.string() },\n    86→  handler: async (ctx, args) => {\n    87→    const results = await ctx.db\n    88→      .query(\"themes\")\n    89→      .withSearchIndex(\"search_name\", (q) => q.search(\"name\", args.name))\n    90→      .take(40);\n    91→    return results.filter((t) => t.isPublic).slice(0, 20);\n    92→  },\n    93→});\n    94→\n    95→function generateSlug(name: string): string {\n    96→  return name\n    97→    .toLowerCase()\n    98→    .replace(/\\s+/g, \"-\")\n    99→    .replace(/[^a-z0-9-]/g, \"\");\n   100→}\n   101→\n   102→async function uniqueSlug(db: DatabaseReader, name: string): Promise<string> {\n   103→  const base = generateSlug(name);\n   104→  let slug = base;\n   105→  let suffix = 2;\n   106→  while (\n   107→    await db\n   108→      .query(\"themes\")\n   109→      .withIndex(\"by_slug\", (q) => q.eq(\"slug\", slug))\n   110→      .unique()\n   111→  ) {\n   112→    slug = `${base}-${suffix}`;\n   113→    suffix++;\n   114→  }\n   115→  return slug;\n   116→}\n   117→\n   118→export const create = mutation({\n   119→  args: {\n   120→    name: v.string(),\n   121→    description: v.optional(v.string()),\n   122→    isPublic: v.boolean(),\n   123→    colors: v.object({\n   124→      background: v.optional(v.string()),\n   125→      foreground: v.optional(v.string()),\n   126→      primary: v.optional(v.string()),\n   127→      secondary: v.optional(v.string()),\n   128→      accent: v.optional(v.string()),\n   129→      muted: v.optional(v.string()),\n   130→    }),\n   131→    fonts: v.optional(\n   132→      v.object({\n   133→        sans: v.optional(v.string()),\n   134→        serif: v.optional(v.string()),\n   135→        mono: v.optional(v.string()),\n   136→      })\n   137→    ),\n   138→  },\n   139→  handler: async (ctx, args) => {\n   140→    const identity = await ctx.auth.getUserIdentity();\n   141→    if (!identity) throw new Error(\"Not authenticated\");\n   142→\n   143→    const user = await ctx.db\n   144→      .query(\"users\")\n   145→      .withIndex(\"by_token\", (q) =>\n   146→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n   147→      )\n   148→      .unique();\n   149→    if (!user) throw new Error(\"User not found\");\n   150→\n   151→    const slug = await uniqueSlug(ctx.db, args.name);\n   152→\n   153→    const id = await ctx.db.insert(\"themes\", {\n   154→      name: args.name,\n   155→      slug,\n   156→      description: args.description,\n   157→      authorId: user._id,\n   158→      isPublic: args.isPublic,\n   159→      starCount: 0,\n   160→      colors: args.colors,\n   161→      fonts: args.fonts,\n   162→    });\n   163→\n   164→    return { id, slug };\n   165→  },\n   166→});\n   167→\n   168→export const update = mutation({\n   169→  args: {\n   170→    id: v.id(\"themes\"),\n   171→    name: v.optional(v.string()),\n   172→    description: v.optional(v.string()),\n   173→    isPublic: v.optional(v.boolean()),\n   174→    colors: v.optional(\n   175→      v.object({\n   176→        background: v.optional(v.string()),\n   177→        foreground: v.optional(v.string()),\n   178→        primary: v.optional(v.string()),\n   179→        secondary: v.optional(v.string()),\n   180→        accent: v.optional(v.string()),\n   181→        muted: v.optional(v.string()),\n   182→      })\n   183→    ),\n   184→    fonts: v.optional(\n   185→      v.object({\n   186→        sans: v.optional(v.string()),\n   187→        serif: v.optional(v.string()),\n   188→        mono: v.optional(v.string()),\n   189→      })\n   190→    ),\n   191→  },\n   192→  handler: async (ctx, args) => {\n   193→    const identity = await ctx.auth.getUserIdentity();\n   194→    if (!identity) throw new Error(\"Not authenticated\");\n   195→\n   196→    const user = await ctx.db\n   197→      .query(\"users\")\n   198→      .withIndex(\"by_token\", (q) =>\n   199→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n   200→      )\n   201→      .unique();\n   202→    if (!user) throw new Error(\"User not found\");\n   203→\n   204→    const theme = await ctx.db.get(args.id);\n   205→    if (!theme) throw new Error(\"Theme not found\");\n   206→    if (theme.authorId !== user._id) throw new Error(\"Not authorized\");\n   207→\n   208→    const updates: Record<string, unknown> = {};\n   209→    if (args.name !== undefined) {\n   210→      updates.name = args.name;\n   211→      updates.slug = await uniqueSlug(ctx.db, args.name);\n   212→    }\n   213→    if (args.description !== undefined) updates.description = args.description;\n   214→    if (args.isPublic !== undefined) updates.isPublic = args.isPublic;\n   215→    if (args.colors !== undefined) updates.colors = args.colors;\n   216→    if (args.fonts !== undefined) updates.fonts = args.fonts;\n   217→\n   218→    await ctx.db.patch(args.id, updates);\n   219→  },\n   220→});\n   221→\n   222→export const remove = mutation({\n   223→  args: { id: v.id(\"themes\") },\n   224→  handler: async (ctx, args) => {\n   225→    const identity = await ctx.auth.getUserIdentity();\n   226→    if (!identity) throw new Error(\"Not authenticated\");\n   227→\n   228→    const user = await ctx.db\n   229→      .query(\"users\")\n   230→      .withIndex(\"by_token\", (q) =>\n   231→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n   232→      )\n   233→      .unique();\n   234→    if (!user) throw new Error(\"User not found\");\n   235→\n   236→    const theme = await ctx.db.get(args.id);\n   237→    if (!theme) throw new Error(\"Theme not found\");\n   238→    if (theme.authorId !== user._id) throw new Error(\"Not authorized\");\n   239→\n   240→    // Clean up all associated stars\n   241→    let stars;\n   242→    do {\n   243→      stars = await ctx.db\n   244→        .query(\"stars\")\n   245→        .withIndex(\"by_theme\", (q) => q.eq(\"themeId\", args.id))\n   246→        .take(500);\n   247→      for (const star of stars) {\n   248→        await ctx.db.delete(star._id);\n   249→      }\n   250→    } while (stars.length === 500);\n   251→\n   252→    // Clean up all associated comments\n   253→    let comments;\n   254→    do {\n   255→      comments = await ctx.db\n   256→        .query(\"comments\")\n   257→        .withIndex(\"by_theme\", (q) => q.eq(\"themeId\", args.id))\n   258→        .take(500);\n   259→      for (const comment of comments) {\n   260→        await ctx.db.delete(comment._id);\n   261→      }\n   262→    } while (comments.length === 500);\n   263→\n   264→    await ctx.db.delete(args.id);\n   265→  },\n   266→});\n   267→\n   268→export const fork = mutation({\n   269→  args: { id: v.id(\"themes\") },\n   270→  handler: async (ctx, args) => {\n   271→    const identity = await ctx.auth.getUserIdentity();\n   272→    if (!identity) throw new Error(\"Not authenticated\");\n   273→\n   274→    const user = await ctx.db\n   275→      .query(\"users\")\n   276→      .withIndex(\"by_token\", (q) =>\n   277→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n   278→      )\n   279→      .unique();\n   280→    if (!user) throw new Error(\"User not found\");\n   281→\n   282→    const original = await ctx.db.get(args.id);\n   283→    if (!original) throw new Error(\"Theme not found\");\n   284→    if (!original.isPublic && original.authorId !== user._id) {\n   285→      throw new Error(\"Not authorized\");\n   286→    }\n   287→\n   288→    const slug = await uniqueSlug(ctx.db, original.name + \" fork\");\n   289→\n   290→    const id = await ctx.db.insert(\"themes\", {\n   291→      name: original.name + \" (fork)\",\n   292→      slug,\n   293→      description: original.description,\n   294→      authorId: user._id,\n   295→      forkedFromId: original._id,\n   296→      isPublic: false,\n   297→      starCount: 0,\n   298→      colors: original.colors,\n   299→      fonts: original.fonts,\n   300→    });\n   301→\n   302→    return { id, slug };\n   303→  },\n   304→});\n   305→"}]},"parent_tool_use_id":"toolu_017vEa3YZnPDug5fZTfF6vsi","session_id":"ceec0539-6478-4eeb-897f-84ed3b4ac287","uuid":"d84cecef-a4c8-421d-9b80-3ac1da1c4b05","timestamp":"2026-03-27T23:54:20.218Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TG89NM5W3q5tg1jVLSXgUd","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { useParams, useRouter } from \"next/navigation\";\n     4→import { useQuery, useMutation } from \"convex/react\";\n     5→import { api } from \"../../../../convex/_generated/api\";\n     6→import { useState } from \"react\";\n     7→import AuthControls from \"../../components/AuthControls\";\n     8→import CreateThemeLink from \"../../components/CreateThemeLink\";\n     9→\n    10→const COLOR_LABELS: { key: string; label: string }[] = [\n    11→  { key: \"background\", label: \"Background\" },\n    12→  { key: \"foreground\", label: \"Foreground\" },\n    13→  { key: \"primary\", label: \"Primary\" },\n    14→  { key: \"secondary\", label: \"Secondary\" },\n    15→  { key: \"accent\", label: \"Accent\" },\n    16→  { key: \"muted\", label: \"Muted\" },\n    17→];\n    18→\n    19→const FONT_KEYS = [\"sans\", \"serif\", \"mono\"] as const;\n    20→\n    21→function ColorSwatch({ color, label }: { color: string; label: string }) {\n    22→  return (\n    23→    <div className=\"flex flex-col items-center gap-2\">\n    24→      <div\n    25→        className=\"w-16 h-16 rounded-xl border border-gray-200 shadow-sm\"\n    26→        style={{ backgroundColor: color }}\n    27→      />\n    28→      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n    29→      <span className=\"text-xs font-mono text-gray-400\">{color}</span>\n    30→    </div>\n    31→  );\n    32→}\n    33→\n    34→function EditableColorSwatch({\n    35→  color,\n    36→  label,\n    37→  onChange,\n    38→}: {\n    39→  color: string;\n    40→  label: string;\n    41→  onChange: (value: string) => void;\n    42→}) {\n    43→  return (\n    44→    <div className=\"flex flex-col items-center gap-2\">\n    45→      <label className=\"relative w-16 h-16 rounded-xl border border-gray-200 shadow-sm cursor-pointer overflow-hidden\">\n    46→        <div\n    47→          className=\"absolute inset-0\"\n    48→          style={{ backgroundColor: color }}\n    49→        />\n    50→        <input\n    51→          type=\"color\"\n    52→          value={color}\n    53→          onChange={(e) => onChange(e.target.value)}\n    54→          className=\"absolute inset-0 opacity-0 cursor-pointer\"\n    55→        />\n    56→      </label>\n    57→      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n    58→      <input\n    59→        type=\"text\"\n    60→        value={color}\n    61→        onChange={(e) => onChange(e.target.value)}\n    62→        className=\"text-xs font-mono text-gray-600 w-20 text-center border border-gray-200 rounded px-1 py-0.5 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n    63→      />\n    64→    </div>\n    65→  );\n    66→}\n    67→\n    68→function LivePreview({\n    69→  colors,\n    70→}: {\n    71→  colors: Record<string, string | undefined>;\n    72→}) {\n    73→  return (\n    74→    <div\n    75→      className=\"rounded-xl border p-6 space-y-4\"\n    76→      style={{\n    77→        backgroundColor: colors.background ?? \"#ffffff\",\n    78→        color: colors.foreground ?? \"#000000\",\n    79→        borderColor: colors.muted ?? \"#e5e7eb\",\n    80→      }}\n    81→    >\n    82→      <h3 className=\"text-lg font-semibold\">Live Preview</h3>\n    83→      <p style={{ color: colors.muted ?? \"#6b7280\" }} className=\"text-sm\">\n    84→        This is how the theme looks when applied to a card.\n    85→      </p>\n    86→      <div className=\"flex gap-3\">\n    87→        <button\n    88→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    89→          style={{ backgroundColor: colors.primary ?? \"#3b82f6\" }}\n    90→        >\n    91→          Primary\n    92→        </button>\n    93→        <button\n    94→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    95→          style={{ backgroundColor: colors.secondary ?? \"#6366f1\" }}\n    96→        >\n    97→          Secondary\n    98→        </button>\n    99→        <button\n   100→          className=\"px-4 py-2 rounded-lg text-sm font-medium border\"\n   101→          style={{\n   102→            backgroundColor: colors.accent ?? \"#f59e0b\",\n   103→            borderColor: colors.muted ?? \"#e5e7eb\",\n   104→          }}\n   105→        >\n   106→          Accent\n   107→        </button>\n   108→      </div>\n   109→    </div>\n   110→  );\n   111→}\n   112→\n   113→function slugify(name: string): string {\n   114→  return name\n   115→    .toLowerCase()\n   116→    .trim()\n   117→    .replace(/[^a-z0-9]+/g, \"-\")\n   118→    .replace(/^-|-$/g, \"\");\n   119→}\n   120→\n   121→export default function ThemeDetailPage() {\n   122→  const params = useParams<{ slug: string }>();\n   123→  const router = useRouter();\n   124→  const slug = params.slug;\n   125→\n   126→  const theme = useQuery(api.themes.getBySlug, { slug });\n   127→  const author = useQuery(\n   128→    api.users.get,\n   129→    theme ? { id: theme.authorId } : \"skip\"\n   130→  );\n   131→  const currentUser = useQuery(api.users.getCurrentUser);\n   132→\n   133→  // Stars\n   134→  const isStarred = useQuery(\n   135→    api.stars.isStarred,\n   136→    theme ? { themeId: theme._id } : \"skip\"\n   137→  );\n   138→  const toggleStar = useMutation(api.stars.toggle);\n   139→\n   140→  // Comments\n   141→  const comments = useQuery(\n   142→    api.comments.listByTheme,\n   143→    theme ? { themeId: theme._id } : \"skip\"\n   144→  );\n   145→  const createComment = useMutation(api.comments.create);\n   146→  const [commentBody, setCommentBody] = useState(\"\");\n   147→  const [submittingComment, setSubmittingComment] = useState(false);\n   148→\n   149→  // Fork\n   150→  const forkTheme = useMutation(api.themes.fork);\n   151→  const [forking, setForking] = useState(false);\n   152→\n   153→  // Forked-from theme info (for link)\n   154→  const forkedFrom = useQuery(\n   155→    api.themes.getBasicInfo,\n   156→    theme?.forkedFromId ? { id: theme.forkedFromId } : \"skip\"\n   157→  );\n   158→\n   159→  // Edit/Delete mutations\n   160→  const updateTheme = useMutation(api.themes.update);\n   161→  const removeTheme = useMutation(api.themes.remove);\n   162→\n   163→  // Edit mode state\n   164→  const [editing, setEditing] = useState(false);\n   165→  const [editName, setEditName] = useState(\"\");\n   166→  const [editDescription, setEditDescription] = useState(\"\");\n   167→  const [editIsPublic, setEditIsPublic] = useState(true);\n   168→  const [editColors, setEditColors] = useState<Record<string, string>>({});\n   169→  const [editFonts, setEditFonts] = useState<Record<string, string>>({});\n   170→  const [saving, setSaving] = useState(false);\n   171→  const [saveError, setSaveError] = useState<string | null>(null);\n   172→\n   173→  // Delete state\n   174→  const [confirmingDelete, setConfirmingDelete] = useState(false);\n   175→  const [deleting, setDeleting] = useState(false);\n   176→  const [deleteError, setDeleteError] = useState<string | null>(null);\n   177→\n   178→  // Owner detection\n   179→  const isOwner = !!(currentUser && theme && currentUser._id === theme.authorId);\n   180→\n   181→  function enterEditMode() {\n   182→    if (!theme) return;\n   183→    setEditName(theme.name);\n   184→    setEditDescription(theme.description ?? \"\");\n   185→    setEditIsPublic(theme.isPublic);\n   186→    const c: Record<string, string> = {};\n   187→    const themeColors = theme.colors as Record<string, string | undefined>;\n   188→    for (const { key } of COLOR_LABELS) {\n   189→      if (themeColors[key]) c[key] = themeColors[key]!;\n   190→    }\n   191→    setEditColors(c);\n   192→    const f: Record<string, string> = {};\n   193→    if (theme.fonts) {\n   194→      for (const k of FONT_KEYS) {\n   195→        if (theme.fonts[k]) f[k] = theme.fonts[k]!;\n   196→      }\n   197→    }\n   198→    setEditFonts(f);\n   199→    setSaveError(null);\n   200→    setEditing(true);\n   201→  }\n   202→\n   203→  function cancelEdit() {\n   204→    setEditing(false);\n   205→    setSaveError(null);\n   206→  }\n   207→\n   208→  async function handleSave() {\n   209→    if (!theme) return;\n   210→    setSaving(true);\n   211→    setSaveError(null);\n   212→    try {\n   213→      const updates: Record<string, unknown> = { id: theme._id };\n   214→      if (editName !== theme.name) updates.name = editName;\n   215→      if (editDescription !== (theme.description ?? \"\"))\n   216→        updates.description = editDescription;\n   217→      if (editIsPublic !== theme.isPublic) updates.isPublic = editIsPublic;\n   218→\n   219→      // Colors: always send all edited colors\n   220→      const origColors = theme.colors as Record<string, string | undefined>;\n   221→      const colorsChanged = COLOR_LABELS.some(\n   222→        ({ key }) => (editColors[key] ?? \"\") !== (origColors[key] ?? \"\")\n   223→      );\n   224→      if (colorsChanged) updates.colors = editColors;\n   225→\n   226→      // Fonts: send if changed\n   227→      const origFonts = (theme.fonts ?? {}) as Record<string, string | undefined>;\n   228→      const fontsChanged = FONT_KEYS.some(\n   229→        (k) => (editFonts[k] ?? \"\") !== (origFonts[k] ?? \"\")\n   230→      );\n   231→      if (fontsChanged) {\n   232→        const fontPayload: Record<string, string> = {};\n   233→        for (const k of FONT_KEYS) {\n   234→          if (editFonts[k]?.trim()) fontPayload[k] = editFonts[k];\n   235→        }\n   236→        updates.fonts = fontPayload;\n   237→      }\n   238→\n   239→      await updateTheme(updates as Parameters<typeof updateTheme>[0]);\n   240→      setEditing(false);\n   241→\n   242→      // If name changed, the slug changed server-side — redirect\n   243→      if (editName !== theme.name) {\n   244→        const newSlug = slugify(editName);\n   245→        router.push(`/theme/${newSlug}`);\n   246→      }\n   247→    } catch (err) {\n   248→      setSaveError(err instanceof Error ? err.message : \"Failed to save\");\n   249→    } finally {\n   250→      setSaving(false);\n   251→    }\n   252→  }\n   253→\n   254→  async function handleDelete() {\n   255→    if (!theme) return;\n   256→    setDeleting(true);\n   257→    setDeleteError(null);\n   258→    try {\n   259→      await removeTheme({ id: theme._id });\n   260→      router.push(\"/\");\n   261→    } catch (err) {\n   262→      setDeleteError(err instanceof Error ? err.message : \"Failed to delete\");\n   263→      setDeleting(false);\n   264→    }\n   265→  }\n   266→\n   267→  // Loading state\n   268→  if (theme === undefined) {\n   269→    return (\n   270→      <div className=\"min-h-screen flex items-center justify-center\">\n   271→        <div className=\"animate-pulse text-gray-400 text-lg\">\n   272→          Loading theme...\n   273→        </div>\n   274→      </div>\n   275→    );\n   276→  }\n   277→\n   278→  // Not found\n   279→  if (theme === null) {\n   280→    return (\n   281→      <div className=\"min-h-screen flex flex-col items-center justify-center gap-4\">\n   282→        <h1 className=\"text-2xl font-bold text-gray-800\">Theme not found</h1>\n   283→        <p className=\"text-gray-500\">\n   284→          This theme doesn&apos;t exist or is private.\n   285→        </p>\n   286→        <a href=\"/\" className=\"text-blue-600 hover:underline text-sm\">\n   287→          Back to gallery\n   288→        </a>\n   289→      </div>\n   290→    );\n   291→  }\n   292→\n   293→  const colors = editing\n   294→    ? (editColors as Record<string, string | undefined>)\n   295→    : (theme.colors as Record<string, string | undefined>);\n   296→\n   297→  async function handleToggleStar() {\n   298→    if (!theme || !currentUser) return;\n   299→    await toggleStar({ themeId: theme._id });\n   300→  }\n   301→\n   302→  async function handleSubmitComment(e: React.FormEvent) {\n   303→    e.preventDefault();\n   304→    if (!theme || !commentBody.trim()) return;\n   305→    setSubmittingComment(true);\n   306→    try {\n   307→      await createComment({ themeId: theme._id, body: commentBody.trim() });\n   308→      setCommentBody(\"\");\n   309→    } finally {\n   310→      setSubmittingComment(false);\n   311→    }\n   312→  }\n   313→\n   314→  async function handleFork() {\n   315→    if (!theme) return;\n   316→    setForking(true);\n   317→    try {\n   318→      const result = await forkTheme({ id: theme._id });\n   319→      if (result) {\n   320→        router.push(`/theme/${result.slug}`);\n   321→      }\n   322→    } catch {\n   323→      // Fork may fail if not authenticated\n   324→    } finally {\n   325→      setForking(false);\n   326→    }\n   327→  }\n   328→\n   329→  return (\n   330→    <div className=\"min-h-screen bg-gray-50\">\n   331→      {/* Header */}\n   332→      <header className=\"bg-white border-b border-gray-200\">\n   333→        <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n   334→          <a\n   335→            href=\"/\"\n   336→            className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n   337→          >\n   338→            ThemeDrops\n   339→          </a>\n   340→          <div className=\"flex items-center gap-3\">\n   341→            <CreateThemeLink />\n   342→            <AuthControls />\n   343→          </div>\n   344→        </div>\n   345→      </header>\n   346→\n   347→      <main className=\"max-w-4xl mx-auto px-6 py-10 space-y-10\">\n   348→        {/* Theme header */}\n   349→        <div className=\"space-y-3\">\n   350→          <div className=\"flex items-start justify-between gap-4\">\n   351→            <div className=\"space-y-1 flex-1\">\n   352→              {editing ? (\n   353→                <input\n   354→                  type=\"text\"\n   355→                  value={editName}\n   356→                  onChange={(e) => setEditName(e.target.value)}\n   357→                  className=\"text-3xl font-bold text-gray-900 w-full border border-gray-300 rounded-lg px-3 py-1 focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   358→                />\n   359→              ) : (\n   360→                <h1 className=\"text-3xl font-bold text-gray-900\">\n   361→                  {theme.name}\n   362→                </h1>\n   363→              )}\n   364→              {author && (\n   365→                <p className=\"text-sm text-gray-500\">\n   366→                  by{\" \"}\n   367→                  <span className=\"font-medium text-gray-700\">\n   368→                    {author.displayName ?? author.username}\n   369→                  </span>\n   370→                </p>\n   371→              )}\n   372→            </div>\n   373→\n   374→            <div className=\"flex items-center gap-2\">\n   375→              {/* Owner controls */}\n   376→              {isOwner && !editing && (\n   377→                <>\n   378→                  <button\n   379→                    onClick={enterEditMode}\n   380→                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors\"\n   381→                  >\n   382→                    Edit\n   383→                  </button>\n   384→                  {!confirmingDelete ? (\n   385→                    <button\n   386→                      onClick={() => setConfirmingDelete(true)}\n   387→                      className=\"px-4 py-2 rounded-lg border border-red-200 bg-white text-sm font-medium text-red-600 hover:bg-red-50 transition-colors\"\n   388→                    >\n   389→                      Delete\n   390→                    </button>\n   391→                  ) : (\n   392→                    <div className=\"flex items-center gap-2 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   393→                      <span className=\"text-sm text-red-700\">Delete this theme?</span>\n   394→                      <button\n   395→                        onClick={handleDelete}\n   396→                        disabled={deleting}\n   397→                        className=\"px-3 py-1 rounded bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition-colors disabled:opacity-50\"\n   398→                      >\n   399→                        {deleting ? \"Deleting...\" : \"Confirm\"}\n   400→                      </button>\n   401→                      <button\n   402→                        onClick={() => {\n   403→                          setConfirmingDelete(false);\n   404→                          setDeleteError(null);\n   405→                        }}\n   406→                        disabled={deleting}\n   407→                        className=\"px-3 py-1 rounded border border-red-200 text-sm text-red-600 hover:bg-red-100 transition-colors disabled:opacity-50\"\n   408→                      >\n   409→                        Cancel\n   410→                      </button>\n   411→                    </div>\n   412→                  )}\n   413→                </>\n   414→              )}\n   415→\n   416→              {/* Edit mode controls */}\n   417→              {editing && (\n   418→                <>\n   419→                  <button\n   420→                    onClick={handleSave}\n   421→                    disabled={saving || !editName.trim()}\n   422→                    className=\"px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n   423→                  >\n   424→                    {saving ? \"Saving...\" : \"Save\"}\n   425→                  </button>\n   426→                  <button\n   427→                    onClick={cancelEdit}\n   428→                    disabled={saving}\n   429→                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50\"\n   430→                  >\n   431→                    Cancel\n   432→                  </button>\n   433→                </>\n   434→              )}\n   435→\n   436→              {/* Star button */}\n   437→              {!editing && (\n   438→                <button\n   439→                  onClick={handleToggleStar}\n   440→                  disabled={!currentUser}\n   441→                  className={`flex items-center gap-1.5 px-4 py-2 rounded-lg border text-sm font-medium transition-colors ${\n   442→                    isStarred\n   443→                      ? \"bg-yellow-50 border-yellow-300 text-yellow-700\"\n   444→                      : \"bg-white border-gray-200 text-gray-600 hover:bg-gray-50\"\n   445→                  } ${!currentUser ? \"opacity-50 cursor-not-allowed\" : \"cursor-pointer\"}`}\n   446→                  title={!currentUser ? \"Sign in to star themes\" : undefined}\n   447→                >\n   448→                  <span className=\"text-lg\">\n   449→                    {isStarred ? \"\\u2605\" : \"\\u2606\"}\n   450→                  </span>\n   451→                  <span>{theme.starCount}</span>\n   452→                </button>\n   453→              )}\n   454→            </div>\n   455→          </div>\n   456→\n   457→          {/* Delete error */}\n   458→          {deleteError && (\n   459→            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   460→              {deleteError}\n   461→            </p>\n   462→          )}\n   463→\n   464→          {/* Save error */}\n   465→          {saveError && (\n   466→            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   467→              {saveError}\n   468→            </p>\n   469→          )}\n   470→\n   471→          {/* Description */}\n   472→          {editing ? (\n   473→            <textarea\n   474→              value={editDescription}\n   475→              onChange={(e) => setEditDescription(e.target.value)}\n   476→              placeholder=\"Theme description...\"\n   477→              rows={3}\n   478→              className=\"w-full text-gray-600 leading-relaxed border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   479→            />\n   480→          ) : (\n   481→            theme.description && (\n   482→              <p className=\"text-gray-600 leading-relaxed\">\n   483→                {theme.description}\n   484→              </p>\n   485→            )\n   486→          )}\n   487→\n   488→          {/* Visibility toggle */}\n   489→          {editing && (\n   490→            <div className=\"flex items-center gap-3\">\n   491→              <span className=\"text-sm text-gray-600\">Visibility:</span>\n   492→              <button\n   493→                onClick={() => setEditIsPublic(!editIsPublic)}\n   494→                className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${\n   495→                  editIsPublic ? \"bg-blue-600\" : \"bg-gray-300\"\n   496→                }`}\n   497→              >\n   498→                <span\n   499→                  className={`inline-block h-4 w-4 rounded-full bg-white transition-transform ${\n   500→                    editIsPublic ? \"translate-x-6\" : \"translate-x-1\"\n   501→                  }`}\n   502→                />\n   503→              </button>\n   504→              <span className=\"text-sm text-gray-500\">\n   505→                {editIsPublic ? \"Public\" : \"Private\"}\n   506→              </span>\n   507→            </div>\n   508→          )}\n   509→\n   510→          {theme.forkedFromId && forkedFrom && (\n   511→            <p className=\"text-sm text-gray-400 italic\">\n   512→              Forked from{\" \"}\n   513→              <a\n   514→                href={`/theme/${forkedFrom.slug}`}\n   515→                className=\"text-blue-500 hover:underline\"\n   516→              >\n   517→                {forkedFrom.name}\n   518→              </a>\n   519→            </p>\n   520→          )}\n   521→\n   522→          {!editing && (\n   523→            <p className=\"text-xs text-gray-400 font-mono bg-gray-100 inline-block px-2 py-1 rounded\">\n   524→              API: /api/theme/{theme.slug}\n   525→            </p>\n   526→          )}\n   527→        </div>\n   528→\n   529→        {/* Color palette */}\n   530→        <section className=\"space-y-4\">\n   531→          <h2 className=\"text-lg font-semibold text-gray-800\">Color Palette</h2>\n   532→          <div className=\"flex flex-wrap gap-6\">\n   533→            {editing\n   534→              ? COLOR_LABELS.map(({ key, label }) => (\n   535→                  <EditableColorSwatch\n   536→                    key={key}\n   537→                    color={editColors[key] ?? \"#000000\"}\n   538→                    label={label}\n   539→                    onChange={(value) =>\n   540→                      setEditColors((prev) => ({ ...prev, [key]: value }))\n   541→                    }\n   542→                  />\n   543→                ))\n   544→              : COLOR_LABELS.map(({ key, label }) => {\n   545→                  const color = colors[key];\n   546→                  if (!color) return null;\n   547→                  return <ColorSwatch key={key} color={color} label={label} />;\n   548→                })}\n   549→          </div>\n   550→        </section>\n   551→\n   552→        {/* Live preview */}\n   553→        <section className=\"space-y-4\">\n   554→          <h2 className=\"text-lg font-semibold text-gray-800\">Preview</h2>\n   555→          <LivePreview colors={colors} />\n   556→        </section>\n   557→\n   558→        {/* Fonts */}\n   559→        {editing ? (\n   560→          <section className=\"space-y-4\">\n   561→            <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   562→            <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   563→              {FONT_KEYS.map((k) => (\n   564→                <div\n   565→                  key={k}\n   566→                  className=\"bg-white rounded-lg border border-gray-200 p-4\"\n   567→                >\n   568→                  <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   569→                    {k}\n   570→                  </p>\n   571→                  <input\n   572→                    type=\"text\"\n   573→                    value={editFonts[k] ?? \"\"}\n   574→                    onChange={(e) =>\n   575→                      setEditFonts((prev) => ({ ...prev, [k]: e.target.value }))\n   576→                    }\n   577→                    placeholder={`${k} font name`}\n   578→                    className=\"w-full text-sm border border-gray-200 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n   579→                  />\n   580→                  {editFonts[k] && (\n   581→                    <p\n   582→                      className=\"text-sm text-gray-500 mt-2\"\n   583→                      style={{ fontFamily: editFonts[k] }}\n   584→                    >\n   585→                      The quick brown fox jumps over the lazy dog.\n   586→                    </p>\n   587→                  )}\n   588→                </div>\n   589→              ))}\n   590→            </div>\n   591→          </section>\n   592→        ) : (\n   593→          theme.fonts &&\n   594→          (theme.fonts.sans || theme.fonts.serif || theme.fonts.mono) && (\n   595→            <section className=\"space-y-4\">\n   596→              <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   597→              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   598→                {theme.fonts.sans && (\n   599→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   600→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   601→                      Sans\n   602→                    </p>\n   603→                    <p\n   604→                      className=\"text-lg\"\n   605→                      style={{ fontFamily: theme.fonts.sans }}\n   606→                    >\n   607→                      {theme.fonts.sans}\n   608→                    </p>\n   609→                    <p\n   610→                      className=\"text-sm text-gray-500 mt-1\"\n   611→                      style={{ fontFamily: theme.fonts.sans }}\n   612→                    >\n   613→                      The quick brown fox jumps over the lazy dog.\n   614→                    </p>\n   615→                  </div>\n   616→                )}\n   617→                {theme.fonts.serif && (\n   618→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   619→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   620→                      Serif\n   621→                    </p>\n   622→                    <p\n   623→                      className=\"text-lg\"\n   624→                      style={{ fontFamily: theme.fonts.serif }}\n   625→                    >\n   626→                      {theme.fonts.serif}\n   627→                    </p>\n   628→                    <p\n   629→                      className=\"text-sm text-gray-500 mt-1\"\n   630→                      style={{ fontFamily: theme.fonts.serif }}\n   631→                    >\n   632→                      The quick brown fox jumps over the lazy dog.\n   633→                    </p>\n   634→                  </div>\n   635→                )}\n   636→                {theme.fonts.mono && (\n   637→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   638→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   639→                      Mono\n   640→                    </p>\n   641→                    <p\n   642→                      className=\"text-lg font-mono\"\n   643→                      style={{ fontFamily: theme.fonts.mono }}\n   644→                    >\n   645→                      {theme.fonts.mono}\n   646→                    </p>\n   647→                    <p\n   648→                      className=\"text-sm text-gray-500 mt-1\"\n   649→                      style={{ fontFamily: theme.fonts.mono }}\n   650→                    >\n   651→                      The quick brown fox jumps over the lazy dog.\n   652→                    </p>\n   653→                  </div>\n   654→                )}\n   655→              </div>\n   656→            </section>\n   657→          )\n   658→        )}\n   659→\n   660→        {/* Fork button */}\n   661→        {currentUser && !editing && (\n   662→          <div>\n   663→            <button\n   664→              onClick={handleFork}\n   665→              disabled={forking}\n   666→              className=\"px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors disabled:opacity-50\"\n   667→            >\n   668→              {forking ? \"Forking...\" : \"Fork this theme\"}\n   669→            </button>\n   670→          </div>\n   671→        )}\n   672→\n   673→        {/* Comments */}\n   674→        {!editing && (\n   675→          <section className=\"space-y-6\">\n   676→            <h2 className=\"text-lg font-semibold text-gray-800\">\n   677→              Comments{\" \"}\n   678→              {comments && comments.length > 0 && (\n   679→                <span className=\"text-gray-400 font-normal\">\n   680→                  ({comments.length})\n   681→                </span>\n   682→              )}\n   683→            </h2>\n   684→\n   685→            {comments === undefined && (\n   686→              <p className=\"text-gray-400 text-sm animate-pulse\">\n   687→                Loading comments...\n   688→              </p>\n   689→            )}\n   690→\n   691→            {comments && comments.length === 0 && (\n   692→              <p className=\"text-gray-400 text-sm\">No comments yet.</p>\n   693→            )}\n   694→\n   695→            {comments && comments.length > 0 && (\n   696→              <div className=\"space-y-4\">\n   697→                {comments.map((comment) => (\n   698→                  <div\n   699→                    key={comment._id}\n   700→                    className=\"bg-white rounded-lg border border-gray-200 p-4\"\n   701→                  >\n   702→                    <div className=\"flex items-center gap-2 mb-2\">\n   703→                      {comment.author?.avatarUrl && (\n   704→                        <img\n   705→                          src={comment.author.avatarUrl}\n   706→                          alt=\"\"\n   707→                          className=\"w-6 h-6 rounded-full\"\n   708→                        />\n   709→                      )}\n   710→                      <span className=\"text-sm font-medium text-gray-700\">\n   711→                        {comment.author?.displayName ??\n   712→                          comment.author?.username ??\n   713→                          \"Unknown\"}\n   714→                      </span>\n   715→                    </div>\n   716→                    <p className=\"text-sm text-gray-600\">{comment.body}</p>\n   717→                  </div>\n   718→                ))}\n   719→              </div>\n   720→            )}\n   721→\n   722→            {/* Add comment form */}\n   723→            {currentUser && (\n   724→              <form onSubmit={handleSubmitComment} className=\"flex gap-3\">\n   725→                <input\n   726→                  type=\"text\"\n   727→                  value={commentBody}\n   728→                  onChange={(e) => setCommentBody(e.target.value)}\n   729→                  placeholder=\"Add a comment...\"\n   730→                  className=\"flex-1 px-4 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n   731→                />\n   732→                <button\n   733→                  type=\"submit\"\n   734→                  disabled={!commentBody.trim() || submittingComment}\n   735→                  className=\"px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n   736→                >\n   737→                  {submittingComment ? \"Posting...\" : \"Post\"}\n   738→                </button>\n   739→              </form>\n   740→            )}\n   741→          </section>\n   742→        )}\n   743→      </main>\n   744→    </div>\n   745→  );\n   746→}\n   747→"}]},"parent_tool_use_id":"toolu_017vEa3YZnPDug5fZTfF6vsi","session_id":"ceec0539-6478-4eeb-897f-84ed3b4ac287","uuid":"3eb80d23-a1d8-417e-8d99-ff5c786c1cce","timestamp":"2026-03-27T23:54:20.682Z"}
