{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EqQ1rP9BLHyudXdchHYpEg","type":"tool_result","content":"     1→import { v } from \"convex/values\";\n     2→import { query, mutation, DatabaseReader } from \"./_generated/server\";\n     3→import { paginationOptsValidator } from \"convex/server\";\n     4→\n     5→export const list = query({\n     6→  args: { paginationOpts: paginationOptsValidator },\n     7→  handler: async (ctx, args) => {\n     8→    return await ctx.db\n     9→      .query(\"themes\")\n    10→      .withIndex(\"by_public_and_star_count\", (q) => q.eq(\"isPublic\", true))\n    11→      .order(\"desc\")\n    12→      .paginate(args.paginationOpts);\n    13→  },\n    14→});\n    15→\n    16→export const getBySlug = query({\n    17→  args: { slug: v.string() },\n    18→  handler: async (ctx, args) => {\n    19→    const theme = await ctx.db\n    20→      .query(\"themes\")\n    21→      .withIndex(\"by_slug\", (q) => q.eq(\"slug\", args.slug))\n    22→      .unique();\n    23→    if (!theme) return null;\n    24→    if (!theme.isPublic) {\n    25→      const identity = await ctx.auth.getUserIdentity();\n    26→      if (!identity) return null;\n    27→      const user = await ctx.db\n    28→        .query(\"users\")\n    29→        .withIndex(\"by_token\", (q) =>\n    30→          q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    31→        )\n    32→        .unique();\n    33→      if (!user || theme.authorId !== user._id) return null;\n    34→    }\n    35→    return theme;\n    36→  },\n    37→});\n    38→\n    39→export const getByAuthor = query({\n    40→  args: { authorId: v.id(\"users\") },\n    41→  handler: async (ctx, args) => {\n    42→    const identity = await ctx.auth.getUserIdentity();\n    43→    let currentUserId = null;\n    44→    if (identity) {\n    45→      const user = await ctx.db\n    46→        .query(\"users\")\n    47→        .withIndex(\"by_token\", (q) =>\n    48→          q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    49→        )\n    50→        .unique();\n    51→      if (user) currentUserId = user._id;\n    52→    }\n    53→\n    54→    const themes = await ctx.db\n    55→      .query(\"themes\")\n    56→      .withIndex(\"by_author\", (q) => q.eq(\"authorId\", args.authorId))\n    57→      .take(50);\n    58→\n    59→    if (currentUserId === args.authorId) return themes;\n    60→    return themes.filter((t) => t.isPublic);\n    61→  },\n    62→});\n    63→\n    64→export const getBasicInfo = query({\n    65→  args: { id: v.id(\"themes\") },\n    66→  handler: async (ctx, args) => {\n    67→    const theme = await ctx.db.get(args.id);\n    68→    if (!theme) return null;\n    69→    if (!theme.isPublic) {\n    70→      const identity = await ctx.auth.getUserIdentity();\n    71→      if (!identity) return null;\n    72→      const user = await ctx.db\n    73→        .query(\"users\")\n    74→        .withIndex(\"by_token\", (q) =>\n    75→          q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    76→        )\n    77→        .unique();\n    78→      if (!user || theme.authorId !== user._id) return null;\n    79→    }\n    80→    return { name: theme.name, slug: theme.slug };\n    81→  },\n    82→});\n    83→\n    84→export const search = query({\n    85→  args: { name: v.string() },\n    86→  handler: async (ctx, args) => {\n    87→    const results = await ctx.db\n    88→      .query(\"themes\")\n    89→      .withSearchIndex(\"search_name\", (q) => q.search(\"name\", args.name))\n    90→      .take(40);\n    91→    return results.filter((t) => t.isPublic).slice(0, 20);\n    92→  },\n    93→});\n    94→\n    95→function generateSlug(name: string): string {\n    96→  return name\n    97→    .toLowerCase()\n    98→    .replace(/\\s+/g, \"-\")\n    99→    .replace(/[^a-z0-9-]/g, \"\");\n   100→}\n   101→\n   102→async function uniqueSlug(\n   103→  db: DatabaseReader,\n   104→  name: string,\n   105→  excludeId?: import(\"./_generated/dataModel\").Id<\"themes\">\n   106→): Promise<string> {\n   107→  const base = generateSlug(name);\n   108→  let slug = base;\n   109→  let suffix = 2;\n   110→  let existing;\n   111→  while (\n   112→    (existing = await db\n   113→      .query(\"themes\")\n   114→      .withIndex(\"by_slug\", (q) => q.eq(\"slug\", slug))\n   115→      .unique()) &&\n   116→    existing._id !== excludeId\n   117→  ) {\n   118→    slug = `${base}-${suffix}`;\n   119→    suffix++;\n   120→  }\n   121→  return slug;\n   122→}\n   123→\n   124→export const create = mutation({\n   125→  args: {\n   126→    name: v.string(),\n   127→    description: v.optional(v.string()),\n   128→    isPublic: v.boolean(),\n   129→    colors: v.object({\n   130→      background: v.optional(v.string()),\n   131→      foreground: v.optional(v.string()),\n   132→      primary: v.optional(v.string()),\n   133→      secondary: v.optional(v.string()),\n   134→      accent: v.optional(v.string()),\n   135→      muted: v.optional(v.string()),\n   136→    }),\n   137→    fonts: v.optional(\n   138→      v.object({\n   139→        sans: v.optional(v.string()),\n   140→        serif: v.optional(v.string()),\n   141→        mono: v.optional(v.string()),\n   142→      })\n   143→    ),\n   144→  },\n   145→  handler: async (ctx, args) => {\n   146→    const identity = await ctx.auth.getUserIdentity();\n   147→    if (!identity) throw new Error(\"Not authenticated\");\n   148→\n   149→    const user = await ctx.db\n   150→      .query(\"users\")\n   151→      .withIndex(\"by_token\", (q) =>\n   152→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n   153→      )\n   154→      .unique();\n   155→    if (!user) throw new Error(\"User not found\");\n   156→\n   157→    const slug = await uniqueSlug(ctx.db, args.name);\n   158→\n   159→    const id = await ctx.db.insert(\"themes\", {\n   160→      name: args.name,\n   161→      slug,\n   162→      description: args.description,\n   163→      authorId: user._id,\n   164→      isPublic: args.isPublic,\n   165→      starCount: 0,\n   166→      colors: args.colors,\n   167→      fonts: args.fonts,\n   168→    });\n   169→\n   170→    return { id, slug };\n   171→  },\n   172→});\n   173→\n   174→export const update = mutation({\n   175→  args: {\n   176→    id: v.id(\"themes\"),\n   177→    name: v.optional(v.string()),\n   178→    description: v.optional(v.string()),\n   179→    isPublic: v.optional(v.boolean()),\n   180→    colors: v.optional(\n   181→      v.object({\n   182→        background: v.optional(v.string()),\n   183→        foreground: v.optional(v.string()),\n   184→        primary: v.optional(v.string()),\n   185→        secondary: v.optional(v.string()),\n   186→        accent: v.optional(v.string()),\n   187→        muted: v.optional(v.string()),\n   188→      })\n   189→    ),\n   190→    fonts: v.optional(\n   191→      v.object({\n   192→        sans: v.optional(v.string()),\n   193→        serif: v.optional(v.string()),\n   194→        mono: v.optional(v.string()),\n   195→      })\n   196→    ),\n   197→  },\n   198→  handler: async (ctx, args) => {\n   199→    const identity = await ctx.auth.getUserIdentity();\n   200→    if (!identity) throw new Error(\"Not authenticated\");\n   201→\n   202→    const user = await ctx.db\n   203→      .query(\"users\")\n   204→      .withIndex(\"by_token\", (q) =>\n   205→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n   206→      )\n   207→      .unique();\n   208→    if (!user) throw new Error(\"User not found\");\n   209→\n   210→    const theme = await ctx.db.get(args.id);\n   211→    if (!theme) throw new Error(\"Theme not found\");\n   212→    if (theme.authorId !== user._id) throw new Error(\"Not authorized\");\n   213→\n   214→    const updates: Record<string, unknown> = {};\n   215→    if (args.name !== undefined) {\n   216→      updates.name = args.name;\n   217→      updates.slug = await uniqueSlug(ctx.db, args.name, args.id);\n   218→    }\n   219→    if (args.description !== undefined) updates.description = args.description;\n   220→    if (args.isPublic !== undefined) updates.isPublic = args.isPublic;\n   221→    if (args.colors !== undefined) updates.colors = args.colors;\n   222→    if (args.fonts !== undefined) updates.fonts = args.fonts;\n   223→\n   224→    await ctx.db.patch(args.id, updates);\n   225→    return { slug: (updates.slug as string) ?? theme.slug };\n   226→  },\n   227→});\n   228→\n   229→export const remove = mutation({\n   230→  args: { id: v.id(\"themes\") },\n   231→  handler: async (ctx, args) => {\n   232→    const identity = await ctx.auth.getUserIdentity();\n   233→    if (!identity) throw new Error(\"Not authenticated\");\n   234→\n   235→    const user = await ctx.db\n   236→      .query(\"users\")\n   237→      .withIndex(\"by_token\", (q) =>\n   238→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n   239→      )\n   240→      .unique();\n   241→    if (!user) throw new Error(\"User not found\");\n   242→\n   243→    const theme = await ctx.db.get(args.id);\n   244→    if (!theme) throw new Error(\"Theme not found\");\n   245→    if (theme.authorId !== user._id) throw new Error(\"Not authorized\");\n   246→\n   247→    // Clean up all associated stars\n   248→    let stars;\n   249→    do {\n   250→      stars = await ctx.db\n   251→        .query(\"stars\")\n   252→        .withIndex(\"by_theme\", (q) => q.eq(\"themeId\", args.id))\n   253→        .take(500);\n   254→      for (const star of stars) {\n   255→        await ctx.db.delete(star._id);\n   256→      }\n   257→    } while (stars.length === 500);\n   258→\n   259→    // Clean up all associated comments\n   260→    let comments;\n   261→    do {\n   262→      comments = await ctx.db\n   263→        .query(\"comments\")\n   264→        .withIndex(\"by_theme\", (q) => q.eq(\"themeId\", args.id))\n   265→        .take(500);\n   266→      for (const comment of comments) {\n   267→        await ctx.db.delete(comment._id);\n   268→      }\n   269→    } while (comments.length === 500);\n   270→\n   271→    await ctx.db.delete(args.id);\n   272→  },\n   273→});\n   274→\n   275→export const fork = mutation({\n   276→  args: { id: v.id(\"themes\") },\n   277→  handler: async (ctx, args) => {\n   278→    const identity = await ctx.auth.getUserIdentity();\n   279→    if (!identity) throw new Error(\"Not authenticated\");\n   280→\n   281→    const user = await ctx.db\n   282→      .query(\"users\")\n   283→      .withIndex(\"by_token\", (q) =>\n   284→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n   285→      )\n   286→      .unique();\n   287→    if (!user) throw new Error(\"User not found\");\n   288→\n   289→    const original = await ctx.db.get(args.id);\n   290→    if (!original) throw new Error(\"Theme not found\");\n   291→    if (!original.isPublic && original.authorId !== user._id) {\n   292→      throw new Error(\"Not authorized\");\n   293→    }\n   294→\n   295→    const slug = await uniqueSlug(ctx.db, original.name + \" fork\");\n   296→\n   297→    const id = await ctx.db.insert(\"themes\", {\n   298→      name: original.name + \" (fork)\",\n   299→      slug,\n   300→      description: original.description,\n   301→      authorId: user._id,\n   302→      forkedFromId: original._id,\n   303→      isPublic: false,\n   304→      starCount: 0,\n   305→      colors: original.colors,\n   306→      fonts: original.fonts,\n   307→    });\n   308→\n   309→    return { id, slug };\n   310→  },\n   311→});\n   312→"}]},"parent_tool_use_id":"toolu_01AbgCKBbxRYKQDwj1LdXMLq","session_id":"ceec0539-6478-4eeb-897f-84ed3b4ac287","uuid":"209280a9-2d7b-4633-8965-b1bd855faad4","timestamp":"2026-03-27T23:57:07.798Z"}
