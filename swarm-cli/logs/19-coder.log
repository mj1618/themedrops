{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018qbzh7uNDe3qt6QJAEFnfi","type":"tool_result","content":"     1→import { v } from \"convex/values\";\n     2→import { query, mutation } from \"./_generated/server\";\n     3→\n     4→export const listByTheme = query({\n     5→  args: { themeId: v.id(\"themes\") },\n     6→  handler: async (ctx, args) => {\n     7→    const theme = await ctx.db.get(args.themeId);\n     8→    if (!theme) return [];\n     9→    if (!theme.isPublic) {\n    10→      const identity = await ctx.auth.getUserIdentity();\n    11→      if (!identity) return [];\n    12→      const user = await ctx.db\n    13→        .query(\"users\")\n    14→        .withIndex(\"by_token\", (q) =>\n    15→          q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    16→        )\n    17→        .unique();\n    18→      if (!user || theme.authorId !== user._id) return [];\n    19→    }\n    20→\n    21→    const comments = await ctx.db\n    22→      .query(\"comments\")\n    23→      .withIndex(\"by_theme\", (q) => q.eq(\"themeId\", args.themeId))\n    24→      .order(\"asc\")\n    25→      .take(100);\n    26→\n    27→    return Promise.all(\n    28→      comments.map(async (comment) => {\n    29→        const user = await ctx.db.get(comment.userId);\n    30→        return {\n    31→          ...comment,\n    32→          author: user\n    33→            ? {\n    34→                username: user.username,\n    35→                displayName: user.displayName,\n    36→                avatarUrl: user.avatarUrl,\n    37→              }\n    38→            : null,\n    39→        };\n    40→      })\n    41→    );\n    42→  },\n    43→});\n    44→\n    45→export const create = mutation({\n    46→  args: {\n    47→    themeId: v.id(\"themes\"),\n    48→    body: v.string(),\n    49→  },\n    50→  handler: async (ctx, args) => {\n    51→    const identity = await ctx.auth.getUserIdentity();\n    52→    if (!identity) throw new Error(\"Not authenticated\");\n    53→\n    54→    const user = await ctx.db\n    55→      .query(\"users\")\n    56→      .withIndex(\"by_token\", (q) =>\n    57→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    58→      )\n    59→      .unique();\n    60→    if (!user) throw new Error(\"User not found\");\n    61→\n    62→    const theme = await ctx.db.get(args.themeId);\n    63→    if (!theme) throw new Error(\"Theme not found\");\n    64→    if (!theme.isPublic && theme.authorId !== user._id) {\n    65→      throw new Error(\"Not authorized\");\n    66→    }\n    67→\n    68→    return await ctx.db.insert(\"comments\", {\n    69→      userId: user._id,\n    70→      themeId: args.themeId,\n    71→      body: args.body,\n    72→    });\n    73→  },\n    74→});\n    75→\n    76→export const remove = mutation({\n    77→  args: { id: v.id(\"comments\") },\n    78→  handler: async (ctx, args) => {\n    79→    const identity = await ctx.auth.getUserIdentity();\n    80→    if (!identity) throw new Error(\"Not authenticated\");\n    81→\n    82→    const user = await ctx.db\n    83→      .query(\"users\")\n    84→      .withIndex(\"by_token\", (q) =>\n    85→        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n    86→      )\n    87→      .unique();\n    88→    if (!user) throw new Error(\"User not found\");\n    89→\n    90→    const comment = await ctx.db.get(args.id);\n    91→    if (!comment) throw new Error(\"Comment not found\");\n    92→    if (comment.userId !== user._id) throw new Error(\"Not authorized\");\n    93→\n    94→    await ctx.db.delete(args.id);\n    95→  },\n    96→});\n    97→"}]},"parent_tool_use_id":null,"session_id":"2d8cbb2b-c1a2-4d55-970a-911c604b3f71","uuid":"fff1bc73-34fb-4884-ab9d-5259accd3954","timestamp":"2026-03-28T00:17:16.788Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/matt/code/themedrops/app/convex/comments.ts","content":"import { v } from \"convex/values\";\nimport { query, mutation } from \"./_generated/server\";\n\nexport const listByTheme = query({\n  args: { themeId: v.id(\"themes\") },\n  handler: async (ctx, args) => {\n    const theme = await ctx.db.get(args.themeId);\n    if (!theme) return [];\n    if (!theme.isPublic) {\n      const identity = await ctx.auth.getUserIdentity();\n      if (!identity) return [];\n      const user = await ctx.db\n        .query(\"users\")\n        .withIndex(\"by_token\", (q) =>\n          q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n        )\n        .unique();\n      if (!user || theme.authorId !== user._id) return [];\n    }\n\n    const comments = await ctx.db\n      .query(\"comments\")\n      .withIndex(\"by_theme\", (q) => q.eq(\"themeId\", args.themeId))\n      .order(\"asc\")\n      .take(100);\n\n    return Promise.all(\n      comments.map(async (comment) => {\n        const user = await ctx.db.get(comment.userId);\n        return {\n          ...comment,\n          author: user\n            ? {\n                username: user.username,\n                displayName: user.displayName,\n                avatarUrl: user.avatarUrl,\n              }\n            : null,\n        };\n      })\n    );\n  },\n});\n\nexport const create = mutation({\n  args: {\n    themeId: v.id(\"themes\"),\n    body: v.string(),\n  },\n  handler: async (ctx, args) => {\n    const identity = await ctx.auth.getUserIdentity();\n    if (!identity) throw new Error(\"Not authenticated\");\n\n    const user = await ctx.db\n      .query(\"users\")\n      .withIndex(\"by_token\", (q) =>\n        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n      )\n      .unique();\n    if (!user) throw new Error(\"User not found\");\n\n    const theme = await ctx.db.get(args.themeId);\n    if (!theme) throw new Error(\"Theme not found\");\n    if (!theme.isPublic && theme.authorId !== user._id) {\n      throw new Error(\"Not authorized\");\n    }\n\n    return await ctx.db.insert(\"comments\", {\n      userId: user._id,\n      themeId: args.themeId,\n      body: args.body,\n    });\n  },\n});\n\nexport const remove = mutation({\n  args: { id: v.id(\"comments\") },\n  handler: async (ctx, args) => {\n    const identity = await ctx.auth.getUserIdentity();\n    if (!identity) throw new Error(\"Not authenticated\");\n\n    const user = await ctx.db\n      .query(\"users\")\n      .withIndex(\"by_token\", (q) =>\n        q.eq(\"tokenIdentifier\", identity.tokenIdentifier)\n      )\n      .unique();\n    if (!user) throw new Error(\"User not found\");\n\n    const comment = await ctx.db.get(args.id);\n    if (!comment) throw new Error(\"Comment not found\");\n    if (comment.userId !== user._id) throw new Error(\"Not authorized\");\n\n    await ctx.db.delete(args.id);\n  },\n});\n","numLines":97,"startLine":1,"totalLines":97}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017U26iYGbftPXY6mGwdXs8R","type":"tool_result","content":"     1→\"use client\";\n     2→\n     3→import { useParams, useRouter } from \"next/navigation\";\n     4→import { useQuery, useMutation } from \"convex/react\";\n     5→import { api } from \"../../../../convex/_generated/api\";\n     6→import { useState } from \"react\";\n     7→import Link from \"next/link\";\n     8→import AuthControls from \"../../components/AuthControls\";\n     9→import CreateThemeLink from \"../../components/CreateThemeLink\";\n    10→\n    11→const COLOR_LABELS: { key: string; label: string }[] = [\n    12→  { key: \"background\", label: \"Background\" },\n    13→  { key: \"foreground\", label: \"Foreground\" },\n    14→  { key: \"primary\", label: \"Primary\" },\n    15→  { key: \"secondary\", label: \"Secondary\" },\n    16→  { key: \"accent\", label: \"Accent\" },\n    17→  { key: \"muted\", label: \"Muted\" },\n    18→];\n    19→\n    20→const FONT_KEYS = [\"sans\", \"serif\", \"mono\"] as const;\n    21→\n    22→function ColorSwatch({ color, label }: { color: string; label: string }) {\n    23→  return (\n    24→    <div className=\"flex flex-col items-center gap-2\">\n    25→      <div\n    26→        className=\"w-16 h-16 rounded-xl border border-gray-200 shadow-sm\"\n    27→        style={{ backgroundColor: color }}\n    28→      />\n    29→      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n    30→      <span className=\"text-xs font-mono text-gray-400\">{color}</span>\n    31→    </div>\n    32→  );\n    33→}\n    34→\n    35→function EditableColorSwatch({\n    36→  color,\n    37→  label,\n    38→  onChange,\n    39→}: {\n    40→  color: string;\n    41→  label: string;\n    42→  onChange: (value: string) => void;\n    43→}) {\n    44→  return (\n    45→    <div className=\"flex flex-col items-center gap-2\">\n    46→      <label className=\"relative w-16 h-16 rounded-xl border border-gray-200 shadow-sm cursor-pointer overflow-hidden\">\n    47→        <div\n    48→          className=\"absolute inset-0\"\n    49→          style={{ backgroundColor: color }}\n    50→        />\n    51→        <input\n    52→          type=\"color\"\n    53→          value={color}\n    54→          onChange={(e) => onChange(e.target.value)}\n    55→          className=\"absolute inset-0 opacity-0 cursor-pointer\"\n    56→        />\n    57→      </label>\n    58→      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n    59→      <input\n    60→        type=\"text\"\n    61→        value={color}\n    62→        onChange={(e) => onChange(e.target.value)}\n    63→        className=\"text-xs font-mono text-gray-600 w-20 text-center border border-gray-200 rounded px-1 py-0.5 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n    64→      />\n    65→    </div>\n    66→  );\n    67→}\n    68→\n    69→function LivePreview({\n    70→  colors,\n    71→}: {\n    72→  colors: Record<string, string | undefined>;\n    73→}) {\n    74→  return (\n    75→    <div\n    76→      className=\"rounded-xl border p-6 space-y-4\"\n    77→      style={{\n    78→        backgroundColor: colors.background ?? \"#ffffff\",\n    79→        color: colors.foreground ?? \"#000000\",\n    80→        borderColor: colors.muted ?? \"#e5e7eb\",\n    81→      }}\n    82→    >\n    83→      <h3 className=\"text-lg font-semibold\">Live Preview</h3>\n    84→      <p style={{ color: colors.muted ?? \"#6b7280\" }} className=\"text-sm\">\n    85→        This is how the theme looks when applied to a card.\n    86→      </p>\n    87→      <div className=\"flex gap-3\">\n    88→        <button\n    89→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    90→          style={{ backgroundColor: colors.primary ?? \"#3b82f6\" }}\n    91→        >\n    92→          Primary\n    93→        </button>\n    94→        <button\n    95→          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n    96→          style={{ backgroundColor: colors.secondary ?? \"#6366f1\" }}\n    97→        >\n    98→          Secondary\n    99→        </button>\n   100→        <button\n   101→          className=\"px-4 py-2 rounded-lg text-sm font-medium border\"\n   102→          style={{\n   103→            backgroundColor: colors.accent ?? \"#f59e0b\",\n   104→            borderColor: colors.muted ?? \"#e5e7eb\",\n   105→          }}\n   106→        >\n   107→          Accent\n   108→        </button>\n   109→      </div>\n   110→    </div>\n   111→  );\n   112→}\n   113→\n   114→export default function ThemeDetailPage() {\n   115→  const params = useParams<{ slug: string }>();\n   116→  const router = useRouter();\n   117→  const slug = params.slug;\n   118→\n   119→  const theme = useQuery(api.themes.getBySlug, { slug });\n   120→  const author = useQuery(\n   121→    api.users.get,\n   122→    theme ? { id: theme.authorId } : \"skip\"\n   123→  );\n   124→  const currentUser = useQuery(api.users.getCurrentUser);\n   125→\n   126→  // Stars\n   127→  const isStarred = useQuery(\n   128→    api.stars.isStarred,\n   129→    theme ? { themeId: theme._id } : \"skip\"\n   130→  );\n   131→  const toggleStar = useMutation(api.stars.toggle);\n   132→\n   133→  // Comments\n   134→  const comments = useQuery(\n   135→    api.comments.listByTheme,\n   136→    theme ? { themeId: theme._id } : \"skip\"\n   137→  );\n   138→  const createComment = useMutation(api.comments.create);\n   139→  const [commentBody, setCommentBody] = useState(\"\");\n   140→  const [submittingComment, setSubmittingComment] = useState(false);\n   141→\n   142→  // Fork\n   143→  const forkTheme = useMutation(api.themes.fork);\n   144→  const [forking, setForking] = useState(false);\n   145→\n   146→  // Forked-from theme info (for link)\n   147→  const forkedFrom = useQuery(\n   148→    api.themes.getBasicInfo,\n   149→    theme?.forkedFromId ? { id: theme.forkedFromId } : \"skip\"\n   150→  );\n   151→\n   152→  // Edit/Delete mutations\n   153→  const updateTheme = useMutation(api.themes.update);\n   154→  const removeTheme = useMutation(api.themes.remove);\n   155→\n   156→  // Edit mode state\n   157→  const [editing, setEditing] = useState(false);\n   158→  const [editName, setEditName] = useState(\"\");\n   159→  const [editDescription, setEditDescription] = useState(\"\");\n   160→  const [editIsPublic, setEditIsPublic] = useState(true);\n   161→  const [editColors, setEditColors] = useState<Record<string, string>>({});\n   162→  const [editFonts, setEditFonts] = useState<Record<string, string>>({});\n   163→  const [saving, setSaving] = useState(false);\n   164→  const [saveError, setSaveError] = useState<string | null>(null);\n   165→\n   166→  // Delete state\n   167→  const [confirmingDelete, setConfirmingDelete] = useState(false);\n   168→  const [deleting, setDeleting] = useState(false);\n   169→  const [deleteError, setDeleteError] = useState<string | null>(null);\n   170→\n   171→  // Owner detection\n   172→  const isOwner = !!(currentUser && theme && currentUser._id === theme.authorId);\n   173→\n   174→  function enterEditMode() {\n   175→    if (!theme) return;\n   176→    setEditName(theme.name);\n   177→    setEditDescription(theme.description ?? \"\");\n   178→    setEditIsPublic(theme.isPublic);\n   179→    const c: Record<string, string> = {};\n   180→    const themeColors = theme.colors as Record<string, string | undefined>;\n   181→    for (const { key } of COLOR_LABELS) {\n   182→      if (themeColors[key]) c[key] = themeColors[key]!;\n   183→    }\n   184→    setEditColors(c);\n   185→    const f: Record<string, string> = {};\n   186→    if (theme.fonts) {\n   187→      for (const k of FONT_KEYS) {\n   188→        if (theme.fonts[k]) f[k] = theme.fonts[k]!;\n   189→      }\n   190→    }\n   191→    setEditFonts(f);\n   192→    setSaveError(null);\n   193→    setEditing(true);\n   194→  }\n   195→\n   196→  function cancelEdit() {\n   197→    setEditing(false);\n   198→    setSaveError(null);\n   199→  }\n   200→\n   201→  async function handleSave() {\n   202→    if (!theme) return;\n   203→    setSaving(true);\n   204→    setSaveError(null);\n   205→    try {\n   206→      const updates: Record<string, unknown> = { id: theme._id };\n   207→      if (editName !== theme.name) updates.name = editName;\n   208→      if (editDescription !== (theme.description ?? \"\"))\n   209→        updates.description = editDescription;\n   210→      if (editIsPublic !== theme.isPublic) updates.isPublic = editIsPublic;\n   211→\n   212→      // Colors: always send all edited colors\n   213→      const origColors = theme.colors as Record<string, string | undefined>;\n   214→      const colorsChanged = COLOR_LABELS.some(\n   215→        ({ key }) => (editColors[key] ?? \"\") !== (origColors[key] ?? \"\")\n   216→      );\n   217→      if (colorsChanged) updates.colors = editColors;\n   218→\n   219→      // Fonts: send if changed\n   220→      const origFonts = (theme.fonts ?? {}) as Record<string, string | undefined>;\n   221→      const fontsChanged = FONT_KEYS.some(\n   222→        (k) => (editFonts[k] ?? \"\") !== (origFonts[k] ?? \"\")\n   223→      );\n   224→      if (fontsChanged) {\n   225→        const fontPayload: Record<string, string> = {};\n   226→        for (const k of FONT_KEYS) {\n   227→          if (editFonts[k]?.trim()) fontPayload[k] = editFonts[k];\n   228→        }\n   229→        updates.fonts = fontPayload;\n   230→      }\n   231→\n   232→      const result = await updateTheme(updates as Parameters<typeof updateTheme>[0]);\n   233→      setEditing(false);\n   234→\n   235→      // If name changed, the slug changed server-side — redirect using the returned slug\n   236→      if (editName !== theme.name && result?.slug) {\n   237→        router.push(`/theme/${result.slug}`);\n   238→      }\n   239→    } catch (err) {\n   240→      setSaveError(err instanceof Error ? err.message : \"Failed to save\");\n   241→    } finally {\n   242→      setSaving(false);\n   243→    }\n   244→  }\n   245→\n   246→  async function handleDelete() {\n   247→    if (!theme) return;\n   248→    setDeleting(true);\n   249→    setDeleteError(null);\n   250→    try {\n   251→      await removeTheme({ id: theme._id });\n   252→      router.push(\"/\");\n   253→    } catch (err) {\n   254→      setDeleteError(err instanceof Error ? err.message : \"Failed to delete\");\n   255→      setDeleting(false);\n   256→    }\n   257→  }\n   258→\n   259→  // Loading state\n   260→  if (theme === undefined) {\n   261→    return (\n   262→      <div className=\"min-h-screen flex items-center justify-center\">\n   263→        <div className=\"animate-pulse text-gray-400 text-lg\">\n   264→          Loading theme...\n   265→        </div>\n   266→      </div>\n   267→    );\n   268→  }\n   269→\n   270→  // Not found\n   271→  if (theme === null) {\n   272→    return (\n   273→      <div className=\"min-h-screen flex flex-col items-center justify-center gap-4\">\n   274→        <h1 className=\"text-2xl font-bold text-gray-800\">Theme not found</h1>\n   275→        <p className=\"text-gray-500\">\n   276→          This theme doesn&apos;t exist or is private.\n   277→        </p>\n   278→        <a href=\"/\" className=\"text-blue-600 hover:underline text-sm\">\n   279→          Back to gallery\n   280→        </a>\n   281→      </div>\n   282→    );\n   283→  }\n   284→\n   285→  const colors = editing\n   286→    ? (editColors as Record<string, string | undefined>)\n   287→    : (theme.colors as Record<string, string | undefined>);\n   288→\n   289→  async function handleToggleStar() {\n   290→    if (!theme || !currentUser) return;\n   291→    await toggleStar({ themeId: theme._id });\n   292→  }\n   293→\n   294→  async function handleSubmitComment(e: React.FormEvent) {\n   295→    e.preventDefault();\n   296→    if (!theme || !commentBody.trim()) return;\n   297→    setSubmittingComment(true);\n   298→    try {\n   299→      await createComment({ themeId: theme._id, body: commentBody.trim() });\n   300→      setCommentBody(\"\");\n   301→    } finally {\n   302→      setSubmittingComment(false);\n   303→    }\n   304→  }\n   305→\n   306→  async function handleFork() {\n   307→    if (!theme) return;\n   308→    setForking(true);\n   309→    try {\n   310→      const result = await forkTheme({ id: theme._id });\n   311→      if (result) {\n   312→        router.push(`/theme/${result.slug}`);\n   313→      }\n   314→    } catch {\n   315→      // Fork may fail if not authenticated\n   316→    } finally {\n   317→      setForking(false);\n   318→    }\n   319→  }\n   320→\n   321→  return (\n   322→    <div className=\"min-h-screen bg-gray-50\">\n   323→      {/* Header */}\n   324→      <header className=\"bg-white border-b border-gray-200\">\n   325→        <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n   326→          <a\n   327→            href=\"/\"\n   328→            className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n   329→          >\n   330→            ThemeDrops\n   331→          </a>\n   332→          <div className=\"flex items-center gap-3\">\n   333→            <CreateThemeLink />\n   334→            <AuthControls />\n   335→          </div>\n   336→        </div>\n   337→      </header>\n   338→\n   339→      <main className=\"max-w-4xl mx-auto px-6 py-10 space-y-10\">\n   340→        {/* Theme header */}\n   341→        <div className=\"space-y-3\">\n   342→          <div className=\"flex items-start justify-between gap-4\">\n   343→            <div className=\"space-y-1 flex-1\">\n   344→              {editing ? (\n   345→                <input\n   346→                  type=\"text\"\n   347→                  value={editName}\n   348→                  onChange={(e) => setEditName(e.target.value)}\n   349→                  className=\"text-3xl font-bold text-gray-900 w-full border border-gray-300 rounded-lg px-3 py-1 focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   350→                />\n   351→              ) : (\n   352→                <h1 className=\"text-3xl font-bold text-gray-900\">\n   353→                  {theme.name}\n   354→                </h1>\n   355→              )}\n   356→              {author && (\n   357→                <p className=\"text-sm text-gray-500\">\n   358→                  by{\" \"}\n   359→                  <Link\n   360→                    href={`/user/${author.username}`}\n   361→                    className=\"font-medium text-gray-700 hover:text-blue-600 transition-colors\"\n   362→                  >\n   363→                    {author.displayName ?? author.username}\n   364→                  </Link>\n   365→                </p>\n   366→              )}\n   367→            </div>\n   368→\n   369→            <div className=\"flex items-center gap-2\">\n   370→              {/* Owner controls */}\n   371→              {isOwner && !editing && (\n   372→                <>\n   373→                  <button\n   374→                    onClick={enterEditMode}\n   375→                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors\"\n   376→                  >\n   377→                    Edit\n   378→                  </button>\n   379→                  {!confirmingDelete ? (\n   380→                    <button\n   381→                      onClick={() => setConfirmingDelete(true)}\n   382→                      className=\"px-4 py-2 rounded-lg border border-red-200 bg-white text-sm font-medium text-red-600 hover:bg-red-50 transition-colors\"\n   383→                    >\n   384→                      Delete\n   385→                    </button>\n   386→                  ) : (\n   387→                    <div className=\"flex items-center gap-2 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   388→                      <span className=\"text-sm text-red-700\">Delete this theme?</span>\n   389→                      <button\n   390→                        onClick={handleDelete}\n   391→                        disabled={deleting}\n   392→                        className=\"px-3 py-1 rounded bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition-colors disabled:opacity-50\"\n   393→                      >\n   394→                        {deleting ? \"Deleting...\" : \"Confirm\"}\n   395→                      </button>\n   396→                      <button\n   397→                        onClick={() => {\n   398→                          setConfirmingDelete(false);\n   399→                          setDeleteError(null);\n   400→                        }}\n   401→                        disabled={deleting}\n   402→                        className=\"px-3 py-1 rounded border border-red-200 text-sm text-red-600 hover:bg-red-100 transition-colors disabled:opacity-50\"\n   403→                      >\n   404→                        Cancel\n   405→                      </button>\n   406→                    </div>\n   407→                  )}\n   408→                </>\n   409→              )}\n   410→\n   411→              {/* Edit mode controls */}\n   412→              {editing && (\n   413→                <>\n   414→                  <button\n   415→                    onClick={handleSave}\n   416→                    disabled={saving || !editName.trim()}\n   417→                    className=\"px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n   418→                  >\n   419→                    {saving ? \"Saving...\" : \"Save\"}\n   420→                  </button>\n   421→                  <button\n   422→                    onClick={cancelEdit}\n   423→                    disabled={saving}\n   424→                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50\"\n   425→                  >\n   426→                    Cancel\n   427→                  </button>\n   428→                </>\n   429→              )}\n   430→\n   431→              {/* Star button */}\n   432→              {!editing && (\n   433→                <button\n   434→                  onClick={handleToggleStar}\n   435→                  disabled={!currentUser}\n   436→                  className={`flex items-center gap-1.5 px-4 py-2 rounded-lg border text-sm font-medium transition-colors ${\n   437→                    isStarred\n   438→                      ? \"bg-yellow-50 border-yellow-300 text-yellow-700\"\n   439→                      : \"bg-white border-gray-200 text-gray-600 hover:bg-gray-50\"\n   440→                  } ${!currentUser ? \"opacity-50 cursor-not-allowed\" : \"cursor-pointer\"}`}\n   441→                  title={!currentUser ? \"Sign in to star themes\" : undefined}\n   442→                >\n   443→                  <span className=\"text-lg\">\n   444→                    {isStarred ? \"\\u2605\" : \"\\u2606\"}\n   445→                  </span>\n   446→                  <span>{theme.starCount}</span>\n   447→                </button>\n   448→              )}\n   449→            </div>\n   450→          </div>\n   451→\n   452→          {/* Delete error */}\n   453→          {deleteError && (\n   454→            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   455→              {deleteError}\n   456→            </p>\n   457→          )}\n   458→\n   459→          {/* Save error */}\n   460→          {saveError && (\n   461→            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n   462→              {saveError}\n   463→            </p>\n   464→          )}\n   465→\n   466→          {/* Description */}\n   467→          {editing ? (\n   468→            <textarea\n   469→              value={editDescription}\n   470→              onChange={(e) => setEditDescription(e.target.value)}\n   471→              placeholder=\"Theme description...\"\n   472→              rows={3}\n   473→              className=\"w-full text-gray-600 leading-relaxed border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n   474→            />\n   475→          ) : (\n   476→            theme.description && (\n   477→              <p className=\"text-gray-600 leading-relaxed\">\n   478→                {theme.description}\n   479→              </p>\n   480→            )\n   481→          )}\n   482→\n   483→          {/* Visibility toggle */}\n   484→          {editing && (\n   485→            <div className=\"flex items-center gap-3\">\n   486→              <span className=\"text-sm text-gray-600\">Visibility:</span>\n   487→              <button\n   488→                onClick={() => setEditIsPublic(!editIsPublic)}\n   489→                className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${\n   490→                  editIsPublic ? \"bg-blue-600\" : \"bg-gray-300\"\n   491→                }`}\n   492→              >\n   493→                <span\n   494→                  className={`inline-block h-4 w-4 rounded-full bg-white transition-transform ${\n   495→                    editIsPublic ? \"translate-x-6\" : \"translate-x-1\"\n   496→                  }`}\n   497→                />\n   498→              </button>\n   499→              <span className=\"text-sm text-gray-500\">\n   500→                {editIsPublic ? \"Public\" : \"Private\"}\n   501→              </span>\n   502→            </div>\n   503→          )}\n   504→\n   505→          {theme.forkedFromId && forkedFrom && (\n   506→            <p className=\"text-sm text-gray-400 italic\">\n   507→              Forked from{\" \"}\n   508→              <a\n   509→                href={`/theme/${forkedFrom.slug}`}\n   510→                className=\"text-blue-500 hover:underline\"\n   511→              >\n   512→                {forkedFrom.name}\n   513→              </a>\n   514→            </p>\n   515→          )}\n   516→\n   517→          {!editing && (\n   518→            <p className=\"text-xs text-gray-400 font-mono bg-gray-100 inline-block px-2 py-1 rounded\">\n   519→              API: /api/theme/{theme.slug}\n   520→            </p>\n   521→          )}\n   522→        </div>\n   523→\n   524→        {/* Color palette */}\n   525→        <section className=\"space-y-4\">\n   526→          <h2 className=\"text-lg font-semibold text-gray-800\">Color Palette</h2>\n   527→          <div className=\"flex flex-wrap gap-6\">\n   528→            {editing\n   529→              ? COLOR_LABELS.map(({ key, label }) => (\n   530→                  <EditableColorSwatch\n   531→                    key={key}\n   532→                    color={editColors[key] ?? \"#000000\"}\n   533→                    label={label}\n   534→                    onChange={(value) =>\n   535→                      setEditColors((prev) => ({ ...prev, [key]: value }))\n   536→                    }\n   537→                  />\n   538→                ))\n   539→              : COLOR_LABELS.map(({ key, label }) => {\n   540→                  const color = colors[key];\n   541→                  if (!color) return null;\n   542→                  return <ColorSwatch key={key} color={color} label={label} />;\n   543→                })}\n   544→          </div>\n   545→        </section>\n   546→\n   547→        {/* Live preview */}\n   548→        <section className=\"space-y-4\">\n   549→          <h2 className=\"text-lg font-semibold text-gray-800\">Preview</h2>\n   550→          <LivePreview colors={colors} />\n   551→        </section>\n   552→\n   553→        {/* Fonts */}\n   554→        {editing ? (\n   555→          <section className=\"space-y-4\">\n   556→            <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   557→            <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   558→              {FONT_KEYS.map((k) => (\n   559→                <div\n   560→                  key={k}\n   561→                  className=\"bg-white rounded-lg border border-gray-200 p-4\"\n   562→                >\n   563→                  <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   564→                    {k}\n   565→                  </p>\n   566→                  <input\n   567→                    type=\"text\"\n   568→                    value={editFonts[k] ?? \"\"}\n   569→                    onChange={(e) =>\n   570→                      setEditFonts((prev) => ({ ...prev, [k]: e.target.value }))\n   571→                    }\n   572→                    placeholder={`${k} font name`}\n   573→                    className=\"w-full text-sm border border-gray-200 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n   574→                  />\n   575→                  {editFonts[k] && (\n   576→                    <p\n   577→                      className=\"text-sm text-gray-500 mt-2\"\n   578→                      style={{ fontFamily: editFonts[k] }}\n   579→                    >\n   580→                      The quick brown fox jumps over the lazy dog.\n   581→                    </p>\n   582→                  )}\n   583→                </div>\n   584→              ))}\n   585→            </div>\n   586→          </section>\n   587→        ) : (\n   588→          theme.fonts &&\n   589→          (theme.fonts.sans || theme.fonts.serif || theme.fonts.mono) && (\n   590→            <section className=\"space-y-4\">\n   591→              <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n   592→              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n   593→                {theme.fonts.sans && (\n   594→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   595→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   596→                      Sans\n   597→                    </p>\n   598→                    <p\n   599→                      className=\"text-lg\"\n   600→                      style={{ fontFamily: theme.fonts.sans }}\n   601→                    >\n   602→                      {theme.fonts.sans}\n   603→                    </p>\n   604→                    <p\n   605→                      className=\"text-sm text-gray-500 mt-1\"\n   606→                      style={{ fontFamily: theme.fonts.sans }}\n   607→                    >\n   608→                      The quick brown fox jumps over the lazy dog.\n   609→                    </p>\n   610→                  </div>\n   611→                )}\n   612→                {theme.fonts.serif && (\n   613→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   614→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   615→                      Serif\n   616→                    </p>\n   617→                    <p\n   618→                      className=\"text-lg\"\n   619→                      style={{ fontFamily: theme.fonts.serif }}\n   620→                    >\n   621→                      {theme.fonts.serif}\n   622→                    </p>\n   623→                    <p\n   624→                      className=\"text-sm text-gray-500 mt-1\"\n   625→                      style={{ fontFamily: theme.fonts.serif }}\n   626→                    >\n   627→                      The quick brown fox jumps over the lazy dog.\n   628→                    </p>\n   629→                  </div>\n   630→                )}\n   631→                {theme.fonts.mono && (\n   632→                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n   633→                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n   634→                      Mono\n   635→                    </p>\n   636→                    <p\n   637→                      className=\"text-lg font-mono\"\n   638→                      style={{ fontFamily: theme.fonts.mono }}\n   639→                    >\n   640→                      {theme.fonts.mono}\n   641→                    </p>\n   642→                    <p\n   643→                      className=\"text-sm text-gray-500 mt-1\"\n   644→                      style={{ fontFamily: theme.fonts.mono }}\n   645→                    >\n   646→                      The quick brown fox jumps over the lazy dog.\n   647→                    </p>\n   648→                  </div>\n   649→                )}\n   650→              </div>\n   651→            </section>\n   652→          )\n   653→        )}\n   654→\n   655→        {/* Fork button */}\n   656→        {currentUser && !editing && (\n   657→          <div>\n   658→            <button\n   659→              onClick={handleFork}\n   660→              disabled={forking}\n   661→              className=\"px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors disabled:opacity-50\"\n   662→            >\n   663→              {forking ? \"Forking...\" : \"Fork this theme\"}\n   664→            </button>\n   665→          </div>\n   666→        )}\n   667→\n   668→        {/* Comments */}\n   669→        {!editing && (\n   670→          <section className=\"space-y-6\">\n   671→            <h2 className=\"text-lg font-semibold text-gray-800\">\n   672→              Comments{\" \"}\n   673→              {comments && comments.length > 0 && (\n   674→                <span className=\"text-gray-400 font-normal\">\n   675→                  ({comments.length})\n   676→                </span>\n   677→              )}\n   678→            </h2>\n   679→\n   680→            {comments === undefined && (\n   681→              <p className=\"text-gray-400 text-sm animate-pulse\">\n   682→                Loading comments...\n   683→              </p>\n   684→            )}\n   685→\n   686→            {comments && comments.length === 0 && (\n   687→              <p className=\"text-gray-400 text-sm\">No comments yet.</p>\n   688→            )}\n   689→\n   690→            {comments && comments.length > 0 && (\n   691→              <div className=\"space-y-4\">\n   692→                {comments.map((comment) => (\n   693→                  <div\n   694→                    key={comment._id}\n   695→                    className=\"bg-white rounded-lg border border-gray-200 p-4\"\n   696→                  >\n   697→                    <div className=\"flex items-center gap-2 mb-2\">\n   698→                      {comment.author?.avatarUrl && (\n   699→                        <img\n   700→                          src={comment.author.avatarUrl}\n   701→                          alt=\"\"\n   702→                          className=\"w-6 h-6 rounded-full\"\n   703→                        />\n   704→                      )}\n   705→                      <span className=\"text-sm font-medium text-gray-700\">\n   706→                        {comment.author?.displayName ??\n   707→                          comment.author?.username ??\n   708→                          \"Unknown\"}\n   709→                      </span>\n   710→                    </div>\n   711→                    <p className=\"text-sm text-gray-600\">{comment.body}</p>\n   712→                  </div>\n   713→                ))}\n   714→              </div>\n   715→            )}\n   716→\n   717→            {/* Add comment form */}\n   718→            {currentUser && (\n   719→              <form onSubmit={handleSubmitComment} className=\"flex gap-3\">\n   720→                <input\n   721→                  type=\"text\"\n   722→                  value={commentBody}\n   723→                  onChange={(e) => setCommentBody(e.target.value)}\n   724→                  placeholder=\"Add a comment...\"\n   725→                  className=\"flex-1 px-4 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n   726→                />\n   727→                <button\n   728→                  type=\"submit\"\n   729→                  disabled={!commentBody.trim() || submittingComment}\n   730→                  className=\"px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n   731→                >\n   732→                  {submittingComment ? \"Posting...\" : \"Post\"}\n   733→                </button>\n   734→              </form>\n   735→            )}\n   736→          </section>\n   737→        )}\n   738→      </main>\n   739→    </div>\n   740→  );\n   741→}\n   742→"}]},"parent_tool_use_id":null,"session_id":"2d8cbb2b-c1a2-4d55-970a-911c604b3f71","uuid":"35f2c61c-7fea-4cc3-bf97-c6ee19596ec9","timestamp":"2026-03-28T00:17:17.103Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/matt/code/themedrops/app/src/app/theme/[slug]/page.tsx","content":"\"use client\";\n\nimport { useParams, useRouter } from \"next/navigation\";\nimport { useQuery, useMutation } from \"convex/react\";\nimport { api } from \"../../../../convex/_generated/api\";\nimport { useState } from \"react\";\nimport Link from \"next/link\";\nimport AuthControls from \"../../components/AuthControls\";\nimport CreateThemeLink from \"../../components/CreateThemeLink\";\n\nconst COLOR_LABELS: { key: string; label: string }[] = [\n  { key: \"background\", label: \"Background\" },\n  { key: \"foreground\", label: \"Foreground\" },\n  { key: \"primary\", label: \"Primary\" },\n  { key: \"secondary\", label: \"Secondary\" },\n  { key: \"accent\", label: \"Accent\" },\n  { key: \"muted\", label: \"Muted\" },\n];\n\nconst FONT_KEYS = [\"sans\", \"serif\", \"mono\"] as const;\n\nfunction ColorSwatch({ color, label }: { color: string; label: string }) {\n  return (\n    <div className=\"flex flex-col items-center gap-2\">\n      <div\n        className=\"w-16 h-16 rounded-xl border border-gray-200 shadow-sm\"\n        style={{ backgroundColor: color }}\n      />\n      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n      <span className=\"text-xs font-mono text-gray-400\">{color}</span>\n    </div>\n  );\n}\n\nfunction EditableColorSwatch({\n  color,\n  label,\n  onChange,\n}: {\n  color: string;\n  label: string;\n  onChange: (value: string) => void;\n}) {\n  return (\n    <div className=\"flex flex-col items-center gap-2\">\n      <label className=\"relative w-16 h-16 rounded-xl border border-gray-200 shadow-sm cursor-pointer overflow-hidden\">\n        <div\n          className=\"absolute inset-0\"\n          style={{ backgroundColor: color }}\n        />\n        <input\n          type=\"color\"\n          value={color}\n          onChange={(e) => onChange(e.target.value)}\n          className=\"absolute inset-0 opacity-0 cursor-pointer\"\n        />\n      </label>\n      <span className=\"text-xs font-medium text-gray-500\">{label}</span>\n      <input\n        type=\"text\"\n        value={color}\n        onChange={(e) => onChange(e.target.value)}\n        className=\"text-xs font-mono text-gray-600 w-20 text-center border border-gray-200 rounded px-1 py-0.5 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n      />\n    </div>\n  );\n}\n\nfunction LivePreview({\n  colors,\n}: {\n  colors: Record<string, string | undefined>;\n}) {\n  return (\n    <div\n      className=\"rounded-xl border p-6 space-y-4\"\n      style={{\n        backgroundColor: colors.background ?? \"#ffffff\",\n        color: colors.foreground ?? \"#000000\",\n        borderColor: colors.muted ?? \"#e5e7eb\",\n      }}\n    >\n      <h3 className=\"text-lg font-semibold\">Live Preview</h3>\n      <p style={{ color: colors.muted ?? \"#6b7280\" }} className=\"text-sm\">\n        This is how the theme looks when applied to a card.\n      </p>\n      <div className=\"flex gap-3\">\n        <button\n          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n          style={{ backgroundColor: colors.primary ?? \"#3b82f6\" }}\n        >\n          Primary\n        </button>\n        <button\n          className=\"px-4 py-2 rounded-lg text-sm font-medium text-white\"\n          style={{ backgroundColor: colors.secondary ?? \"#6366f1\" }}\n        >\n          Secondary\n        </button>\n        <button\n          className=\"px-4 py-2 rounded-lg text-sm font-medium border\"\n          style={{\n            backgroundColor: colors.accent ?? \"#f59e0b\",\n            borderColor: colors.muted ?? \"#e5e7eb\",\n          }}\n        >\n          Accent\n        </button>\n      </div>\n    </div>\n  );\n}\n\nexport default function ThemeDetailPage() {\n  const params = useParams<{ slug: string }>();\n  const router = useRouter();\n  const slug = params.slug;\n\n  const theme = useQuery(api.themes.getBySlug, { slug });\n  const author = useQuery(\n    api.users.get,\n    theme ? { id: theme.authorId } : \"skip\"\n  );\n  const currentUser = useQuery(api.users.getCurrentUser);\n\n  // Stars\n  const isStarred = useQuery(\n    api.stars.isStarred,\n    theme ? { themeId: theme._id } : \"skip\"\n  );\n  const toggleStar = useMutation(api.stars.toggle);\n\n  // Comments\n  const comments = useQuery(\n    api.comments.listByTheme,\n    theme ? { themeId: theme._id } : \"skip\"\n  );\n  const createComment = useMutation(api.comments.create);\n  const [commentBody, setCommentBody] = useState(\"\");\n  const [submittingComment, setSubmittingComment] = useState(false);\n\n  // Fork\n  const forkTheme = useMutation(api.themes.fork);\n  const [forking, setForking] = useState(false);\n\n  // Forked-from theme info (for link)\n  const forkedFrom = useQuery(\n    api.themes.getBasicInfo,\n    theme?.forkedFromId ? { id: theme.forkedFromId } : \"skip\"\n  );\n\n  // Edit/Delete mutations\n  const updateTheme = useMutation(api.themes.update);\n  const removeTheme = useMutation(api.themes.remove);\n\n  // Edit mode state\n  const [editing, setEditing] = useState(false);\n  const [editName, setEditName] = useState(\"\");\n  const [editDescription, setEditDescription] = useState(\"\");\n  const [editIsPublic, setEditIsPublic] = useState(true);\n  const [editColors, setEditColors] = useState<Record<string, string>>({});\n  const [editFonts, setEditFonts] = useState<Record<string, string>>({});\n  const [saving, setSaving] = useState(false);\n  const [saveError, setSaveError] = useState<string | null>(null);\n\n  // Delete state\n  const [confirmingDelete, setConfirmingDelete] = useState(false);\n  const [deleting, setDeleting] = useState(false);\n  const [deleteError, setDeleteError] = useState<string | null>(null);\n\n  // Owner detection\n  const isOwner = !!(currentUser && theme && currentUser._id === theme.authorId);\n\n  function enterEditMode() {\n    if (!theme) return;\n    setEditName(theme.name);\n    setEditDescription(theme.description ?? \"\");\n    setEditIsPublic(theme.isPublic);\n    const c: Record<string, string> = {};\n    const themeColors = theme.colors as Record<string, string | undefined>;\n    for (const { key } of COLOR_LABELS) {\n      if (themeColors[key]) c[key] = themeColors[key]!;\n    }\n    setEditColors(c);\n    const f: Record<string, string> = {};\n    if (theme.fonts) {\n      for (const k of FONT_KEYS) {\n        if (theme.fonts[k]) f[k] = theme.fonts[k]!;\n      }\n    }\n    setEditFonts(f);\n    setSaveError(null);\n    setEditing(true);\n  }\n\n  function cancelEdit() {\n    setEditing(false);\n    setSaveError(null);\n  }\n\n  async function handleSave() {\n    if (!theme) return;\n    setSaving(true);\n    setSaveError(null);\n    try {\n      const updates: Record<string, unknown> = { id: theme._id };\n      if (editName !== theme.name) updates.name = editName;\n      if (editDescription !== (theme.description ?? \"\"))\n        updates.description = editDescription;\n      if (editIsPublic !== theme.isPublic) updates.isPublic = editIsPublic;\n\n      // Colors: always send all edited colors\n      const origColors = theme.colors as Record<string, string | undefined>;\n      const colorsChanged = COLOR_LABELS.some(\n        ({ key }) => (editColors[key] ?? \"\") !== (origColors[key] ?? \"\")\n      );\n      if (colorsChanged) updates.colors = editColors;\n\n      // Fonts: send if changed\n      const origFonts = (theme.fonts ?? {}) as Record<string, string | undefined>;\n      const fontsChanged = FONT_KEYS.some(\n        (k) => (editFonts[k] ?? \"\") !== (origFonts[k] ?? \"\")\n      );\n      if (fontsChanged) {\n        const fontPayload: Record<string, string> = {};\n        for (const k of FONT_KEYS) {\n          if (editFonts[k]?.trim()) fontPayload[k] = editFonts[k];\n        }\n        updates.fonts = fontPayload;\n      }\n\n      const result = await updateTheme(updates as Parameters<typeof updateTheme>[0]);\n      setEditing(false);\n\n      // If name changed, the slug changed server-side — redirect using the returned slug\n      if (editName !== theme.name && result?.slug) {\n        router.push(`/theme/${result.slug}`);\n      }\n    } catch (err) {\n      setSaveError(err instanceof Error ? err.message : \"Failed to save\");\n    } finally {\n      setSaving(false);\n    }\n  }\n\n  async function handleDelete() {\n    if (!theme) return;\n    setDeleting(true);\n    setDeleteError(null);\n    try {\n      await removeTheme({ id: theme._id });\n      router.push(\"/\");\n    } catch (err) {\n      setDeleteError(err instanceof Error ? err.message : \"Failed to delete\");\n      setDeleting(false);\n    }\n  }\n\n  // Loading state\n  if (theme === undefined) {\n    return (\n      <div className=\"min-h-screen flex items-center justify-center\">\n        <div className=\"animate-pulse text-gray-400 text-lg\">\n          Loading theme...\n        </div>\n      </div>\n    );\n  }\n\n  // Not found\n  if (theme === null) {\n    return (\n      <div className=\"min-h-screen flex flex-col items-center justify-center gap-4\">\n        <h1 className=\"text-2xl font-bold text-gray-800\">Theme not found</h1>\n        <p className=\"text-gray-500\">\n          This theme doesn&apos;t exist or is private.\n        </p>\n        <a href=\"/\" className=\"text-blue-600 hover:underline text-sm\">\n          Back to gallery\n        </a>\n      </div>\n    );\n  }\n\n  const colors = editing\n    ? (editColors as Record<string, string | undefined>)\n    : (theme.colors as Record<string, string | undefined>);\n\n  async function handleToggleStar() {\n    if (!theme || !currentUser) return;\n    await toggleStar({ themeId: theme._id });\n  }\n\n  async function handleSubmitComment(e: React.FormEvent) {\n    e.preventDefault();\n    if (!theme || !commentBody.trim()) return;\n    setSubmittingComment(true);\n    try {\n      await createComment({ themeId: theme._id, body: commentBody.trim() });\n      setCommentBody(\"\");\n    } finally {\n      setSubmittingComment(false);\n    }\n  }\n\n  async function handleFork() {\n    if (!theme) return;\n    setForking(true);\n    try {\n      const result = await forkTheme({ id: theme._id });\n      if (result) {\n        router.push(`/theme/${result.slug}`);\n      }\n    } catch {\n      // Fork may fail if not authenticated\n    } finally {\n      setForking(false);\n    }\n  }\n\n  return (\n    <div className=\"min-h-screen bg-gray-50\">\n      {/* Header */}\n      <header className=\"bg-white border-b border-gray-200\">\n        <div className=\"max-w-4xl mx-auto px-6 py-4 flex items-center justify-between\">\n          <a\n            href=\"/\"\n            className=\"text-lg font-bold tracking-tight text-gray-900 hover:text-gray-600 transition-colors\"\n          >\n            ThemeDrops\n          </a>\n          <div className=\"flex items-center gap-3\">\n            <CreateThemeLink />\n            <AuthControls />\n          </div>\n        </div>\n      </header>\n\n      <main className=\"max-w-4xl mx-auto px-6 py-10 space-y-10\">\n        {/* Theme header */}\n        <div className=\"space-y-3\">\n          <div className=\"flex items-start justify-between gap-4\">\n            <div className=\"space-y-1 flex-1\">\n              {editing ? (\n                <input\n                  type=\"text\"\n                  value={editName}\n                  onChange={(e) => setEditName(e.target.value)}\n                  className=\"text-3xl font-bold text-gray-900 w-full border border-gray-300 rounded-lg px-3 py-1 focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                />\n              ) : (\n                <h1 className=\"text-3xl font-bold text-gray-900\">\n                  {theme.name}\n                </h1>\n              )}\n              {author && (\n                <p className=\"text-sm text-gray-500\">\n                  by{\" \"}\n                  <Link\n                    href={`/user/${author.username}`}\n                    className=\"font-medium text-gray-700 hover:text-blue-600 transition-colors\"\n                  >\n                    {author.displayName ?? author.username}\n                  </Link>\n                </p>\n              )}\n            </div>\n\n            <div className=\"flex items-center gap-2\">\n              {/* Owner controls */}\n              {isOwner && !editing && (\n                <>\n                  <button\n                    onClick={enterEditMode}\n                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors\"\n                  >\n                    Edit\n                  </button>\n                  {!confirmingDelete ? (\n                    <button\n                      onClick={() => setConfirmingDelete(true)}\n                      className=\"px-4 py-2 rounded-lg border border-red-200 bg-white text-sm font-medium text-red-600 hover:bg-red-50 transition-colors\"\n                    >\n                      Delete\n                    </button>\n                  ) : (\n                    <div className=\"flex items-center gap-2 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n                      <span className=\"text-sm text-red-700\">Delete this theme?</span>\n                      <button\n                        onClick={handleDelete}\n                        disabled={deleting}\n                        className=\"px-3 py-1 rounded bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition-colors disabled:opacity-50\"\n                      >\n                        {deleting ? \"Deleting...\" : \"Confirm\"}\n                      </button>\n                      <button\n                        onClick={() => {\n                          setConfirmingDelete(false);\n                          setDeleteError(null);\n                        }}\n                        disabled={deleting}\n                        className=\"px-3 py-1 rounded border border-red-200 text-sm text-red-600 hover:bg-red-100 transition-colors disabled:opacity-50\"\n                      >\n                        Cancel\n                      </button>\n                    </div>\n                  )}\n                </>\n              )}\n\n              {/* Edit mode controls */}\n              {editing && (\n                <>\n                  <button\n                    onClick={handleSave}\n                    disabled={saving || !editName.trim()}\n                    className=\"px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n                  >\n                    {saving ? \"Saving...\" : \"Save\"}\n                  </button>\n                  <button\n                    onClick={cancelEdit}\n                    disabled={saving}\n                    className=\"px-4 py-2 rounded-lg border border-gray-200 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors disabled:opacity-50\"\n                  >\n                    Cancel\n                  </button>\n                </>\n              )}\n\n              {/* Star button */}\n              {!editing && (\n                <button\n                  onClick={handleToggleStar}\n                  disabled={!currentUser}\n                  className={`flex items-center gap-1.5 px-4 py-2 rounded-lg border text-sm font-medium transition-colors ${\n                    isStarred\n                      ? \"bg-yellow-50 border-yellow-300 text-yellow-700\"\n                      : \"bg-white border-gray-200 text-gray-600 hover:bg-gray-50\"\n                  } ${!currentUser ? \"opacity-50 cursor-not-allowed\" : \"cursor-pointer\"}`}\n                  title={!currentUser ? \"Sign in to star themes\" : undefined}\n                >\n                  <span className=\"text-lg\">\n                    {isStarred ? \"\\u2605\" : \"\\u2606\"}\n                  </span>\n                  <span>{theme.starCount}</span>\n                </button>\n              )}\n            </div>\n          </div>\n\n          {/* Delete error */}\n          {deleteError && (\n            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n              {deleteError}\n            </p>\n          )}\n\n          {/* Save error */}\n          {saveError && (\n            <p className=\"text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2\">\n              {saveError}\n            </p>\n          )}\n\n          {/* Description */}\n          {editing ? (\n            <textarea\n              value={editDescription}\n              onChange={(e) => setEditDescription(e.target.value)}\n              placeholder=\"Theme description...\"\n              rows={3}\n              className=\"w-full text-gray-600 leading-relaxed border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n            />\n          ) : (\n            theme.description && (\n              <p className=\"text-gray-600 leading-relaxed\">\n                {theme.description}\n              </p>\n            )\n          )}\n\n          {/* Visibility toggle */}\n          {editing && (\n            <div className=\"flex items-center gap-3\">\n              <span className=\"text-sm text-gray-600\">Visibility:</span>\n              <button\n                onClick={() => setEditIsPublic(!editIsPublic)}\n                className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${\n                  editIsPublic ? \"bg-blue-600\" : \"bg-gray-300\"\n                }`}\n              >\n                <span\n                  className={`inline-block h-4 w-4 rounded-full bg-white transition-transform ${\n                    editIsPublic ? \"translate-x-6\" : \"translate-x-1\"\n                  }`}\n                />\n              </button>\n              <span className=\"text-sm text-gray-500\">\n                {editIsPublic ? \"Public\" : \"Private\"}\n              </span>\n            </div>\n          )}\n\n          {theme.forkedFromId && forkedFrom && (\n            <p className=\"text-sm text-gray-400 italic\">\n              Forked from{\" \"}\n              <a\n                href={`/theme/${forkedFrom.slug}`}\n                className=\"text-blue-500 hover:underline\"\n              >\n                {forkedFrom.name}\n              </a>\n            </p>\n          )}\n\n          {!editing && (\n            <p className=\"text-xs text-gray-400 font-mono bg-gray-100 inline-block px-2 py-1 rounded\">\n              API: /api/theme/{theme.slug}\n            </p>\n          )}\n        </div>\n\n        {/* Color palette */}\n        <section className=\"space-y-4\">\n          <h2 className=\"text-lg font-semibold text-gray-800\">Color Palette</h2>\n          <div className=\"flex flex-wrap gap-6\">\n            {editing\n              ? COLOR_LABELS.map(({ key, label }) => (\n                  <EditableColorSwatch\n                    key={key}\n                    color={editColors[key] ?? \"#000000\"}\n                    label={label}\n                    onChange={(value) =>\n                      setEditColors((prev) => ({ ...prev, [key]: value }))\n                    }\n                  />\n                ))\n              : COLOR_LABELS.map(({ key, label }) => {\n                  const color = colors[key];\n                  if (!color) return null;\n                  return <ColorSwatch key={key} color={color} label={label} />;\n                })}\n          </div>\n        </section>\n\n        {/* Live preview */}\n        <section className=\"space-y-4\">\n          <h2 className=\"text-lg font-semibold text-gray-800\">Preview</h2>\n          <LivePreview colors={colors} />\n        </section>\n\n        {/* Fonts */}\n        {editing ? (\n          <section className=\"space-y-4\">\n            <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n            <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n              {FONT_KEYS.map((k) => (\n                <div\n                  key={k}\n                  className=\"bg-white rounded-lg border border-gray-200 p-4\"\n                >\n                  <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                    {k}\n                  </p>\n                  <input\n                    type=\"text\"\n                    value={editFonts[k] ?? \"\"}\n                    onChange={(e) =>\n                      setEditFonts((prev) => ({ ...prev, [k]: e.target.value }))\n                    }\n                    placeholder={`${k} font name`}\n                    className=\"w-full text-sm border border-gray-200 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500\"\n                  />\n                  {editFonts[k] && (\n                    <p\n                      className=\"text-sm text-gray-500 mt-2\"\n                      style={{ fontFamily: editFonts[k] }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  )}\n                </div>\n              ))}\n            </div>\n          </section>\n        ) : (\n          theme.fonts &&\n          (theme.fonts.sans || theme.fonts.serif || theme.fonts.mono) && (\n            <section className=\"space-y-4\">\n              <h2 className=\"text-lg font-semibold text-gray-800\">Fonts</h2>\n              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4\">\n                {theme.fonts.sans && (\n                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                      Sans\n                    </p>\n                    <p\n                      className=\"text-lg\"\n                      style={{ fontFamily: theme.fonts.sans }}\n                    >\n                      {theme.fonts.sans}\n                    </p>\n                    <p\n                      className=\"text-sm text-gray-500 mt-1\"\n                      style={{ fontFamily: theme.fonts.sans }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  </div>\n                )}\n                {theme.fonts.serif && (\n                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                      Serif\n                    </p>\n                    <p\n                      className=\"text-lg\"\n                      style={{ fontFamily: theme.fonts.serif }}\n                    >\n                      {theme.fonts.serif}\n                    </p>\n                    <p\n                      className=\"text-sm text-gray-500 mt-1\"\n                      style={{ fontFamily: theme.fonts.serif }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  </div>\n                )}\n                {theme.fonts.mono && (\n                  <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <p className=\"text-xs text-gray-400 uppercase tracking-wide mb-1\">\n                      Mono\n                    </p>\n                    <p\n                      className=\"text-lg font-mono\"\n                      style={{ fontFamily: theme.fonts.mono }}\n                    >\n                      {theme.fonts.mono}\n                    </p>\n                    <p\n                      className=\"text-sm text-gray-500 mt-1\"\n                      style={{ fontFamily: theme.fonts.mono }}\n                    >\n                      The quick brown fox jumps over the lazy dog.\n                    </p>\n                  </div>\n                )}\n              </div>\n            </section>\n          )\n        )}\n\n        {/* Fork button */}\n        {currentUser && !editing && (\n          <div>\n            <button\n              onClick={handleFork}\n              disabled={forking}\n              className=\"px-5 py-2.5 rounded-lg bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors disabled:opacity-50\"\n            >\n              {forking ? \"Forking...\" : \"Fork this theme\"}\n            </button>\n          </div>\n        )}\n\n        {/* Comments */}\n        {!editing && (\n          <section className=\"space-y-6\">\n            <h2 className=\"text-lg font-semibold text-gray-800\">\n              Comments{\" \"}\n              {comments && comments.length > 0 && (\n                <span className=\"text-gray-400 font-normal\">\n                  ({comments.length})\n                </span>\n              )}\n            </h2>\n\n            {comments === undefined && (\n              <p className=\"text-gray-400 text-sm animate-pulse\">\n                Loading comments...\n              </p>\n            )}\n\n            {comments && comments.length === 0 && (\n              <p className=\"text-gray-400 text-sm\">No comments yet.</p>\n            )}\n\n            {comments && comments.length > 0 && (\n              <div className=\"space-y-4\">\n                {comments.map((comment) => (\n                  <div\n                    key={comment._id}\n                    className=\"bg-white rounded-lg border border-gray-200 p-4\"\n                  >\n                    <div className=\"flex items-center gap-2 mb-2\">\n                      {comment.author?.avatarUrl && (\n                        <img\n                          src={comment.author.avatarUrl}\n                          alt=\"\"\n                          className=\"w-6 h-6 rounded-full\"\n                        />\n                      )}\n                      <span className=\"text-sm font-medium text-gray-700\">\n                        {comment.author?.displayName ??\n                          comment.author?.username ??\n                          \"Unknown\"}\n                      </span>\n                    </div>\n                    <p className=\"text-sm text-gray-600\">{comment.body}</p>\n                  </div>\n                ))}\n              </div>\n            )}\n\n            {/* Add comment form */}\n            {currentUser && (\n              <form onSubmit={handleSubmitComment} className=\"flex gap-3\">\n                <input\n                  type=\"text\"\n                  value={commentBody}\n                  onChange={(e) => setCommentBody(e.target.value)}\n                  placeholder=\"Add a comment...\"\n                  className=\"flex-1 px-4 py-2 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n                />\n                <button\n                  type=\"submit\"\n                  disabled={!commentBody.trim() || submittingComment}\n                  className=\"px-5 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-500 transition-colors disabled:opacity-50\"\n                >\n                  {submittingComment ? \"Posting...\" : \"Post\"}\n                </button>\n              </form>\n            )}\n          </section>\n        )}\n      </main>\n    </div>\n  );\n}\n","numLines":742,"startLine":1,"totalLines":742}}}
